#
# Action Ontology
#
# Actions are events with a deliberate agent. Not every event has an agent
# (e.g. an earthquake just happens), but when Túrin slays Glaurung, that's
# an action because he chose to do it.
#
# Action is defined using equivalentClass. Any event with an agent
# gets classified as an action.
#

@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix loc:  <https://example.org/story/place#> .
@prefix evt:  <https://example.org/story/event#> .
@prefix act:  <https://example.org/story/action#> .

act: a owl:Ontology ;
    owl:imports <event.ttl>, <place.ttl> ;
    rdfs:label "Action Ontology"@en ;
    dct:title "Action Ontology"@en ;
    rdfs:comment "Actions as a subclass of events, defined by having an intentional agent."@en ;
    owl:versionInfo "1.0" ;
    dct:created "2026-03-28T00:00:00Z"^^xsd:dateTime .

###############################################################
# Action = Event with an agent
###############################################################

act:Action a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            evt:Event
            [ a owl:Restriction ;
              owl:onProperty evt:hasAgent ;
              owl:someValuesFrom owl:Thing ]
        )
    ] ;
    rdfs:label "Action"@en ;
    rdfs:comment "An event with a deliberate agent. Any event that has an agent gets classified as an action."@en .

###############################################################
# Action types
###############################################################

act:MoveAction a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            evt:Journey
            [ a owl:Restriction ;
              owl:onProperty evt:hasAgent ;
              owl:someValuesFrom owl:Thing ]
        )
    ] ;
    rdfs:label "Move action"@en ;
    rdfs:comment "A journey performed by a deliberate agent. Since hasTraveler is a sub-property of hasAgent, every journey with a traveler is a MoveAction."@en .

act:AttackAction a owl:Class ;
    rdfs:subClassOf act:Action,
    [ a owl:Restriction ;
      owl:onProperty act:hasPatient ;
      owl:someValuesFrom owl:Thing ] ;
    rdfs:label "Attack action"@en ;
    rdfs:comment "A hostile action directed at a patient. Left as a conservative subclass rather than a defined class, because patienthood alone would wrongly classify non-violent actions such as curses as attacks."@en .

act:UseItemAction a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            act:Action
            [ a owl:Restriction ;
              owl:onProperty evt:usesItem ;
              owl:someValuesFrom evt:Item ]
        )
    ] ;
    rdfs:label "Use-item action"@en ;
    rdfs:comment "An action that involves an item. Any action with usesItem is classified here."@en .

act:SpeechAction a owl:Class ;
    rdfs:subClassOf act:Action ;
    rdfs:label "Speech action"@en ;
    rdfs:comment "Deliberate speech: commands, declarations, curses, prophecies."@en .

act:CurseAction a owl:Class ;
    rdfs:subClassOf act:SpeechAction ;
    rdfs:label "Curse action"@en ;
    rdfs:comment "Placing a curse on someone. In the Narn, Morgoth curses the children of Húrin."@en .

act:CurseAction rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty act:hasPatient ;
      owl:someValuesFrom owl:Thing ] .

# A curse results in an ongoing state (captivity, exile, transformation),
# not a physical event.
act:CurseAction rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty act:resultsIn ;
      owl:allValuesFrom evt:State ] .

# An attack must result in something (at minimum).
act:AttackAction rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty act:resultsIn ;
      owl:someValuesFrom evt:Event ] .

# Action subtypes are pairwise disjoint (a curse is not an attack, etc.)
[] a owl:AllDisjointClasses ;
    owl:members ( act:MoveAction act:AttackAction act:SpeechAction ) .

###############################################################
# Properties
###############################################################

act:hasAgent a owl:ObjectProperty ;
    rdfs:subPropertyOf evt:hasAgent ;
    # No domain here, inherited from evt:hasAgent. Using this property
    # will trigger the equivalentClass and classify the individual as Action.
    rdfs:label "has agent"@en ;
    rdfs:comment "Who deliberately performs the action. Sub-property of evt:hasAgent."@en .

act:hasPatient a owl:ObjectProperty ;
    rdfs:subPropertyOf evt:hasPatient ;
    rdfs:domain act:Action ;
    rdfs:label "has patient"@en ;
    rdfs:comment "Who is affected by the action."@en .

act:resultsIn a owl:ObjectProperty ;
    rdfs:domain act:Action ;
    rdfs:range evt:Event ;
    rdfs:label "results in"@en ;
    rdfs:comment "What happens as a consequence of the action, e.g. an attack results in a death."@en .

act:hasPurpose a owl:DatatypeProperty ;
    rdfs:domain act:Action ;
    rdfs:range xsd:string ;
    rdfs:label "has purpose"@en ;
    rdfs:comment "Why the agent performed the action (textual description)."@en .

###############################################################
# Cross-module chains from actions
###############################################################

# If an action results in a death, the agent of the action killed
# the deceased. Chain: agent <-- action --> resultsIn --> death --> deceased
evt:killed owl:propertyChainAxiom (
    [ owl:inverseOf act:hasAgent ]
    act:resultsIn
    evt:hasDeceased
) .

# NOTE: The chain inv(resultsIn) . usesItem => usesItem was removed
# because it makes usesItem non-simple, breaking cardinality and
# irreflexivity axioms. Murder weapon queries use SPARQL instead.

###############################################################
# Additional action restrictions
###############################################################


# An action has at most 1 purpose string.
act:Action rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty act:hasPurpose ;
      owl:maxCardinality "1"^^xsd:nonNegativeInteger ] .

# An attack action results only in physical or social events
# (not in states — an attack doesn't result in a reign).
act:AttackAction rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty act:resultsIn ;
      owl:allValuesFrom [ a owl:Class ;
          owl:unionOf ( evt:PhysicalEvent evt:SocialEvent ) ] ] .

# A speech action has at least 1 speaker. Since hasSpeaker is a
# sub-property of hasAgent, the agent must be a speaker specifically.
act:SpeechAction rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty evt:hasSpeaker ;
      owl:someValuesFrom owl:Thing ] .
