#
# Event Ontology
#
# Events, their types, participant roles, and connections to time/place/items.
#
# Events are organised as PhysicalEvent, SocialEvent, or State, with more
# specific types under each (Birth, Death, Marriage, Battle, Journey, etc.).
#
# Specific event types have specialised roles with cardinality constraints.
# E.g. Marriage has hasHusband/hasWife/hasOfficiant (not generic spouse1/spouse2).
#
# Event-level temporal relations (beforeEvent, etc.) are derived from
# Allen's interval relations via property chains.
#

@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix fo:   <http://purl.org/family/> .
@prefix meo:  <http://purl.org/meo/> .
@prefix soc:  <https://example.org/story/social#> .
@prefix loc:  <https://example.org/story/place#> .
@prefix tm:   <https://example.org/story/time#> .
@prefix evt:  <https://example.org/story/event#> .

evt: a owl:Ontology ;
    owl:imports <place.ttl>, <time.ttl>, <fo.ttl>, <soc.ttl> ;
    rdfs:label "Event Ontology"@en ;
    dct:title "Event Ontology"@en ;
    rdfs:comment "Events in story plots: occurrences involving characters, places, and time. Includes an event hierarchy, participant roles, and temporal relations."@en ;
    owl:versionInfo "1.0" ;
    dct:created "2026-03-28T00:00:00Z"^^xsd:dateTime .

###############################################################
# Top-level Event class
###############################################################

evt:Event a owl:Class ;
    rdfs:label "Event"@en ;
    rdfs:comment "Something that happens in the story world, with a time, place, and participants."@en ;
    rdfs:seeAlso <http://purl.org/NET/c4dm/event.owl#Event>,
                 <http://schema.org/Event> .

###############################################################
# Event hierarchy
###############################################################

evt:PhysicalEvent a owl:Class ;
    rdfs:subClassOf evt:Event ;
    rdfs:label "Physical event"@en ;
    rdfs:comment "Events with physical consequences: battles, journeys, disasters."@en .

evt:SocialEvent a owl:Class ;
    rdfs:subClassOf evt:Event ;
    rdfs:label "Social event"@en ;
    rdfs:comment "Events with social significance: births, deaths, marriages, coronations."@en .

evt:State a owl:Class ;
    rdfs:subClassOf evt:Event ;
    rdfs:label "State"@en ;
    rdfs:comment "An ongoing state of affairs: a residence, captivity, or reign."@en .

# --- Social events ---

evt:Birth a owl:Class ;
    rdfs:subClassOf evt:SocialEvent ;
    rdfs:label "Birth"@en ;
    rdfs:comment "The birth of a character."@en .

evt:Death a owl:Class ;
    rdfs:subClassOf evt:SocialEvent ;
    rdfs:label "Death"@en ;
    rdfs:comment "The death of a character."@en .

evt:Marriage a owl:Class ;
    rdfs:subClassOf evt:SocialEvent ;
    rdfs:label "Marriage"@en ;
    rdfs:comment "A marriage event with husband, wife, and officiant roles."@en .

evt:Meeting a owl:Class ;
    rdfs:subClassOf evt:SocialEvent ;
    rdfs:label "Meeting"@en ;
    rdfs:comment "Two or more characters encounter each other."@en .

evt:Conversation a owl:Class ;
    rdfs:subClassOf evt:Meeting ;
    rdfs:label "Conversation"@en ;
    rdfs:comment "A meeting involving verbal exchange."@en .

evt:Coronation a owl:Class ;
    rdfs:subClassOf evt:SocialEvent ;
    rdfs:label "Coronation"@en ;
    rdfs:comment "An event in which a character is crowned or given authority."@en .

evt:Captivity a owl:Class ;
    rdfs:subClassOf evt:State ;
    rdfs:label "Captivity"@en ;
    rdfs:comment "Being held prisoner."@en .

# --- Physical events ---

evt:Journey a owl:Class ;
    rdfs:subClassOf evt:PhysicalEvent ;
    rdfs:label "Journey"@en ;
    rdfs:comment "Moving from one place to another."@en .

evt:Battle a owl:Class ;
    rdfs:subClassOf evt:PhysicalEvent ;
    rdfs:label "Battle"@en ;
    rdfs:comment "A violent confrontation."@en .

evt:War a owl:Class ;
    rdfs:subClassOf evt:PhysicalEvent ;
    rdfs:label "War"@en ;
    rdfs:comment "A prolonged conflict made up of multiple battles."@en .

evt:NaturalDisaster a owl:Class ;
    rdfs:subClassOf evt:PhysicalEvent ;
    rdfs:label "Natural disaster"@en ;
    rdfs:comment "A catastrophic natural event such as a flood, earthquake, or volcanic eruption."@en .

# --- States ---

evt:Residence a owl:Class ;
    rdfs:subClassOf evt:State ;
    rdfs:label "Residence"@en ;
    rdfs:comment "A state of living at a particular place for a period of time."@en .

evt:Reign a owl:Class ;
    rdfs:subClassOf evt:State ;
    rdfs:label "Reign"@en ;
    rdfs:comment "A state of ruling over a realm or people."@en .

# The three top-level event categories are pairwise disjoint.
[] a owl:AllDisjointClasses ;
    owl:members ( evt:PhysicalEvent evt:SocialEvent evt:State ) .

# Social event subtypes
[] a owl:AllDisjointClasses ;
    owl:members ( evt:Birth evt:Death evt:Marriage evt:Meeting evt:Coronation ) .

# Physical event subtypes
[] a owl:AllDisjointClasses ;
    owl:members ( evt:Journey evt:Battle evt:War evt:NaturalDisaster ) .

# State subtypes
[] a owl:AllDisjointClasses ;
    owl:members ( evt:Residence evt:Captivity evt:Reign ) .

###############################################################
# Item classes (objects used in events)
###############################################################

evt:Item a owl:Class ;
    rdfs:label "Item"@en ;
    rdfs:comment "A significant object that can be used in events. Items include weapons, vehicles, and artifacts."@en .

evt:Weapon a owl:Class ;
    rdfs:subClassOf evt:Item ;
    rdfs:label "Weapon"@en ;
    rdfs:comment "An object designed or used for combat. Example: Gurthang (Túrin's sword)."@en .

evt:Vehicle a owl:Class ;
    rdfs:subClassOf evt:Item ;
    rdfs:label "Vehicle"@en ;
    rdfs:comment "A means of transport used in a journey."@en .

evt:Artifact a owl:Class ;
    rdfs:subClassOf evt:Item ;
    rdfs:label "Artifact"@en ;
    rdfs:comment "A crafted object of special significance, such as a jewel, ring, or magical item."@en .

evt:Weapon owl:disjointWith evt:Vehicle .

###############################################################
# Faction class (collective actors in battles)
###############################################################

evt:Faction a owl:Class ;
    rdfs:label "Faction"@en ;
    rdfs:comment "A collective side in a conflict. Used as combatant in battles instead of individual characters when the conflict involves armies rather than individuals."@en .

###############################################################
# Participant properties
###############################################################

evt:hasParticipant a owl:ObjectProperty ;
    rdfs:domain evt:Event ;
    rdfs:label "has participant"@en ;
    rdfs:comment "A character involved in the event."@en .

evt:participatesIn a owl:ObjectProperty ;
    owl:inverseOf evt:hasParticipant ;
    rdfs:label "participates in"@en ;
    rdfs:comment "Inverse of hasParticipant."@en .

evt:hasAgent a owl:ObjectProperty ;
    rdfs:subPropertyOf evt:hasParticipant ;
    rdfs:domain evt:Event ;
    rdfs:label "has agent"@en ;
    rdfs:comment "The active performer of the event."@en .

evt:hasPatient a owl:ObjectProperty ;
    rdfs:subPropertyOf evt:hasParticipant ;
    rdfs:domain evt:Event ;
    rdfs:label "has patient"@en ;
    rdfs:comment "The character affected by the event."@en .

# --- Birth-specific roles ---

evt:hasNewborn a owl:ObjectProperty ;
    rdfs:subPropertyOf evt:hasParticipant ;
    rdfs:domain evt:Birth ;
    rdfs:label "has newborn"@en ;
    rdfs:comment "The character born."@en .

evt:hasMother a owl:ObjectProperty ;
    rdfs:subPropertyOf evt:hasParticipant ;
    rdfs:domain evt:Birth ;
    rdfs:range fo:Female ;
    rdfs:label "has mother"@en ;
    rdfs:comment "The mother. Range fo:Female."@en .

evt:hasFather a owl:ObjectProperty ;
    rdfs:subPropertyOf evt:hasParticipant ;
    rdfs:domain evt:Birth ;
    rdfs:range fo:Male ;
    rdfs:label "has father"@en ;
    rdfs:comment "The father. Range fo:Male."@en .

# --- Death-specific roles ---

evt:hasDeceased a owl:ObjectProperty ;
    rdfs:subPropertyOf evt:hasParticipant ;
    rdfs:domain evt:Death ;
    rdfs:label "has deceased"@en ;
    rdfs:comment "The character who dies."@en .

evt:hasKiller a owl:ObjectProperty ;
    rdfs:subPropertyOf evt:hasParticipant ;
    rdfs:domain evt:Death ;
    rdfs:label "has killer"@en ;
    rdfs:comment "Who caused the death, if anyone."@en .

# --- Marriage-specific roles ---

evt:hasHusband a owl:ObjectProperty ;
    rdfs:subPropertyOf evt:hasParticipant ;
    rdfs:domain evt:Marriage ;
    rdfs:range fo:Male ;
    rdfs:label "has husband"@en ;
    rdfs:comment "The husband in the marriage."@en .

evt:hasWife a owl:ObjectProperty ;
    rdfs:subPropertyOf evt:hasParticipant ;
    rdfs:domain evt:Marriage ;
    rdfs:range fo:Female ;
    rdfs:label "has wife"@en ;
    rdfs:comment "The wife in the marriage."@en .

evt:hasOfficiant a owl:ObjectProperty ;
    rdfs:subPropertyOf evt:hasParticipant ;
    rdfs:domain evt:Marriage ;
    rdfs:label "has officiant"@en ;
    rdfs:comment "The authority who validates the marriage (priest, king, etc.)."@en .

# Husband and wife must be different individuals in a marriage
evt:hasHusband owl:propertyDisjointWith evt:hasWife .

# Father and mother must be different in a birth
evt:hasFather owl:propertyDisjointWith evt:hasMother .

# --- Journey-specific roles ---

evt:hasTraveler a owl:ObjectProperty ;
    rdfs:subPropertyOf evt:hasParticipant ;
    rdfs:domain evt:Journey ;
    rdfs:label "has traveler"@en ;
    rdfs:comment "A character undertaking the journey."@en .

evt:hasOrigin a owl:ObjectProperty ;
    rdfs:domain evt:Journey ;
    rdfs:range loc:Place ;
    rdfs:label "has origin"@en ;
    rdfs:comment "The starting place of a journey."@en .

evt:hasDestination a owl:ObjectProperty ;
    rdfs:domain evt:Journey ;
    rdfs:range loc:Place ;
    rdfs:label "has destination"@en ;
    rdfs:comment "The destination place of a journey."@en .

# --- Battle-specific roles ---

evt:hasCombatant a owl:ObjectProperty ;
    rdfs:subPropertyOf evt:hasParticipant ;
    rdfs:domain evt:Battle ;
    rdfs:label "has combatant"@en ;
    rdfs:comment "A combatant side or individual fighting in the battle."@en .

evt:hasVictor a owl:ObjectProperty ;
    rdfs:subPropertyOf evt:hasCombatant ;
    rdfs:domain evt:Battle ;
    rdfs:label "has victor"@en ;
    rdfs:comment "The winning side of a battle."@en .

# --- Conversation-specific roles ---

evt:hasSpeaker a owl:ObjectProperty ;
    rdfs:subPropertyOf evt:hasParticipant ;
    rdfs:domain evt:Conversation ;
    rdfs:label "has speaker"@en ;
    rdfs:comment "A character who speaks during the conversation."@en .

# --- Residence-specific ---

evt:hasResident a owl:ObjectProperty ;
    rdfs:subPropertyOf evt:hasParticipant ;
    rdfs:domain evt:Residence ;
    rdfs:label "has resident"@en ;
    rdfs:comment "The character residing at a place."@en .

# --- Captivity-specific ---

evt:hasCaptive a owl:ObjectProperty ;
    rdfs:subPropertyOf evt:hasParticipant ;
    rdfs:domain evt:Captivity ;
    rdfs:label "has captive"@en ;
    rdfs:comment "The character held prisoner."@en .

evt:hasCaptor a owl:ObjectProperty ;
    rdfs:subPropertyOf evt:hasParticipant ;
    rdfs:domain evt:Captivity ;
    rdfs:label "has captor"@en ;
    rdfs:comment "The character or entity holding the captive."@en .

###############################################################
# Location and time properties
###############################################################

evt:hasLocation a owl:ObjectProperty ;
    rdfs:domain evt:Event ;
    rdfs:range loc:Place ;
    rdfs:label "has location"@en ;
    rdfs:comment "The place where an event occurs."@en .

evt:hasTemporalExtent a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain evt:Event ;
    rdfs:range tm:Interval ;
    rdfs:label "has temporal extent"@en ;
    rdfs:comment "When the event occurs (as an interval)."@en .

evt:isTemporalExtentOf a owl:ObjectProperty ;
    owl:inverseOf evt:hasTemporalExtent ;
    rdfs:label "is temporal extent of"@en ;
    rdfs:comment "Inverse of hasTemporalExtent."@en .

###############################################################
# Item usage
###############################################################

evt:usesItem a owl:ObjectProperty ;
    rdfs:domain evt:Event ;
    rdfs:range evt:Item ;
    rdfs:label "uses item"@en ;
    rdfs:comment "An item used in the event."@en .

###############################################################
# Sub-event structure
###############################################################

evt:hasSubEvent a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain evt:Event ;
    rdfs:range evt:Event ;
    rdfs:label "has sub-event"@en ;
    rdfs:comment "An event contains another as a sub-event. Transitive."@en .

evt:partOfEvent a owl:ObjectProperty, owl:TransitiveProperty ;
    owl:inverseOf evt:hasSubEvent ;
    rdfs:label "part of event"@en ;
    rdfs:comment "Inverse of hasSubEvent."@en .

###############################################################
# Cardinality restrictions (rich axioms)
###############################################################

# Every event should have a temporal extent.
# Functional (at most 1) is declared on the property itself.
# Here we say at least 1, together with Functional that gives exactly 1.
# NOTE: under OWA, events with no stated interval are not inconsistent,
# under OWA, events with no stated interval are not inconsistent.
evt:Event rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty evt:hasTemporalExtent ;
    owl:someValuesFrom tm:Interval
] .

# A Birth is uniquely identified by its newborn. No two Birth events
# can share the same newborn (each person is born exactly once).
evt:Birth owl:hasKey ( evt:hasNewborn ) .

# A birth has exactly 1 newborn, exactly 1 mother, at most 1 father
evt:Birth rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty evt:hasNewborn ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass owl:Thing ],
    [ a owl:Restriction ; owl:onProperty evt:hasMother ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass owl:Thing ],
    [ a owl:Restriction ; owl:onProperty evt:hasFather ;
      owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass owl:Thing ] .

# A Death is uniquely identified by its deceased (a person dies once).
evt:Death owl:hasKey ( evt:hasDeceased ) .

# A death has exactly 1 deceased, at most 1 killer
evt:Death rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty evt:hasDeceased ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass owl:Thing ],
    [ a owl:Restriction ; owl:onProperty evt:hasKiller ;
      owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass owl:Thing ] .

# A marriage has exactly 1 husband, exactly 1 wife, at most 1 officiant
# (the officiant is max 1 because the text does not always name one)
evt:Marriage rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty evt:hasHusband ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass owl:Thing ],
    [ a owl:Restriction ; owl:onProperty evt:hasWife ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass owl:Thing ],
    [ a owl:Restriction ; owl:onProperty evt:hasOfficiant ;
      owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass owl:Thing ] .

# A journey has at least 1 traveler, exactly 1 origin, exactly 1 destination
evt:Journey rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty evt:hasTraveler ;
      owl:someValuesFrom owl:Thing ],
    [ a owl:Restriction ; owl:onProperty evt:hasOrigin ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass loc:Place ],
    [ a owl:Restriction ; owl:onProperty evt:hasDestination ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass loc:Place ] .

# A battle has at least 2 combatants
evt:Battle rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty evt:hasCombatant ;
      owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ; owl:onClass owl:Thing ] .

# A conversation has at least 2 speakers
evt:Conversation rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty evt:hasSpeaker ;
      owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ; owl:onClass owl:Thing ] .

# A meeting involves at least 2 participants
evt:Meeting rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty evt:hasParticipant ;
      owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ; owl:onClass owl:Thing ] .

# A residence involves at least 1 resident and at least 1 location
evt:Residence rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty evt:hasResident ;
      owl:someValuesFrom owl:Thing ],
    [ a owl:Restriction ; owl:onProperty evt:hasLocation ;
      owl:someValuesFrom loc:Place ] .

# A captivity has at least 1 captive and at least 1 captor
evt:Captivity rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty evt:hasCaptive ;
      owl:someValuesFrom owl:Thing ],
    [ a owl:Restriction ; owl:onProperty evt:hasCaptor ;
      owl:someValuesFrom owl:Thing ] .

# A war contains at least one battle as a sub-event
evt:War rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty evt:hasSubEvent ;
      owl:someValuesFrom evt:Battle ] .

# All sub-events of a war must be battles or other wars (not births, etc.)
evt:War rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty evt:hasSubEvent ;
      owl:allValuesFrom [ a owl:Class ;
          owl:unionOf ( evt:Battle evt:War ) ] ] .

###############################################################
# Cross-module inference chains
#
# These connect the event layer to the family and social layers.
# These connect the event layer to the family and social layers.
###############################################################

# From a Death event, infer who killed whom:
# if Death D has killer X and deceased Y, then X killed Y.
evt:killed a owl:ObjectProperty ;
    rdfs:label "killed"@en ;
    rdfs:comment "X killed Y. Inferred from Death events via hasKiller and hasDeceased."@en .

evt:killed owl:propertyChainAxiom (
    [ owl:inverseOf evt:hasKiller ]
    evt:hasDeceased
) .

# From a Marriage event, infer the marriage relation:
# if Marriage M has husband X and wife Y, then X isMarriedTo Y.
fo:isMarriedTo owl:propertyChainAxiom (
    [ owl:inverseOf evt:hasHusband ]
    evt:hasWife
) .

# From a Birth event, infer the child-parent relation:
# if Birth B has newborn X and father Y, then X isAChildOf Y.
fo:isAChildOf owl:propertyChainAxiom (
    [ owl:inverseOf evt:hasNewborn ]
    evt:hasFather
) .

# Same for mothers:
# if Birth B has newborn X and mother Y, then X isAChildOf Y.
fo:isAChildOf owl:propertyChainAxiom (
    [ owl:inverseOf evt:hasNewborn ]
    evt:hasMother
) .

# From a Residence event, infer where a character lived:
# if Residence R has resident X and location Y, then X livedIn Y.
soc:livedIn owl:propertyChainAxiom (
    [ owl:inverseOf evt:hasResident ]
    evt:hasLocation
) .

# From a Journey event, infer where a character travelled to/from
soc:travelledTo a owl:ObjectProperty ;
    rdfs:range loc:Place ;
    rdfs:label "travelled to"@en ;
    rdfs:comment "Inferred from Journey events via hasTraveler and hasDestination."@en .

soc:travelledTo owl:propertyChainAxiom (
    [ owl:inverseOf evt:hasTraveler ]
    evt:hasDestination
) .

soc:travelledFrom a owl:ObjectProperty ;
    rdfs:range loc:Place ;
    rdfs:label "travelled from"@en ;
    rdfs:comment "Inferred from Journey events via hasTraveler and hasOrigin."@en .

soc:travelledFrom owl:propertyChainAxiom (
    [ owl:inverseOf evt:hasTraveler ]
    evt:hasOrigin
) .

###############################################################
# Event-level temporal relations (derived via property chains)
###############################################################

evt:beforeEvent a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain evt:Event ;
    rdfs:range evt:Event ;
    rdfs:label "before event"@en ;
    rdfs:comment "E1 happens entirely before E2."@en .

evt:afterEvent a owl:ObjectProperty, owl:TransitiveProperty ;
    owl:inverseOf evt:beforeEvent ;
    rdfs:label "after event"@en ;
    rdfs:comment "Inverse of beforeEvent."@en .

evt:meetsEvent a owl:ObjectProperty ;
    rdfs:domain evt:Event ;
    rdfs:range evt:Event ;
    rdfs:label "meets event"@en ;
    rdfs:comment "Event E1 ends exactly when event E2 starts."@en .

evt:overlapsEvent a owl:ObjectProperty ;
    rdfs:domain evt:Event ;
    rdfs:range evt:Event ;
    rdfs:label "overlaps event"@en ;
    rdfs:comment "Event E1 starts before and partially overlaps event E2."@en .

evt:duringEvent a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain evt:Event ;
    rdfs:range evt:Event ;
    rdfs:label "during event"@en ;
    rdfs:comment "Event E1 occurs entirely within the time span of event E2."@en .

# Property chains: event temporal relations derived from interval-level Allen relations
evt:beforeEvent owl:propertyChainAxiom (
    evt:hasTemporalExtent tm:beforeInterval evt:isTemporalExtentOf ) .

evt:afterEvent owl:propertyChainAxiom (
    evt:hasTemporalExtent tm:afterInterval evt:isTemporalExtentOf ) .

evt:meetsEvent owl:propertyChainAxiom (
    evt:hasTemporalExtent tm:meetsInterval evt:isTemporalExtentOf ) .

evt:overlapsEvent owl:propertyChainAxiom (
    evt:hasTemporalExtent tm:overlapsInterval evt:isTemporalExtentOf ) .

evt:duringEvent owl:propertyChainAxiom (
    evt:hasTemporalExtent tm:duringInterval evt:isTemporalExtentOf ) .
