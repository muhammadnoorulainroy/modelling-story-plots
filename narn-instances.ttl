#
# Instance File: Narn i Chîn Húrin
#
# Example data from the Children of Húrin, using all ontology modules.
#

@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Base ontology prefixes
@prefix fo:   <http://purl.org/family/> .
@prefix meo:  <http://purl.org/meo/> .
@prefix rcc:  <https://purl.org/region/rcc8/> .

# Module prefixes
@prefix soc:  <https://example.org/story/social#> .
@prefix loc:  <https://example.org/story/place#> .
@prefix tm:   <https://example.org/story/time#> .
@prefix evt:  <https://example.org/story/event#> .
@prefix act:  <https://example.org/story/action#> .
@prefix plot: <https://example.org/story/plot#> .

# Instance namespace
@prefix narn: <https://example.org/story/narn#> .
@prefix dct:  <http://purl.org/dc/terms/> .

narn: a owl:Ontology ;
    owl:imports <fo.ttl>, <meo.ttl>, <rcc.ttl>, <place.ttl>, <time.ttl>,
        <soc.ttl>, <event.ttl>, <action.ttl>, <plot.ttl> ;
    rdfs:label "Narn i Chîn Húrin, Instance Data"@en ;
    rdfs:comment "Example data from the Narn. Imports pull in all other modules."@en ;
    dct:created "2026-03-28T00:00:00Z"^^xsd:dateTime .

###############################################################
# CHARACTERS (meo: races + fo: gender)
###############################################################

narn:Turin a meo:Adan, fo:Male ;
    rdfs:label "Túrin"@en ;
    rdfs:comment "Túrin Turambar, son of Húrin and Morwen. The tragic hero of the Narn."@en .

narn:Morwen a meo:Adan, fo:Female ;
    rdfs:label "Morwen"@en ;
    rdfs:comment "Morwen Eledhwen, wife of Húrin, mother of Túrin and Niënor."@en .

narn:Hurin a meo:Adan, fo:Male ;
    rdfs:label "Húrin"@en ;
    rdfs:comment "Húrin Thalion, lord of Dor-lómin, father of Túrin and Niënor."@en .

narn:Nienor a meo:Adan, fo:Female ;
    rdfs:label "Niënor"@en ;
    rdfs:comment "Niënor Níniel, daughter of Húrin and Morwen, sister of Túrin."@en .

narn:Thingol a meo:Elda, fo:Male ;
    rdfs:label "Thingol"@en ;
    rdfs:comment "Elu Thingol, King of Doriath. Foster-father of Túrin."@en .

narn:Glaurung a meo:Loce ;
    rdfs:label "Glaurung"@en ;
    rdfs:comment "Glaurung, the Father of Dragons, a great worm of Morgoth."@en .

narn:Mablung a meo:Elda, fo:Male ;
    rdfs:label "Mablung"@en ;
    rdfs:comment "Mablung of Doriath, captain of Thingol's guard."@en .

narn:Beleg a meo:Elda, fo:Male ;
    rdfs:label "Beleg"@en ;
    rdfs:comment "Beleg Cúthalion, a great archer and companion of Túrin."@en .

narn:Morgoth a meo:Vala, meo:EvilBeing ;
    owl:sameAs meo:morgoth ;
    rdfs:label "Morgoth"@en ;
    rdfs:comment "The Dark Lord, the great enemy."@en .

narn:Finduilas a meo:Elda, fo:Female ;
    rdfs:label "Finduilas"@en ;
    rdfs:comment "Finduilas of Nargothrond, who loved Túrin."@en .

narn:Orodreth a meo:Elda, fo:Male ;
    rdfs:label "Orodreth"@en ;
    rdfs:comment "Orodreth, King of Nargothrond, father of Finduilas."@en .

narn:Galdor a meo:Adan, fo:Male ;
    rdfs:label "Galdor"@en ;
    rdfs:comment "Galdor the Tall, lord of Dor-lómin, father of Húrin."@en .

###############################################################
# Unique Name Assumption guards.
# OWL does not assume different IRIs denote different things.
###############################################################

# Characters
[] a owl:AllDifferent ;
    owl:distinctMembers (
        narn:Turin narn:Morwen narn:Hurin narn:Nienor narn:Thingol
        narn:Glaurung narn:Mablung narn:Beleg narn:Morgoth
        narn:Finduilas narn:Orodreth narn:Galdor
    ) .

###############################################################
# FAMILY RELATIONS (fo:)
###############################################################

narn:Hurin fo:isMarriedTo narn:Morwen .
narn:Hurin fo:isTheFatherOf narn:Turin, narn:Nienor .
narn:Morwen fo:isTheMotherOf narn:Turin, narn:Nienor .
narn:Turin fo:isASiblingOf narn:Nienor .
narn:Galdor fo:isTheFatherOf narn:Hurin .
narn:Orodreth fo:isTheFatherOf narn:Finduilas .

###############################################################
# SOCIAL RELATIONS (soc:)
###############################################################

narn:Hurin soc:allyOf narn:Thingol .
narn:Glaurung soc:enemyOf narn:Turin .
narn:Mablung soc:companionOf narn:Turin .
narn:Beleg soc:friendOf narn:Turin ;
    soc:companionOf narn:Turin .
narn:Thingol soc:fostersChild narn:Turin .
narn:Turin soc:fosteredBy narn:Thingol .
narn:Glaurung soc:serves narn:Morgoth .
narn:Turin soc:livedIn narn:DorLomin, narn:Menegroth, narn:Nargothrond, narn:Brethil .
narn:Morgoth soc:enemyOf narn:Thingol .

###############################################################
# PLACES (loc:)
###############################################################

narn:Beleriand a loc:Realm ;
    rdfs:label "Beleriand"@en ;
    rdfs:comment "The great region of Middle-earth west of the Blue Mountains."@en .

narn:DorLomin a loc:Realm ;
    rdfs:label "Dor-lómin"@en ;
    rdfs:comment "A region in Hithlum, domain of the House of Hador."@en ;
    loc:interiorPartOf narn:Beleriand .

narn:Doriath a loc:Realm ;
    rdfs:label "Doriath"@en ;
    rdfs:comment "The kingdom of Thingol, protected by the Girdle of Melian."@en ;
    loc:interiorPartOf narn:Beleriand .

narn:Menegroth a loc:Fortress ;
    rdfs:label "Menegroth"@en ;
    rdfs:comment "The Thousand Caves, the fortress-city of Thingol in Doriath."@en ;
    loc:interiorPartOf narn:Doriath ;
    loc:isCapitalOf narn:Doriath .

narn:Nargothrond a loc:Fortress ;
    rdfs:label "Nargothrond"@en ;
    rdfs:comment "A great underground fortress on the river Narog."@en ;
    loc:interiorPartOf narn:Beleriand .

narn:Brethil a loc:Forest ;
    rdfs:label "Brethil"@en ;
    rdfs:comment "The Forest of Brethil between the rivers Teiglin and Sirion."@en ;
    loc:interiorPartOf narn:Beleriand .

narn:Angband a loc:Fortress ;
    rdfs:label "Angband"@en ;
    rdfs:comment "The great fortress of Morgoth in the north."@en .

narn:ThroneRoom a loc:Room ;
    rdfs:label "Throne Room of Menegroth"@en ;
    rdfs:comment "The throne room within Menegroth where Thingol held court."@en ;
    loc:interiorPartOf narn:Menegroth .

narn:TaurNuFuin a loc:Forest ;
    rdfs:label "Taur-nu-Fuin"@en ;
    rdfs:comment "The forest of dread north of Doriath, formerly Dorthonion."@en ;
    loc:interiorPartOf narn:Beleriand .

narn:AnfauglithPlain a loc:Plain ;
    rdfs:label "Anfauglith"@en ;
    rdfs:comment "The desert plain before Angband where the Nirnaeth Arnoediad was fought."@en ;
    loc:tangentialPartOf narn:Beleriand ;
    loc:adjacentTo narn:Angband .

# All places are distinct individuals
[] a owl:AllDifferent ;
    owl:distinctMembers (
        narn:Beleriand narn:DorLomin narn:Doriath narn:Menegroth
        narn:Nargothrond narn:Brethil narn:Angband narn:ThroneRoom
        narn:TaurNuFuin narn:AnfauglithPlain
    ) .

###############################################################
# SPATIAL REGIONS (rcc:)
###############################################################

narn:regBeleriand a rcc:Region ; rdfs:label "Region of Beleriand"@en ;
    rdfs:comment "Spatial extent of Beleriand."@en .
narn:regDorLomin a rcc:Region ; rdfs:label "Region of Dor-lómin"@en ;
    rdfs:comment "Spatial extent of Dor-lómin."@en .
narn:regDoriath a rcc:Region ; rdfs:label "Region of Doriath"@en ;
    rdfs:comment "Spatial extent of Doriath."@en .
narn:regMenegroth a rcc:Region ; rdfs:label "Region of Menegroth"@en ;
    rdfs:comment "Spatial extent of Menegroth."@en .
narn:regNargothrond a rcc:Region ; rdfs:label "Region of Nargothrond"@en ;
    rdfs:comment "Spatial extent of Nargothrond."@en .
narn:regBrethil a rcc:Region ; rdfs:label "Region of Brethil"@en ;
    rdfs:comment "Spatial extent of the Forest of Brethil."@en .
narn:regAngband a rcc:Region ; rdfs:label "Region of Angband"@en ;
    rdfs:comment "Spatial extent of Angband, north of Beleriand."@en .
narn:regThroneRoom a rcc:Region ; rdfs:label "Region of Throne Room"@en ;
    rdfs:comment "Spatial extent of Menegroth's throne room."@en .
narn:regTaurNuFuin a rcc:Region ; rdfs:label "Region of Taur-nu-Fuin"@en ;
    rdfs:comment "Spatial extent of Taur-nu-Fuin."@en .
narn:regAnfauglith a rcc:Region ; rdfs:label "Region of Anfauglith"@en ;
    rdfs:comment "Spatial extent of Anfauglith, on the northern edge of Beleriand."@en .

# Places occupy regions
narn:Beleriand loc:occupiesRegion narn:regBeleriand .
narn:DorLomin loc:occupiesRegion narn:regDorLomin .
narn:Doriath loc:occupiesRegion narn:regDoriath .
narn:Menegroth loc:occupiesRegion narn:regMenegroth .
narn:Nargothrond loc:occupiesRegion narn:regNargothrond .
narn:Brethil loc:occupiesRegion narn:regBrethil .
narn:Angband loc:occupiesRegion narn:regAngband .
narn:ThroneRoom loc:occupiesRegion narn:regThroneRoom .
narn:TaurNuFuin loc:occupiesRegion narn:regTaurNuFuin .
narn:AnfauglithPlain loc:occupiesRegion narn:regAnfauglith .

# RCC8 spatial relations
narn:regDorLomin rcc:ntpp narn:regBeleriand .
narn:regDoriath rcc:ntpp narn:regBeleriand .
narn:regMenegroth rcc:ntpp narn:regDoriath .
narn:regThroneRoom rcc:ntpp narn:regMenegroth .
narn:regBrethil rcc:ntpp narn:regBeleriand .
narn:regNargothrond rcc:ntpp narn:regBeleriand .
narn:regTaurNuFuin rcc:ntpp narn:regBeleriand .
narn:regTaurNuFuin rcc:dc narn:regDoriath .
# Anfauglith is on the northern edge of Beleriand (tpp, not ntpp)
narn:regAnfauglith rcc:tpp narn:regBeleriand .
# Disconnected pairs
narn:regDorLomin rcc:dc narn:regDoriath .
narn:regNargothrond rcc:dc narn:regBrethil .
narn:regDorLomin rcc:dc narn:regBrethil .
# Angband is just north of Beleriand, their boundaries touch at the Ered Engrin
narn:regAngband rcc:ec narn:regBeleriand .
narn:regAnfauglith rcc:dc narn:regDoriath .
# Anfauglith and Angband share a boundary at the northern mountains
narn:regAnfauglith rcc:ec narn:regAngband .

###############################################################
# TEMPORAL INSTANTS AND INTERVALS (tm:)
###############################################################

narn:t1 a tm:Instant ; rdfs:label "t1"@en ; rdfs:comment "Húrin and Morwen's marriage."@en .
narn:t2 a tm:Instant ; rdfs:label "t2"@en ; rdfs:comment "Túrin's birth."@en .
narn:t10 a tm:Instant ; rdfs:label "t10"@en ; rdfs:comment "Start of the Nirnaeth Arnoediad."@en .
narn:t10b a tm:Instant ; rdfs:label "t10b"@en ; rdfs:comment "End of the battle of Nirnaeth."@en .
narn:t10c a tm:Instant ; rdfs:label "t10c"@en ; rdfs:comment "Morgoth taunts Húrin and pronounces the curse in Angband."@en .
narn:t2b a tm:Instant ; rdfs:label "t2b"@en ; rdfs:comment "Niënor's birth (after the Nirnaeth, during Hurin's captivity)."@en .
narn:t3 a tm:Instant ; rdfs:label "t3"@en ; rdfs:comment "Túrin arrives at Menegroth."@en .
narn:t3b a tm:Instant ; rdfs:label "t3b"@en ; rdfs:comment "Túrin meets Beleg."@en .
narn:t4 a tm:Instant ; rdfs:label "t4"@en ; rdfs:comment "Túrin leaves Menegroth."@en .
narn:t4b a tm:Instant ; rdfs:label "t4b"@en ; rdfs:comment "Beleg's death."@en .
narn:t4c a tm:Instant ; rdfs:label "t4c"@en ; rdfs:comment "Túrin begins the journey to Nargothrond after Beleg's death."@en .
narn:t5 a tm:Instant ; rdfs:label "t5"@en ; rdfs:comment "Túrin arrives at Nargothrond."@en .
narn:t6 a tm:Instant ; rdfs:label "t6"@en ; rdfs:comment "Túrin leaves Nargothrond."@en .
narn:t7 a tm:Instant ; rdfs:label "t7"@en ; rdfs:comment "Túrin arrives in Brethil."@en .
narn:t7b a tm:Instant ; rdfs:label "t7b"@en ; rdfs:comment "Niënor's death."@en .
narn:t8 a tm:Instant ; rdfs:label "t8"@en ; rdfs:comment "Glaurung slain."@en .
narn:t9 a tm:Instant ; rdfs:label "t9"@en ; rdfs:comment "Túrin's death."@en .

# Instant ordering
narn:t1 tm:occursBefore narn:t2 .
narn:t2 tm:occursBefore narn:t10 .
narn:t10 tm:occursBefore narn:t10b .
narn:t10b tm:occursBefore narn:t10c .
narn:t10c tm:occursBefore narn:t2b .
narn:t2b tm:occursBefore narn:t3 .
narn:t3 tm:occursBefore narn:t3b .
narn:t3b tm:occursBefore narn:t4 .
narn:t4 tm:occursBefore narn:t4b .
narn:t4b tm:occursBefore narn:t4c .
narn:t4c tm:occursBefore narn:t5 .
narn:t5 tm:occursBefore narn:t6 .
narn:t6 tm:occursBefore narn:t7 .
narn:t7 tm:occursBefore narn:t7b .
narn:t7b tm:occursBefore narn:t8 .
narn:t8 tm:occursBefore narn:t9 .

# Temporal instants (prevents timeline collapse)
[] a owl:AllDifferent ;
    owl:distinctMembers (
        narn:t1 narn:t2 narn:t10 narn:t10b narn:t10c narn:t2b
        narn:t3 narn:t3b narn:t4 narn:t4b narn:t4c narn:t5
        narn:t6 narn:t7 narn:t7b narn:t8 narn:t9
    ) .

# Sample instant-within-interval facts
narn:t10c tm:occursDuring narn:intCaptivityHurin .
narn:t3b tm:occursDuring narn:intResidenceMenegroth .

# Intervals
narn:intMarriage a tm:FiniteInterval ;
    tm:startsAt narn:t1 ; tm:endsAt narn:t1 ;
    rdfs:label "Marriage interval"@en ;
    rdfs:comment "Point event: the marriage ceremony."@en .

narn:intBirthTurin a tm:FiniteInterval ;
    tm:startsAt narn:t2 ; tm:endsAt narn:t2 ;
    rdfs:label "Birth of Túrin interval"@en ;
    rdfs:comment "Point event: Túrin's birth."@en .

narn:intBirthNienor a tm:FiniteInterval ;
    tm:startsAt narn:t2b ; tm:endsAt narn:t2b ;
    rdfs:label "Birth of Niënor interval"@en ;
    rdfs:comment "Point event: Niënor's birth."@en .

narn:intNirnaeth a tm:FiniteInterval ;
    tm:startsAt narn:t10 ; tm:endsAt narn:t10b ;
    rdfs:label "Nirnaeth Arnoediad interval"@en ;
    rdfs:comment "Extended interval: the battle lasted days."@en .

narn:intCurse a tm:FiniteInterval ;
    tm:startsAt narn:t10c ; tm:endsAt narn:t10c ;
    rdfs:label "Curse interval"@en ;
    rdfs:comment "Point event: Morgoth pronounces the curse after Húrin's capture."@en .

narn:intCaptivityHurin a tm:FiniteInterval ;
    tm:startsAt narn:t10b ; tm:endsAt narn:t9 ;
    rdfs:label "Captivity of Húrin interval"@en ;
    rdfs:comment "Extended interval: ~28 years of imprisonment."@en .

narn:intTaunt a tm:FiniteInterval ;
    tm:startsAt narn:t10c ; tm:endsAt narn:t10c ;
    rdfs:label "Morgoth taunts Húrin interval"@en ;
    rdfs:comment "Point event: Morgoth gloats over his prisoner."@en .

narn:intResidenceMenegroth a tm:FiniteInterval ;
    tm:startsAt narn:t3 ; tm:endsAt narn:t4 ;
    rdfs:label "Residence at Menegroth interval"@en ;
    rdfs:comment "Extended interval: Túrin's years as foster-son."@en .

narn:intMeetingBeleg a tm:FiniteInterval ;
    tm:startsAt narn:t3b ; tm:endsAt narn:t3b ;
    rdfs:label "Meeting Beleg interval"@en ;
    rdfs:comment "Point event: first encounter."@en .

narn:intDeathBeleg a tm:FiniteInterval ;
    tm:startsAt narn:t4b ; tm:endsAt narn:t4b ;
    rdfs:label "Death of Beleg interval"@en ;
    rdfs:comment "Point event: accidental killing."@en .

narn:intJourneyToNargothrond a tm:FiniteInterval ;
    tm:startsAt narn:t4c ; tm:endsAt narn:t5 ;
    rdfs:label "Journey to Nargothrond interval"@en ;
    rdfs:comment "Extended interval: the journey from Taur-nu-Fuin to Nargothrond after Beleg's death."@en .

narn:intResidenceNargothrond a tm:FiniteInterval ;
    tm:startsAt narn:t5 ; tm:endsAt narn:t6 ;
    rdfs:label "Residence at Nargothrond interval"@en ;
    rdfs:comment "Extended interval: Túrin's time in Nargothrond."@en .

narn:intJourneyToBrethil a tm:FiniteInterval ;
    tm:startsAt narn:t6 ; tm:endsAt narn:t7 ;
    rdfs:label "Journey to Brethil interval"@en ;
    rdfs:comment "Extended interval: flight to Brethil."@en .

narn:intDeathNienor a tm:FiniteInterval ;
    tm:startsAt narn:t7b ; tm:endsAt narn:t7b ;
    rdfs:label "Death of Niënor interval"@en ;
    rdfs:comment "Point event: Niënor casts herself into the Teiglin."@en .

narn:intSlayingGlaurung a tm:FiniteInterval ;
    tm:startsAt narn:t8 ; tm:endsAt narn:t8 ;
    rdfs:label "Slaying of Glaurung interval"@en ;
    rdfs:comment "Point event: Túrin stabs Glaurung."@en .

narn:intWarOfJewels a tm:Interval, tm:InfiniteInterval ;
    rdfs:label "War of the Jewels interval"@en ;
    rdfs:comment "Spans centuries. Start and end are beyond the Narn's scope, so no startsAt/endsAt."@en .

narn:intReignThingol a tm:Interval, tm:InfiniteInterval ;
    rdfs:label "Reign of Thingol interval"@en ;
    rdfs:comment "Thingol's reign spans millennia. Unbounded in this model."@en .

narn:intDeathTurin a tm:FiniteInterval ;
    tm:startsAt narn:t9 ; tm:endsAt narn:t9 ;
    rdfs:label "Death of Túrin interval"@en ;
    rdfs:comment "Point event: Túrin falls on his sword."@en .

# Allen relations between intervals
narn:intMarriage tm:beforeInterval narn:intBirthTurin .
narn:intBirthTurin tm:beforeInterval narn:intBirthNienor .
narn:intNirnaeth tm:beforeInterval narn:intBirthNienor .
narn:intBirthNienor tm:duringInterval narn:intCaptivityHurin .
# The curse and the taunt are modeled as the same point event after the battle.
narn:intCurse tm:intervalEquals narn:intTaunt .
narn:intNirnaeth tm:beforeInterval narn:intTaunt .
narn:intNirnaeth tm:beforeInterval narn:intCurse .
narn:intTaunt tm:duringInterval narn:intCaptivityHurin .
narn:intCurse tm:duringInterval narn:intCaptivityHurin .
narn:intTaunt tm:beforeInterval narn:intResidenceMenegroth .
narn:intMeetingBeleg tm:duringInterval narn:intResidenceMenegroth .
narn:intResidenceMenegroth tm:beforeInterval narn:intJourneyToNargothrond .
narn:intDeathBeleg tm:beforeInterval narn:intJourneyToNargothrond .
narn:intJourneyToNargothrond tm:meetsInterval narn:intResidenceNargothrond .
narn:intResidenceNargothrond tm:meetsInterval narn:intJourneyToBrethil .
narn:intJourneyToBrethil tm:beforeInterval narn:intDeathNienor .
narn:intDeathNienor tm:beforeInterval narn:intSlayingGlaurung .
narn:intSlayingGlaurung tm:beforeInterval narn:intDeathTurin .
# The captivity spans nearly the whole story
narn:intCaptivityHurin tm:containsInterval narn:intResidenceMenegroth .
narn:intCaptivityHurin tm:containsInterval narn:intSlayingGlaurung .
# Túrin's death ends at the same time the captivity ends (t9)
narn:intDeathTurin tm:finishesInterval narn:intCaptivityHurin .
# The war and reign span the entire story
narn:intWarOfJewels tm:containsInterval narn:intNirnaeth .
narn:intReignThingol tm:containsInterval narn:intResidenceMenegroth .
