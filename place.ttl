#
# Place Ontology
#
# Categories of places and spatial relations for story modelling.
# Place is separate from Region (rcc.ttl). A Place is a named location
# like a city or forest, a Region is its abstract spatial extent.
# They're linked by occupiesRegion to enable RCC8 reasoning on places.
#
# The hierarchy splits into land/water first, then more specific types.
# Settlements and wild areas are disjoint. A city can't be a forest.
#

@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix rcc:  <https://purl.org/region/rcc8/> .
@prefix loc:  <https://example.org/story/place#> .

loc: a owl:Ontology ;
    owl:imports <rcc.ttl> ;
    rdfs:label "Place Ontology"@en ;
    dct:title "Place Ontology"@en ;
    rdfs:comment "Place categories and spatial relations for story plots."@en ;
    owl:versionInfo "1.0" ;
    dct:created "2026-03-28T00:00:00Z"^^xsd:dateTime .

###############################################################
# Top-level class
###############################################################

loc:Place a owl:Class ;
    rdfs:label "Place"@en ;
    rdfs:comment "A named location in the story world."@en .

###############################################################
# Place hierarchy
###############################################################

# --- Land vs Water ---

loc:LandArea a owl:Class ;
    rdfs:subClassOf loc:Place ;
    rdfs:label "Land area"@en ;
    rdfs:comment "A place on land."@en .

loc:WaterArea a owl:Class ;
    rdfs:subClassOf loc:Place ;
    rdfs:label "Water area"@en ;
    rdfs:comment "A body of water: river, lake, or sea."@en .

# --- Settlements ---

loc:Settlement a owl:Class ;
    rdfs:subClassOf loc:LandArea ;
    rdfs:label "Settlement"@en ;
    rdfs:comment "An inhabited place. Has a population."@en .

loc:City a owl:Class ;
    rdfs:subClassOf loc:Settlement ;
    rdfs:label "City"@en ;
    rdfs:comment "A large settlement with political importance."@en .

loc:Town a owl:Class ;
    rdfs:subClassOf loc:Settlement ;
    rdfs:label "Town"@en ;
    rdfs:comment "Bigger than a hamlet, smaller than a city."@en .

loc:Hamlet a owl:Class ;
    rdfs:subClassOf loc:Settlement ;
    rdfs:label "Hamlet"@en ;
    rdfs:comment "A very small settlement."@en .

loc:Fortress a owl:Class ;
    rdfs:subClassOf loc:Settlement ;
    rdfs:label "Fortress"@en ;
    rdfs:comment "A fortified settlement or stronghold, like Nargothrond or Menegroth. Not disjoint with City since some fortresses are city-sized."@en .

# --- Wild areas ---

loc:WildArea a owl:Class ;
    rdfs:subClassOf loc:LandArea ;
    rdfs:label "Wild area"@en ;
    rdfs:comment "Uninhabited natural area."@en .

loc:WoodedArea a owl:Class ;
    rdfs:subClassOf loc:WildArea ;
    rdfs:label "Wooded area"@en ;
    rdfs:comment "Area covered mostly by trees."@en .

loc:Forest a owl:Class ;
    rdfs:subClassOf loc:WoodedArea ;
    rdfs:label "Forest"@en ;
    rdfs:comment "A large wooded area. E.g. Brethil in the Narn."@en .

loc:MountainRange a owl:Class ;
    rdfs:subClassOf loc:WildArea ;
    rdfs:label "Mountain range"@en ;
    rdfs:comment "A chain of mountains."@en .

loc:Plain a owl:Class ;
    rdfs:subClassOf loc:WildArea ;
    rdfs:label "Plain"@en ;
    rdfs:comment "Flat open land."@en .

# --- Buildings ---

loc:Building a owl:Class ;
    rdfs:subClassOf loc:Place ;
    rdfs:label "Building"@en ;
    rdfs:comment "A structure with walls and a roof."@en .

loc:Room a owl:Class ;
    rdfs:subClassOf loc:Place ;
    rdfs:label "Room"@en ;
    rdfs:comment "A space inside a building or fortified complex."@en .

# A room must be part of some building or fortress
loc:Room rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty loc:partOf ;
    owl:someValuesFrom [
        a owl:Class ;
        owl:unionOf ( loc:Building loc:Fortress )
    ]
] .

# --- Water subtypes ---

loc:River a owl:Class ;
    rdfs:subClassOf loc:WaterArea ;
    rdfs:label "River"@en ;
    rdfs:comment "A flowing watercourse."@en .

loc:Lake a owl:Class ;
    rdfs:subClassOf loc:WaterArea ;
    rdfs:label "Lake"@en ;
    rdfs:comment "Standing water surrounded by land."@en .

loc:Sea a owl:Class ;
    rdfs:subClassOf loc:WaterArea ;
    rdfs:label "Sea"@en ;
    rdfs:comment "A large body of salt water."@en .

# --- Roads ---

loc:Road a owl:Class ;
    rdfs:subClassOf loc:Place ;
    rdfs:label "Road"@en ;
    rdfs:comment "A path or route connecting places."@en .

# --- Realms ---

loc:Realm a owl:Class ;
    rdfs:subClassOf loc:LandArea ;
    rdfs:label "Realm"@en ;
    rdfs:comment "A kingdom or administrative region containing settlements and wild areas."@en .

###############################################################
# Disjointness
###############################################################

# Top-level partition of Place
[] a owl:AllDisjointClasses ;
    owl:members ( loc:LandArea loc:WaterArea loc:Building loc:Room loc:Road ) .

# LandArea subtypes
[] a owl:AllDisjointClasses ;
    owl:members ( loc:Settlement loc:WildArea loc:Realm ) .

# Settlement subtypes
[] a owl:AllDisjointClasses ;
    owl:members ( loc:City loc:Town loc:Hamlet ) .

# Water subtypes
[] a owl:AllDisjointClasses ;
    owl:members ( loc:River loc:Lake loc:Sea ) .

###############################################################
# Object Properties
###############################################################

loc:partOf a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain loc:Place ;
    rdfs:range loc:Place ;
    rdfs:label "part of"@en ;
    rdfs:comment "Spatial containment between places. E.g. Menegroth is part of Doriath."@en .

loc:interiorPartOf a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:subPropertyOf loc:partOf ;
    rdfs:domain loc:Place ;
    rdfs:range loc:Place ;
    rdfs:label "interior part of"@en ;
    rdfs:comment "Proper part relation where the subject lies wholly inside the larger place, corresponding to RCC8 NTPP at region level."@en .

loc:tangentialPartOf a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:subPropertyOf loc:partOf ;
    rdfs:domain loc:Place ;
    rdfs:range loc:Place ;
    rdfs:label "tangential part of"@en ;
    rdfs:comment "Proper part relation where the subject touches the boundary of the larger place, corresponding to RCC8 TPP at region level."@en .

loc:hasPart a owl:ObjectProperty ;
    owl:inverseOf loc:partOf ;
    rdfs:label "has part"@en ;
    rdfs:comment "Inverse of partOf."@en .

loc:adjacentTo a owl:ObjectProperty, owl:SymmetricProperty, owl:IrreflexiveProperty ;
    rdfs:domain loc:Place ;
    rdfs:range loc:Place ;
    rdfs:label "adjacent to"@en ;
    rdfs:comment "Two places that share a boundary or are next to each other."@en .

loc:occupiesRegion a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain loc:Place ;
    rdfs:range rcc:Region ;
    rdfs:label "occupies region"@en ;
    rdfs:comment "Links a place to its spatial region. Functional (one region per place). Enables RCC8 reasoning on places."@en .

loc:isCapitalOf a owl:ObjectProperty, owl:FunctionalProperty, owl:InverseFunctionalProperty ;
    rdfs:domain loc:Settlement ;
    rdfs:range loc:Realm ;
    rdfs:label "is capital of"@en ;
    rdfs:comment "The settlement is the capital of this realm. Functional and inverse-functional (one capital per realm, one realm per capital)."@en .

# A capital must be part of its realm
loc:isCapitalOf rdfs:subPropertyOf loc:partOf .

loc:hasCapital a owl:ObjectProperty ;
    owl:inverseOf loc:isCapitalOf ;
    rdfs:label "has capital"@en ;
    rdfs:comment "Inverse of isCapitalOf."@en .

###############################################################
# Bridge axioms: Place mereology -> Region RCC8
#
# These property chains formally connect the place-level spatial
# relations to the region-level RCC8 relations via occupiesRegion.
# If P1 interiorPartOf P2, then the region of P1 is ntpp of the region of P2.
# If P1 tangentialPartOf P2, then the region of P1 is tpp of the region of P2.
# If P1 adjacentTo P2, then their regions are ec.
###############################################################

# interiorPartOf -> ntpp: if region R1 is occupied by place P1,
# and P1 interiorPartOf P2, and P2 occupies region R2, then R1 ntpp R2.
rcc:ntpp owl:propertyChainAxiom (
    [ owl:inverseOf loc:occupiesRegion ]
    loc:interiorPartOf
    loc:occupiesRegion
) .

# tangentialPartOf -> tpp: if region R1 is occupied by place P1,
# and P1 tangentialPartOf P2, and P2 occupies region R2, then R1 tpp R2.
rcc:tpp owl:propertyChainAxiom (
    [ owl:inverseOf loc:occupiesRegion ]
    loc:tangentialPartOf
    loc:occupiesRegion
) .

# adjacentTo -> ec: if region R1 is occupied by place P1,
# and P1 adjacentTo P2, and P2 occupies region R2, then R1 ec R2.
rcc:ec owl:propertyChainAxiom (
    [ owl:inverseOf loc:occupiesRegion ]
    loc:adjacentTo
    loc:occupiesRegion
) .

###############################################################
# Datatype Properties
###############################################################

loc:hasPopulation a owl:DatatypeProperty ;
    rdfs:domain loc:Settlement ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:label "has population"@en ;
    rdfs:comment "Number of inhabitants. Only makes sense for settlements."@en .

loc:hasFoundationDate a owl:DatatypeProperty ;
    rdfs:domain loc:Place ;
    rdfs:range xsd:string ;
    rdfs:label "has foundation date"@en ;
    rdfs:comment "When the place was established. String because fictional dates don't always fit xsd:date."@en .
