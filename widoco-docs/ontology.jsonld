    "@language" : "en",
    "@value" : "A parent at least one of whose children has died. In the Narn, Hurin and Morwen are bereaved parents."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "bereaved parent"
