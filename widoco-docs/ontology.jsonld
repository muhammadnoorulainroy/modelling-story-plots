}, {
  "@id" : "http://purl.org/meo/Adan",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The Edain (plural form of Adan) are the Men that belong to the Three Houses of Men that came to Beleriand in the elder days. Originally, “Adan” (plural “Edain”) is the Sindarin equivalent of Quenya “Atan” (plural “Atani”) but eventually came to mean this narrow subgroup."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "sjn",
    "@value" : "Adan"
  }, {
    "@language" : "en",
    "@value" : "Man"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.org/meo/Atan"
  } ]
}, {
  "@id" : "http://purl.org/meo/Ainu",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The Ainur (plural form of Ainu) are the spirits created by Eru Ilúvatar before time existed"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "qya",
    "@value" : "Ainu"
  }, {
    "@language" : "en",
    "@value" : "Holy one"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.org/meo/Immortal"
  } ],
  "http://www.w3.org/2002/07/owl#disjointUnionOf" : [ {
    "@list" : [ {
      "@id" : "http://purl.org/meo/Maia"
    }, {
      "@id" : "http://purl.org/meo/Vala"
    } ]
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "http://purl.org/meo/Casar"
  }, {
    "@id" : "http://purl.org/meo/Eruhin"
  }, {
    "@id" : "http://purl.org/meo/God"
  }, {
    "@id" : "http://purl.org/meo/Lócë"
  }, {
    "@id" : "http://purl.org/meo/Torog"
  } ]
}, {
  "@id" : "http://purl.org/meo/Atan",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The Atani (plural form of Atan) are the second born of the Children of Ilúvatar, the Men (i.e. Humans, not male people). They were given many names also by the Eldar."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "sjn",
    "@value" : "Adan"
  }, {
    "@language" : "qya",
    "@value" : "Atan"
  }, {
    "@language" : "en",
    "@value" : "Man"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.org/meo/Eruhin"
  }, {
    "@id" : "http://purl.org/meo/Mortal"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "http://purl.org/meo/Casar"
  }, {
    "@id" : "http://purl.org/meo/Quendë"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "en",
    "@value" : "After-born"
  }, {
    "@language" : "en",
    "@value" : "After-comer"
  }, {
    "@language" : "qya",
    "@value" : "Apanóna"
  }, {
    "@language" : "qya",
    "@value" : "Engwa"
  }, {
    "@language" : "en",
    "@value" : "Follower"
  }, {
    "@language" : "qya",
    "@value" : "Fírima"
  }, {
    "@language" : "qya",
    "@value" : "Hildo"
  }, {
    "@language" : "en",
    "@value" : "Human"
  }, {
    "@language" : "en",
    "@value" : "Mortal"
  }, {
    "@language" : "en",
    "@value" : "Secondborn"
  }, {
    "@language" : "en",
    "@value" : "Sickly"
  } ]
}, {
  "@id" : "http://purl.org/meo/Casar",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The Casari (plural form of Casar in Quenya), more often called with the Sindarin variant Naugrim (plural of Naug in Sindarin), are the Dwarves created by the Vala Aulë."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "qya",
    "@value" : "Casar"
  }, {
    "@language" : "en",
    "@value" : "Dwarf"
  }, {
    "@language" : "sjn",
    "@value" : "Naug"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.org/meo/Mortal"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "http://purl.org/meo/God"
  }, {
    "@id" : "http://purl.org/meo/Lócë"
  }, {
    "@id" : "http://purl.org/meo/Quendë"
  }, {
    "@id" : "http://purl.org/meo/Torog"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "qya",
    "@value" : "Aulëonna"
  }, {
    "@language" : "en",
    "@value" : "Child of Aulë"
  } ]
}, {
  "@id" : "http://purl.org/meo/Elda",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The Eldar (plural form of Elda) are the Elves. They initially called themselves the Quendi, but the Vala Oromë, who met them at lake Cuiviénen under the stars, called them the Eldar. Now only the Quendi who followed Oromë to the West call themselves Eldar."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "qya",
    "@value" : "Elda"
  }, {
    "@language" : "sjn",
    "@value" : "Eledh"
  }, {
    "@language" : "en",
    "@value" : "Elf"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "http://purl.org/meo/Quendë"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "en",
    "@value" : "Firstborn"
  }, {
    "@language" : "en",
    "@value" : "of the stars"
  }, {
    "@language" : "en",
    "@value" : "person of the stars"
  } ]
}, {
  "@id" : "http://purl.org/meo/Eruhin",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The Eruhíni (plural form of Eruhin), literally “the Children of Eru”, are usually called the “Children of Ilúvatar”. They are the Elves and Men. “Children of Ilúvatar” is used to collectively refer to the two races of Men and Elves, and the singular form is rarely used."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Child of Ilúvatar"
  }, {
    "@language" : "qya",
    "@value" : "Eruhin"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "http://purl.org/meo/God"
  }, {
    "@id" : "http://purl.org/meo/Lócë"
  }, {
    "@id" : "http://purl.org/meo/Torog"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "en",
    "@value" : "Child of Eru"
  } ]
}, {
  "@id" : "http://purl.org/meo/EvilBeing",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The evil beings are sentient agents that have chosen to do bad things, behave badly for the sake of doing bad, or became corrupted into doing evil. Some things are raised and bred to be evil. Some things are led to become evil by other evil beings by subversion. Some choose to become evil due to greed or as a way to overcome hardships of their lives."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "evil being"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "http://purl.org/meo/God"
  } ]
}, {
  "@id" : "http://purl.org/meo/God",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A sperior entity. A singleton class that only contains Eru Ilúvatar, the One Allfather."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "God"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.org/meo/Immortal"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "http://purl.org/meo/Mortal"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid288"
  } ]
}, {
  "@id" : "http://purl.org/meo/Immortal",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An individual that does not die of natural death. Some immortals may die from wounds inflicted to them by violence or accident (like Elves), but some are truly eternal, like the Ainur)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "immortal"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "http://purl.org/meo/Mortal"
  } ]
}, {
  "@id" : "http://purl.org/meo/Lócë",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Evil and powerful monster."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Dragon"
  }, {
    "@language" : "qya",
    "@value" : "Lócë"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.org/meo/EvilBeing"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "http://purl.org/meo/Torog"
  } ]
}, {
  "@id" : "http://purl.org/meo/Maia",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The Maiar (plural form of Maia) are Ainur who entered Arda and serve the Valar."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Beautiful"
  }, {
    "@language" : "qya",
    "@value" : "Maia"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.org/meo/Ainu"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "http://purl.org/meo/Vala"
  } ]
}, {
  "@id" : "http://purl.org/meo/Mortal",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Mortal living being, such as Men and Dwarces."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "mortal"
  } ]
}, {
  "@id" : "http://purl.org/meo/Peredhel",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Peredhil are descendent of both elves and humans."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Half-elf"
  }, {
    "@language" : "sjn",
    "@value" : "Peredhel"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.org/meo/Eruhin"
  }, {
    "@id" : "_:genid290"
  }, {
    "@id" : "_:genid291"
  } ]
}, {
  "@id" : "http://purl.org/meo/Quendë",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The Quendi (plural form of Quendë) are the first born of the Children of Ilúvatar, the Elves. They are named thus because they were the only ones who spoke when they first appeared, before Men and Dwarves came to be. They are more often called the Eldar."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Elf"
  }, {
    "@language" : "qya",
    "@value" : "Quendë"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.org/meo/Eruhin"
  }, {
    "@id" : "http://purl.org/meo/Immortal"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "qya",
    "@value" : "Elda"
  }, {
    "@language" : "en",
    "@value" : "Firstborn"
  }, {
    "@language" : "en",
    "@value" : "one that speaks"
  } ]
}, {
  "@id" : "http://purl.org/meo/Torog",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The *Teryg (probably the plural form of Torog in Sindarin) are the Trolls, large humanoid monsters of great physical strength and weak intellect."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "sjn",
    "@value" : "torog"
  }, {
    "@language" : "en",
    "@value" : "troll"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.org/meo/EvilBeing"
  } ]
}, {
  "@id" : "http://purl.org/meo/Vala",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The Valar (plural form of Vala) are the most powerful Ainur who entered Arda, the world."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "qya",
    "@value" : "Vala"
  }, {
    "@language" : "en",
    "@value" : "angelic power"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.org/meo/Ainu"
  } ]
}, {
  "@id" : "http://purl.org/meo/eru",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://purl.org/meo/God"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The one God creator of everything."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "qya",
    "@value" : "Eru"
  }, {
    "@language" : "en",
    "@value" : "The One"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "qya",
    "@value" : "Eru Ilúvatar"
  }, {
    "@language" : "en",
    "@value" : "God"
  }, {
    "@language" : "qya",
    "@value" : "Ilúvatar"
  }, {
    "@language" : "en",
    "@value" : "The Allfather"
  } ]
}, {
  "@id" : "http://purl.org/meo/melkor",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://purl.org/meo/Vala"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The greatest of the Ainur."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "He who arises in might"
  }, {
    "@language" : "qya",
    "@value" : "Melkor"
  } ],
  "http://www.w3.org/2002/07/owl#sameAs" : [ {
    "@id" : "http://purl.org/meo/morgoth"
  } ]
}, {
  "@id" : "http://purl.org/meo/morgoth",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://purl.org/meo/EvilBeing"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The only Vala who became evil. The enemy of all other Valar."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "sjn",
    "@value" : "Morgoth"
  }, {
    "@language" : "en",
    "@value" : "The Black Enemy"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "sjn",
    "@value" : "Bauglir"
  }, {
    "@language" : "en",
    "@value" : "The Constrainer"
  } ]
}, {
  "@id" : "http://purl.org/meo/served",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Relates someone to someone else that they serve. Relation servant-master."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "serves"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentProperty" : [ {
    "@id" : "https://example.org/story/social#serves"
  } ]
}, {
  "@id" : "http://www.w3.org/2004/02/skos/core#altLabel",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "https://example.org/story/action#Action",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An event with a deliberate agent. Any event that has an agent gets classified as an action."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Action"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid296"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid292"
  } ]
}, {
  "@id" : "https://example.org/story/action#AttackAction",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A hostile action directed at a patient. Left as a conservative subclass rather than a defined class, because patienthood alone would wrongly classify non-violent actions such as curses as attacks."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Attack action"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://example.org/story/action#Action"
  }, {
    "@id" : "_:genid297"
  }, {
    "@id" : "_:genid298"
  }, {
    "@id" : "_:genid299"
  } ]
}, {
  "@id" : "https://example.org/story/action#CurseAction",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Placing a curse on someone. In the Narn, Morgoth curses the children of Húrin."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Curse action"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://example.org/story/action#SpeechAction"
  }, {
    "@id" : "_:genid303"
  }, {
    "@id" : "_:genid304"
  } ]
}, {
  "@id" : "https://example.org/story/action#MoveAction",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A journey performed by a deliberate agent. Since hasTraveler is a sub-property of hasAgent, every journey with a traveler is a MoveAction."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Move action"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid305"
  } ]
}, {
