  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A relation between a father and his child. Asymmetric (a child is not its father's father) and irreflexive (nobody is their own father)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
