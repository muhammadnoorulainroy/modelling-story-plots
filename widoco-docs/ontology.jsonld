  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A modular OWL ontology for representing story plots, characters, events, places, and narrative structure. Use case: Narn i Chin Hurin (J.R.R. Tolkien)."
  }, {
    "@language" : "en",
    "@value" : "Actions as a subclass of events, defined by having an intentional agent."
  }, {
    "@language" : "en",
    "@value" : "An ontology for J.R.R. Tolkienʼs legendarium."
  }, {
    "@language" : "en",
    "@value" : "An ontology for family relationships."
  }, {
    "@language" : "en",
    "@value" : "Events in story plots: occurrences involving characters, places, and time. Includes an event hierarchy, participant roles, and temporal relations."
  }, {
    "@language" : "en",
    "@value" : "Instants, intervals, and Allen's 13 temporal relations."
  }, {
    "@language" : "en",
    "@value" : "Narrative and literary structure of stories, with a real-world layer (authors, books) and a fictional layer (sections, plot events)."
  }, {
    "@language" : "en",
    "@value" : "Non-familial social relations between characters: friendship, enmity, alliance, service, etc."
  }, {
    "@language" : "en",
    "@value" : "Place categories and spatial relations for story plots."
  }, {
    "@language" : "en",
    "@value" : "RCC8 spatial relations between regions, encoded with DL-safe OWL axioms."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Action Ontology"
  }, {
    "@language" : "en",
    "@value" : "Event Ontology"
  }, {
    "@language" : "en",
    "@value" : "Place Ontology"
  }, {
    "@language" : "en",
    "@value" : "Plot Structure Ontology"
  }, {
    "@language" : "en",
    "@value" : "Social Relations Ontology"
  }, {
    "@language" : "en",
    "@value" : "Story Plot Ontology"
  }, {
    "@language" : "en",
    "@value" : "The Middle-earth ontology"
  }, {
    "@language" : "en",
    "@value" : "The RCC8 ontology"
  }, {
    "@language" : "en",
    "@value" : "The family ontology"
  }, {
    "@language" : "en",
    "@value" : "Time Ontology"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "1.0"
  } ]
