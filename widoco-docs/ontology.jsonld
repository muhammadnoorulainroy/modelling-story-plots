    "@id" : "https://example.org/story/place#Realm"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://example.org/story/place#partOf"
  } ]
}, {
  "@id" : "https://example.org/story/place#occupiesRegion",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#FunctionalProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links a place to its spatial region. Functional (one region per place). Enables RCC8 reasoning on places."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://example.org/story/place#Place"
