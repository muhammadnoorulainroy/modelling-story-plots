  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Proper part relation where the subject touches the boundary of the larger place, corresponding to RCC8 TPP at region level."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://example.org/story/place#Place"
  } ],
