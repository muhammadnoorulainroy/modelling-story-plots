  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The settlement is the capital of this realm. Functional and inverse-functional (one capital per realm, one realm per capital). Asymmetric and irreflexive (a realm is not the capital of itself)."
