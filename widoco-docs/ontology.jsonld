  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "People united through marriage. Functional enforces monogamy: each individual can have at most one spouse. Combined with SymmetricProperty, this also makes the inverse functional (if two people are married to the same person, they must be the same person)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "is married to"
