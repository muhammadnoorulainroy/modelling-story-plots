        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/plot#sectionOf"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://example.org/story/plot#Story"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A structural part of a story: prologue, chapter, or epilogue.</rdfs:comment>
        <rdfs:label xml:lang="en">Story section</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/time#EndingInterval -->


    <owl:Class rdf:about="https://example.org/story/time#EndingInterval">
        <rdfs:subClassOf rdf:resource="https://example.org/story/time#Interval"/>
