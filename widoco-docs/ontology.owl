            </owl:Class>
        </owl:equivalentClass>
        <owl:disjointWith rdf:resource="https://example.org/story/time#InfiniteInterval"/>
        <rdfs:comment xml:lang="en">An interval with both start and end. Defined as StartingInterval ⊓ EndingInterval.</rdfs:comment>
        <rdfs:label xml:lang="en">Finite interval</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/time#InfiniteInterval -->


    <owl:Class rdf:about="https://example.org/story/time#InfiniteInterval">
        <rdfs:subClassOf rdf:resource="https://example.org/story/time#Interval"/>
        <rdfs:comment xml:lang="en">An interval unbounded on at least one side.</rdfs:comment>
        <rdfs:label xml:lang="en">Infinite interval</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/time#Instant -->


    <owl:Class rdf:about="https://example.org/story/time#Instant">
