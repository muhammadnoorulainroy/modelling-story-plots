                        <owl:someValuesFrom rdf:resource="https://example.org/story/event#Battle"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">A plot event describing a battle.</rdfs:comment>
        <rdfs:label xml:lang="en">Battle plot event</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/plot#BirthPlotEvent -->


    <owl:Class rdf:about="https://example.org/story/plot#BirthPlotEvent">
