    <owl:Class rdf:about="https://example.org/story/social#Appellation">
        <rdfs:comment xml:lang="en">A name, epithet, or title by which a character can be known in the story world.</rdfs:comment>
        <rdfs:label xml:lang="en">Appellation</rdfs:label>
