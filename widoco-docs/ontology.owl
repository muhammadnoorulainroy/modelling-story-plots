                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://example.org/story/plot#PlotEvent"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/story/plot#describesEvent"/>
                        <owl:someValuesFrom rdf:resource="https://example.org/story/event#Birth"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">A plot event describing a birth.</rdfs:comment>
        <rdfs:label xml:lang="en">Birth plot event</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/plot#Chapter -->


    <owl:Class rdf:about="https://example.org/story/plot#Chapter">
        <rdfs:subClassOf rdf:resource="https://example.org/story/plot#StorySection"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/plot#hasChapterNumber"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A main division of the narrative.</rdfs:comment>
        <rdfs:label xml:lang="en">Chapter</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/plot#ClosingPlotEvent -->


    <owl:Class rdf:about="https://example.org/story/plot#ClosingPlotEvent">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://example.org/story/plot#PlotEvent"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://example.org/story/plot#endsWith"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://example.org/story/plot#Story"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">The plot event that ends the whole story.</rdfs:comment>
        <rdfs:label xml:lang="en">Closing plot event</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/plot#Contributor -->


    <owl:Class rdf:about="https://example.org/story/plot#Contributor">
        <owl:disjointWith rdf:resource="https://example.org/story/plot#Publisher"/>
        <rdfs:comment xml:lang="en">A real-world person who contributes to the production of a narrative work.</rdfs:comment>
        <rdfs:label xml:lang="en">Contributor</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/plot#DeathPlotEvent -->


    <owl:Class rdf:about="https://example.org/story/plot#DeathPlotEvent">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://example.org/story/plot#PlotEvent"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/story/plot#describesEvent"/>
                        <owl:someValuesFrom rdf:resource="https://example.org/story/event#Death"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">A plot event describing a death.</rdfs:comment>
        <rdfs:label xml:lang="en">Death plot event</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/plot#Editor -->


    <owl:Class rdf:about="https://example.org/story/plot#Editor">
        <rdfs:subClassOf rdf:resource="https://example.org/story/plot#Contributor"/>
        <rdfs:comment xml:lang="en">A real-world person who edited or compiled the published work.</rdfs:comment>
        <rdfs:label xml:lang="en">Editor</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/plot#Epilogue -->


    <owl:Class rdf:about="https://example.org/story/plot#Epilogue">
        <rdfs:subClassOf rdf:resource="https://example.org/story/plot#StorySection"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/plot#nextSection"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Nothing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A concluding section that follows the main narrative. No section can follow an epilogue (allValuesFrom Nothing on nextSection).</rdfs:comment>
        <rdfs:label xml:lang="en">Epilogue</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/plot#JourneyPlotEvent -->


    <owl:Class rdf:about="https://example.org/story/plot#JourneyPlotEvent">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://example.org/story/plot#PlotEvent"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/story/plot#describesEvent"/>
                        <owl:someValuesFrom rdf:resource="https://example.org/story/event#Journey"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">A plot event describing a journey.</rdfs:comment>
        <rdfs:label xml:lang="en">Journey plot event</rdfs:label>
    </owl:Class>
    


