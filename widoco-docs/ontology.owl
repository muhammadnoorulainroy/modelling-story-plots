            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An interval with a known start.</rdfs:comment>
        <rdfs:label xml:lang="en">Starting interval</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/time#TemporalEntity -->


    <owl:Class rdf:about="https://example.org/story/time#TemporalEntity">
