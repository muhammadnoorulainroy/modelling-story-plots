    </owl:Class>
    


    <!-- https://example.org/story/plot#NarrativeContainer -->


    <owl:Class rdf:about="https://example.org/story/plot#NarrativeContainer">
        <rdfs:comment xml:lang="en">A structural element that can contain other narrative parts.</rdfs:comment>
        <rdfs:label xml:lang="en">Narrative container</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/plot#NarrativeElement -->


    <owl:Class rdf:about="https://example.org/story/plot#NarrativeElement">
        <rdfs:comment xml:lang="en">An atomic narrative element, like a single plot event.</rdfs:comment>
        <rdfs:label xml:lang="en">Narrative element</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/plot#NarrativeWork -->


    <owl:Class rdf:about="https://example.org/story/plot#NarrativeWork">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/plot#hasAuthor"/>
                <owl:someValuesFrom rdf:resource="https://example.org/story/plot#Author"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/plot#narrates"/>
                <owl:allValuesFrom rdf:resource="https://example.org/story/plot#Story"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/plot#hasPublisher"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://example.org/story/plot#Publisher"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/plot#narrates"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://example.org/story/plot#Story"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/plot#hasPublicationDate"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A real-world book, manuscript, or film script with authorship, editorial, and publication metadata.</rdfs:comment>
        <rdfs:label xml:lang="en">Narrative work</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://purl.org/ontology/bibo/Document"/>
        <rdfs:seeAlso rdf:resource="http://schema.org/Book"/>
    </owl:Class>
    


    <!-- https://example.org/story/plot#OpeningPlotEvent -->


    <owl:Class rdf:about="https://example.org/story/plot#OpeningPlotEvent">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://example.org/story/plot#PlotEvent"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://example.org/story/plot#startsWith"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://example.org/story/plot#Story"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">The plot event that starts the whole story.</rdfs:comment>
        <rdfs:label xml:lang="en">Opening plot event</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/plot#PlotEvent -->


    <owl:Class rdf:about="https://example.org/story/plot#PlotEvent">
        <rdfs:subClassOf rdf:resource="https://example.org/story/plot#NarrativeElement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/plot#describesEvent"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://example.org/story/event#Event"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A narrative element describing an in-world event. Bridges the plot layer and the event layer via describesEvent.</rdfs:comment>
        <rdfs:label xml:lang="en">Plot event</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/plot#Prologue -->


    <owl:Class rdf:about="https://example.org/story/plot#Prologue">
        <rdfs:subClassOf rdf:resource="https://example.org/story/plot#StorySection"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://example.org/story/plot#nextSection"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Nothing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An introductory section that precedes the main narrative. No section can precede a prologue (allValuesFrom Nothing on inv(nextSection)).</rdfs:comment>
        <rdfs:label xml:lang="en">Prologue</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/plot#Publisher -->


    <owl:Class rdf:about="https://example.org/story/plot#Publisher">
        <rdfs:comment xml:lang="en">A real-world organization that publishes a narrative work.</rdfs:comment>
        <rdfs:label xml:lang="en">Publisher</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/plot#Story -->


    <owl:Class rdf:about="https://example.org/story/plot#Story">
        <rdfs:subClassOf rdf:resource="https://example.org/story/plot#NarrativeContainer"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/plot#endsWith"/>
                <owl:someValuesFrom rdf:resource="https://example.org/story/plot#PlotEvent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/plot#hasSection"/>
                <owl:someValuesFrom rdf:resource="https://example.org/story/plot#StorySection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/plot#startsWith"/>
                <owl:someValuesFrom rdf:resource="https://example.org/story/plot#PlotEvent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/plot#hasSection"/>
                <owl:allValuesFrom rdf:resource="https://example.org/story/plot#StorySection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/plot#hasSection"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://example.org/story/plot#Epilogue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/plot#hasSection"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://example.org/story/plot#Prologue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://example.org/story/plot#StorySection"/>
        <rdfs:comment xml:lang="en">The fictional story as a whole.</rdfs:comment>
        <rdfs:label xml:lang="en">Story</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/plot#StorySection -->


    <owl:Class rdf:about="https://example.org/story/plot#StorySection">
        <rdfs:subClassOf rdf:resource="https://example.org/story/plot#NarrativeContainer"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/plot#containsPlotEvent"/>
                <owl:someValuesFrom rdf:resource="https://example.org/story/plot#PlotEvent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/plot#containsPlotEvent"/>
                <owl:allValuesFrom rdf:resource="https://example.org/story/plot#PlotEvent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/plot#sectionOf"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://example.org/story/plot#Story"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://example.org/story/plot#Chapter"/>
            <rdf:Description rdf:about="https://example.org/story/plot#Epilogue"/>
            <rdf:Description rdf:about="https://example.org/story/plot#Prologue"/>
        </owl:disjointUnionOf>
        <rdfs:comment xml:lang="en">A structural part of a story: prologue, chapter, or epilogue.</rdfs:comment>
        <rdfs:label xml:lang="en">Story section</rdfs:label>
    </owl:Class>
    


