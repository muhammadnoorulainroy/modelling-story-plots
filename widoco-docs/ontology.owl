            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://example.org/story/plot#StorySection"/>
        <rdfs:comment xml:lang="en">The fictional story as a whole.</rdfs:comment>
        <rdfs:label xml:lang="en">Story</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/plot#StorySection -->


    <owl:Class rdf:about="https://example.org/story/plot#StorySection">
        <rdfs:subClassOf rdf:resource="https://example.org/story/plot#NarrativeContainer"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/plot#containsPlotEvent"/>
