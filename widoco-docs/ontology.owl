        <owl:disjointWith rdf:resource="https://example.org/story/time#Interval"/>
        <rdfs:comment xml:lang="en">A single point in time.</rdfs:comment>
        <rdfs:label xml:lang="en">Instant</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.w3.org/2006/time#Instant"/>
    </owl:Class>
    


    <!-- https://example.org/story/time#Interval -->


    <owl:Class rdf:about="https://example.org/story/time#Interval">
        <rdfs:subClassOf rdf:resource="https://example.org/story/time#TemporalEntity"/>
        <rdfs:comment xml:lang="en">A stretch of time between two instants.</rdfs:comment>
        <rdfs:label xml:lang="en">Interval</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.w3.org/2006/time#Interval"/>
    </owl:Class>
    


    <!-- https://example.org/story/time#StartingInterval -->


