        <rdfs:comment xml:lang="en">An interval with a known end.</rdfs:comment>
        <rdfs:label xml:lang="en">Ending interval</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/story/time#FiniteInterval -->


    <owl:Class rdf:about="https://example.org/story/time#FiniteInterval">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://example.org/story/time#EndingInterval"/>
                    <rdf:Description rdf:about="https://example.org/story/time#StartingInterval"/>
