        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/social#knowledgeHoldsDuring"/>
                <owl:allValuesFrom rdf:resource="https://example.org/story/time#FiniteInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/social#hasKnower"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/story/social#hasKnownCharacter"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
