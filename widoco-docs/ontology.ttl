                                                              <https://purl.org/region/rcc8/ntppi>
                                                            ) ,
                                                            ( <https://purl.org/region/rcc8/ntppi>
                                                              <https://purl.org/region/rcc8/eq>
                                                            ) ,
                                                            ( <https://purl.org/region/rcc8/ntppi>
                                                              <https://purl.org/region/rcc8/tppi>
                                                            ) ,
                                                            ( <https://purl.org/region/rcc8/tppi>
                                                              <https://purl.org/region/rcc8/ntppi>
                                                            ) ;
                                     rdfs:comment "Inverse of NTPP. First region completely contains the second."@en ;
                                     rdfs:label "non-tangential proper part inverse"@en .


###  https://purl.org/region/rcc8/po
<https://purl.org/region/rcc8/po> rdf:type owl:ObjectProperty ,
                                           owl:SymmetricProperty ,
                                           owl:IrreflexiveProperty ;
                                  rdfs:domain <https://purl.org/region/rcc8/Region> ;
                                  rdfs:range <https://purl.org/region/rcc8/Region> ;
                                  rdfs:comment "The regions partially overlap. Each has parts not in the other."@en ;
                                  rdfs:label "partially overlapping"@en .


###  https://purl.org/region/rcc8/tpp
<https://purl.org/region/rcc8/tpp> rdf:type owl:ObjectProperty ,
                                            owl:TransitiveProperty ;
                                   rdfs:domain <https://purl.org/region/rcc8/Region> ;
