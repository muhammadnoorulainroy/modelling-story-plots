                                                                       <https://example.org/story/plot#describesEvent>
                                                                       <https://example.org/story/event#usesItem>
                                                                     ) ;
                                              rdfs:comment "A section mentions an item used in one of its described events."@en ;
                                              rdfs:label "mentions item"@en .


###  https://example.org/story/plot#mentionsParticipant
<https://example.org/story/plot#mentionsParticipant> rdf:type owl:ObjectProperty ;
