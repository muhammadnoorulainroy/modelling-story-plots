                                                                  <https://example.org/story/social#sociallyRelatedTo> ;
                                               rdf:type owl:SymmetricProperty ,
                                                        owl:IrreflexiveProperty ;
                                               rdfs:comment "Characters who travel together or spend significant time together in the story."@en ;
                                               rdfs:label "companion of"@en .


###  https://example.org/story/social#enemyOf
<https://example.org/story/social#enemyOf> rdf:type owl:ObjectProperty ;
                                           rdfs:subPropertyOf <https://example.org/story/social#sociallyRelatedTo> ;
                                           rdf:type owl:SymmetricProperty ;
                                           owl:propertyChainAxiom ( <https://example.org/story/social#allyOf>
                                                                    <https://example.org/story/social#enemyOf>
                                                                  ) ,
                                                                  ( <https://example.org/story/social#serves>
                                                                    <https://example.org/story/social#enemyOf>
                                                                  ) ;
                                           rdfs:comment "Enmity between two characters."@en ;
                                           rdfs:label "enemy of"@en .


