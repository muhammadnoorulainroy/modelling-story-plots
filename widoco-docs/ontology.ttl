                                                                            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                            owl:onClass <https://example.org/story/social#Appellation>
                                                                          ] ,
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty <https://example.org/story/social#knowledgeInPlace> ;
