[ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                         owl:onProperty :isAChildOf ;
                         owl:someValuesFrom <http://purl.org/meo/Adan>
                       ]
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :isAChildOf ;
                         owl:someValuesFrom <http://purl.org/meo/Elda>
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf <http://purl.org/meo/Peredhel>
] .


[ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                         owl:onProperty [ owl:inverseOf :isTheFatherOf
                                        ] ;
                         owl:someValuesFrom <http://purl.org/meo/Atan>
                       ]
                       [ rdf:type owl:Restriction ;
                         owl:onProperty [ owl:inverseOf :isTheMotherOf
                                        ] ;
                         owl:someValuesFrom <http://purl.org/meo/Atan>
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf <http://purl.org/meo/Atan>
] .


[ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                         owl:onProperty [ owl:inverseOf :isTheFatherOf
                                        ] ;
                         owl:someValuesFrom <http://purl.org/meo/Elda>
                       ]
                       [ rdf:type owl:Restriction ;
                         owl:onProperty [ owl:inverseOf :isTheMotherOf
                                        ] ;
                         owl:someValuesFrom <http://purl.org/meo/Elda>
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf <http://purl.org/meo/Elda>
] .


[ rdf:type owl:Restriction ;
  owl:onProperty :isAChildOf ;
  owl:allValuesFrom <http://purl.org/meo/Atan> ;
  rdfs:subClassOf <http://purl.org/meo/Atan>
] .


[ rdf:type owl:Restriction ;
  owl:onProperty :isAChildOf ;
  owl:allValuesFrom <http://purl.org/meo/Elda> ;
  rdfs:subClassOf <http://purl.org/meo/Elda>
] .


[ rdf:type owl:Restriction ;
  owl:onProperty <http://purl.org/meo/served> ;
  owl:hasValue <http://purl.org/meo/morgoth> ;
  rdfs:subClassOf <http://purl.org/meo/EvilBeing>
] .


