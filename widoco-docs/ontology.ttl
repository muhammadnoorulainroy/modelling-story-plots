                                           owl:inverseOf <https://example.org/story/plot#hasSection> ;
                                           rdf:type owl:IrreflexiveProperty ;
                                           rdfs:comment "Inverse of hasSection."@en ;
                                           rdfs:label "section of"@en .


###  https://example.org/story/plot#startsWith
<https://example.org/story/plot#startsWith> rdf:type owl:ObjectProperty ,
                                                     owl:FunctionalProperty ,
                                                     owl:AsymmetricProperty ,
                                                     owl:IrreflexiveProperty ;
                                            rdfs:domain <https://example.org/story/plot#NarrativeContainer> ;
                                            rdfs:range <https://example.org/story/plot#PlotEvent> ;
                                            rdfs:comment "The first plot event in a story or section."@en ;
                                            rdfs:label "starts with"@en .


