                                    rdfs:domain <https://purl.org/region/rcc8/Region> ;
                                    rdfs:range <https://purl.org/region/rcc8/Region> ;
                                    owl:propertyChainAxiom ( <https://purl.org/region/rcc8/eq>
                                                             <https://purl.org/region/rcc8/ntpp>
                                                           ) ,
                                                           ( <https://purl.org/region/rcc8/ntpp>
                                                             <https://purl.org/region/rcc8/eq>
                                                           ) ,
                                                           ( <https://purl.org/region/rcc8/ntpp>
                                                             <https://purl.org/region/rcc8/tpp>
                                                           ) ,
                                                           ( <https://purl.org/region/rcc8/tpp>
                                                             <https://purl.org/region/rcc8/ntpp>
                                                           ) ,
                                                           ( [ owl:inverseOf <https://example.org/story/place#occupiesRegion>
                                                             ]
                                                             <https://example.org/story/place#interiorPartOf>
                                                             <https://example.org/story/place#occupiesRegion>
                                                           ) ;
                                    rdfs:comment "First region is completely inside the second, boundaries don't touch."@en ;
                                    rdfs:label "non-tangential proper part"@en .


###  https://purl.org/region/rcc8/ntppi
<https://purl.org/region/rcc8/ntppi> rdf:type owl:ObjectProperty ;
                                     owl:inverseOf <https://purl.org/region/rcc8/ntpp> ;
                                     rdf:type owl:TransitiveProperty ;
                                     rdfs:domain <https://purl.org/region/rcc8/Region> ;
                                     rdfs:range <https://purl.org/region/rcc8/Region> ;
