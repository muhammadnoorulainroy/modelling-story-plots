###  https://example.org/story/time#EndingInterval
<https://example.org/story/time#EndingInterval> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://example.org/story/time#Interval> ,
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty <https://example.org/story/time#endsAt> ;
                                                                  owl:someValuesFrom <https://example.org/story/time#Instant>
                                                                ] ;
                                                rdfs:comment "An interval with a known end."@en ;
                                                rdfs:label "Ending interval"@en .


###  https://example.org/story/time#FiniteInterval
<https://example.org/story/time#FiniteInterval> rdf:type owl:Class ;
                                                owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/time#EndingInterval>
                                                                                           <https://example.org/story/time#StartingInterval>
                                                                                         ) ;
                                                                      rdf:type owl:Class
                                                                    ] ;
                                                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                  owl:onProperty <https://example.org/story/time#endsAt> ;
                                                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                  owl:onClass <https://example.org/story/time#Instant>
                                                                ] ,
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty <https://example.org/story/time#startsAt> ;
                                                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                  owl:onClass <https://example.org/story/time#Instant>
                                                                ] ;
                                                owl:disjointWith <https://example.org/story/time#InfiniteInterval> ;
                                                rdfs:comment "An interval with both a known start and a known end."@en ;
                                                rdfs:label "Finite interval"@en .


###  https://example.org/story/time#InfiniteInterval
<https://example.org/story/time#InfiniteInterval> rdf:type owl:Class ;
                                                  rdfs:subClassOf <https://example.org/story/time#Interval> ;
                                                  rdfs:comment "An interval unbounded on at least one side."@en ;
                                                  rdfs:label "Infinite interval"@en .


###  https://example.org/story/time#Instant
<https://example.org/story/time#Instant> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://example.org/story/time#TemporalEntity> ;
                                         owl:disjointWith <https://example.org/story/time#Interval> ;
                                         rdfs:comment "A single point in time."@en ;
                                         rdfs:label "Instant"@en ;
                                         rdfs:seeAlso <http://www.w3.org/2006/time#Instant> .


###  https://example.org/story/time#Interval
<https://example.org/story/time#Interval> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://example.org/story/time#TemporalEntity> ;
                                          rdfs:comment "A stretch of time between two instants."@en ;
                                          rdfs:label "Interval"@en ;
                                          rdfs:seeAlso <http://www.w3.org/2006/time#Interval> .


###  https://example.org/story/time#PointInterval
<https://example.org/story/time#PointInterval> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://example.org/story/time#FiniteInterval> ;
                                               rdfs:comment "An interval with zero duration where start and end are the same instant. OWL 2 DL cannot express start=end as a class restriction, so this is a named subclass rather than a defined class."@en ;
                                               rdfs:label "Point interval"@en .


###  https://example.org/story/time#StartingInterval
<https://example.org/story/time#StartingInterval> rdf:type owl:Class ;
                                                  rdfs:subClassOf <https://example.org/story/time#Interval> ,
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty <https://example.org/story/time#startsAt> ;
                                                                    owl:someValuesFrom <https://example.org/story/time#Instant>
                                                                  ] ;
                                                  rdfs:comment "An interval with a known start."@en ;
                                                  rdfs:label "Starting interval"@en .


###  https://example.org/story/time#TemporalEntity
<https://example.org/story/time#TemporalEntity> rdf:type owl:Class ;
                                                rdfs:comment "Superclass of instants and intervals."@en ;
                                                rdfs:label "Temporal entity"@en .


###  https://purl.org/region/rcc8/Region
<https://purl.org/region/rcc8/Region> rdf:type owl:Class ;
                                      rdfs:comment "A continuous extent of space. In story modelling, places occupy regions."@en ;
                                      rdfs:label "region"@en .


