@prefix : <https://example.org/story/ontology#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcterms:created a owl:AnnotationProperty .

dcterms:creator a owl:AnnotationProperty .

dcterms:description a owl:AnnotationProperty .

dcterms:modified a owl:AnnotationProperty .

dcterms:title a owl:AnnotationProperty .

<http://purl.org/family/isABrotherOf> a owl:ObjectProperty ;
    rdfs:label "is a brother of"@en ;
    rdfs:comment "A male sibling of someone."@en ;
    rdfs:domain <http://purl.org/family/Male> ;
    rdfs:subPropertyOf <http://purl.org/family/isASiblingOf> .

<http://purl.org/family/isACousinOf> a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is a cousin of"@en ;
    rdfs:comment "One that is the child of a sibling of the parent of someone else."@en ;
    owl:propertyChainAxiom ( <http://purl.org/family/isAChildOf> <http://purl.org/family/isASiblingOf> <http://purl.org/family/isAParentOf> ) .

<http://purl.org/family/isADaughterOf> a owl:ObjectProperty ;
    rdfs:label "is a daughter of"@en ;
    rdfs:comment "A relation between a female child and his parent."@en ;
    rdfs:domain <http://purl.org/family/Female> ;
    rdfs:subPropertyOf <http://purl.org/family/isAChildOf> .

<http://purl.org/family/isASisterOf> a owl:ObjectProperty ;
    rdfs:label "is a sister of"@en ;
    rdfs:comment "A female sibling of someone."@en ;
    rdfs:domain <http://purl.org/family/Female> ;
    rdfs:subPropertyOf <http://purl.org/family/isASiblingOf> .

<http://purl.org/family/isASonOf> a owl:ObjectProperty ;
    rdfs:label "is a son of"@en ;
    rdfs:comment "A relation between a male child and his parent."@en ;
    rdfs:domain <http://purl.org/family/Male> ;
    rdfs:subPropertyOf <http://purl.org/family/isAChildOf> .

<http://purl.org/family/isMarriedTo> a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is married to"@en ;
    rdfs:comment "People united through marriage."@en ;
    owl:propertyChainAxiom ( [ owl:inverseOf <https://example.org/story/event#hasHusband> ] <https://example.org/story/event#hasWife> ) .

<http://purl.org/meo/Casar> a owl:Class ;
    rdfs:label "Dwarf"@en,
        "Casar"@qya,
        "Naug"@sjn ;
    rdfs:comment "The Casari (plural form of Casar in Quenya), more often called with the Sindarin variant Naugrim (plural of Naug in Sindarin), are the Dwarves created by the Vala AulÃ«."@en ;
    rdfs:subClassOf <http://purl.org/meo/Mortal> ;
    skos:altLabel "Child of AulÃ«"@en,
        "AulÃ«onna"@qya .

<http://purl.org/meo/LÃ³cÃ«> a owl:Class ;
    rdfs:label "Dragon"@en,
        "LÃ³cÃ«"@qya ;
    rdfs:comment "Evil and powerful monster."@en ;
    rdfs:subClassOf <http://purl.org/meo/EvilBeing> .

<http://purl.org/meo/Maia> a owl:Class ;
    rdfs:label "Beautiful"@en,
        "Maia"@qya ;
    rdfs:comment "The Maiar (plural form of Maia) are Ainur who entered Arda and serve the Valar."@en ;
    rdfs:subClassOf <http://purl.org/meo/Ainu> .

<http://purl.org/meo/Torog> a owl:Class ;
    rdfs:label "troll"@en,
        "torog"@sjn ;
    rdfs:comment "The *Teryg (probably the plural form of Torog in Sindarin) are the Trolls, large humanoid monsters of great physical strength and weak intellect."@en ;
    rdfs:subClassOf <http://purl.org/meo/EvilBeing> .

<http://purl.org/meo/melkor> a <http://purl.org/meo/Vala>,
        owl:NamedIndividual ;
    rdfs:label "He who arises in might"@en,
        "Melkor"@qya ;
    rdfs:comment "The greatest of the Ainur."@en ;
    owl:sameAs <http://purl.org/meo/morgoth> .

vann:preferredNamespacePrefix a owl:AnnotationProperty .

vann:preferredNamespaceUri a owl:AnnotationProperty .

xsd:date a rdfs:Datatype .

skos:altLabel a owl:AnnotationProperty .

<https://example.org/story/action#AttackAction> a owl:Class ;
    rdfs:label "Attack action"@en ;
    rdfs:comment "A hostile action directed at a patient. Left as a conservative subclass rather than a defined class, because patienthood alone would wrongly classify non-violent actions such as curses as attacks."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://example.org/story/action#hasPatient> ;
            owl:someValuesFrom owl:Thing ],
        <https://example.org/story/action#Action> .

<https://example.org/story/action#CurseAction> a owl:Class ;
    rdfs:label "Curse action"@en ;
    rdfs:comment "Placing a curse on someone. In the Narn, Morgoth curses the children of HÃºrin."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://example.org/story/action#hasPatient> ;
            owl:someValuesFrom owl:Thing ],
        <https://example.org/story/action#SpeechAction> .

<https://example.org/story/action#MoveAction> a owl:Class ;
    rdfs:label "Move action"@en ;
    rdfs:comment "Moving from one place to another."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass <https://example.org/story/place#Place> ;
            owl:onProperty <https://example.org/story/event#hasOrigin> ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass <https://example.org/story/place#Place> ;
            owl:onProperty <https://example.org/story/event#hasDestination> ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        <https://example.org/story/action#Action> .

<https://example.org/story/action#UseItemAction> a owl:Class ;
    rdfs:label "Use-item action"@en ;
    rdfs:comment "An action that involves an item. Any action with usesItem is classified here."@en ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( <https://example.org/story/action#Action> [ a owl:Restriction ;
                        owl:onProperty <https://example.org/story/event#usesItem> ;
                        owl:someValuesFrom <https://example.org/story/event#Item> ] ) ] .

<https://example.org/story/action#hasAgent> a owl:ObjectProperty ;
    rdfs:label "has agent"@en ;
    rdfs:comment "Who deliberately performs the action. Sub-property of evt:hasAgent."@en ;
    rdfs:subPropertyOf <https://example.org/story/event#hasAgent> .

<https://example.org/story/action#hasPurpose> a owl:DatatypeProperty ;
    rdfs:label "has purpose"@en ;
    rdfs:comment "Why the agent performed the action (textual description)."@en ;
    rdfs:domain <https://example.org/story/action#Action> ;
    rdfs:range xsd:string .

<https://example.org/story/action#resultsIn> a owl:ObjectProperty ;
    rdfs:label "results in"@en ;
    rdfs:comment "What happens as a consequence of the action, e.g. an attack results in a death."@en ;
    rdfs:domain <https://example.org/story/action#Action> ;
    rdfs:range <https://example.org/story/event#Event> .

<https://example.org/story/event#Artifact> a owl:Class ;
    rdfs:label "Artifact"@en ;
    rdfs:comment "A crafted object of special significance, such as a jewel, ring, or magical item."@en ;
    rdfs:subClassOf <https://example.org/story/event#Item> .

<https://example.org/story/event#Faction> a owl:Class ;
    rdfs:label "Faction"@en ;
    rdfs:comment "A collective side in a conflict. Used as combatant in battles instead of individual characters when the conflict involves armies rather than individuals."@en .

<https://example.org/story/event#Vehicle> a owl:Class ;
    rdfs:label "Vehicle"@en ;
    rdfs:comment "A means of transport used in a journey."@en ;
    rdfs:subClassOf <https://example.org/story/event#Item> ;
    owl:disjointWith <https://example.org/story/event#Weapon> .

<https://example.org/story/event#afterEvent> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "after event"@en ;
    rdfs:comment "Inverse of beforeEvent."@en ;
    owl:inverseOf <https://example.org/story/event#beforeEvent> ;
    owl:propertyChainAxiom ( <https://example.org/story/event#hasTemporalExtent> <https://example.org/story/time#afterInterval> <https://example.org/story/event#isTemporalExtentOf> ) .

<https://example.org/story/event#duringEvent> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "during event"@en ;
    rdfs:comment "Event E1 occurs entirely within the time span of event E2."@en ;
    rdfs:domain <https://example.org/story/event#Event> ;
    rdfs:range <https://example.org/story/event#Event> ;
    owl:propertyChainAxiom ( <https://example.org/story/event#hasTemporalExtent> <https://example.org/story/time#duringInterval> <https://example.org/story/event#isTemporalExtentOf> ) .

<https://example.org/story/event#hasVictor> a owl:ObjectProperty ;
    rdfs:label "has victor"@en ;
    rdfs:comment "The winning side of a battle."@en ;
    rdfs:domain <https://example.org/story/event#Battle> ;
    rdfs:subPropertyOf <https://example.org/story/event#hasCombatant> .

<https://example.org/story/event#killed> a owl:ObjectProperty ;
    rdfs:label "killed"@en ;
    rdfs:comment "X killed Y. Inferred from Death events via hasKiller and hasDeceased."@en ;
    owl:propertyChainAxiom ( [ owl:inverseOf <https://example.org/story/event#hasKiller> ] <https://example.org/story/event#hasDeceased> ) .

<https://example.org/story/event#meetsEvent> a owl:ObjectProperty ;
    rdfs:label "meets event"@en ;
    rdfs:comment "Event E1 ends exactly when event E2 starts."@en ;
    rdfs:domain <https://example.org/story/event#Event> ;
    rdfs:range <https://example.org/story/event#Event> ;
    owl:propertyChainAxiom ( <https://example.org/story/event#hasTemporalExtent> <https://example.org/story/time#meetsInterval> <https://example.org/story/event#isTemporalExtentOf> ) .

<https://example.org/story/event#overlapsEvent> a owl:ObjectProperty ;
    rdfs:label "overlaps event"@en ;
    rdfs:comment "Event E1 starts before and partially overlaps event E2."@en ;
    rdfs:domain <https://example.org/story/event#Event> ;
    rdfs:range <https://example.org/story/event#Event> ;
    owl:propertyChainAxiom ( <https://example.org/story/event#hasTemporalExtent> <https://example.org/story/time#overlapsInterval> <https://example.org/story/event#isTemporalExtentOf> ) .

<https://example.org/story/event#partOfEvent> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "part of event"@en ;
    rdfs:comment "Inverse of hasSubEvent."@en ;
    owl:inverseOf <https://example.org/story/event#hasSubEvent> .

<https://example.org/story/event#participatesIn> a owl:ObjectProperty ;
    rdfs:label "participates in"@en ;
    rdfs:comment "Inverse of hasParticipant."@en ;
    owl:inverseOf <https://example.org/story/event#hasParticipant> .

: a owl:Ontology ;
    rdfs:label "Story Plot Ontology"@en ;
    dcterms:created "2026-03-28"^^xsd:date ;
    dcterms:creator "Muhammad Noor Ul Ain" ;
    dcterms:description "A modular OWL ontology for representing story plots, characters, events, places, and narrative structure. Use case: Narn i Chin Hurin (J.R.R. Tolkien)."@en ;
    dcterms:modified "2026-04-03"^^xsd:date ;
    dcterms:title "Story Plot Ontology"@en ;
    vann:preferredNamespacePrefix "spo" ;
    vann:preferredNamespaceUri "https://example.org/story/ontology#" ;
    rdfs:comment "A modular OWL ontology for representing story plots, characters, events, places, and narrative structure. Use case: Narn i Chin Hurin (J.R.R. Tolkien)."@en ;
    owl:versionInfo "1.0" .

<https://example.org/story/place#Forest> a owl:Class ;
    rdfs:label "Forest"@en ;
    rdfs:comment "A large wooded area. E.g. Brethil in the Narn."@en ;
    rdfs:subClassOf <https://example.org/story/place#WoodedArea> .

<https://example.org/story/place#MountainRange> a owl:Class ;
    rdfs:label "Mountain range"@en ;
    rdfs:comment "A chain of mountains."@en ;
    rdfs:subClassOf <https://example.org/story/place#WildArea> .

<https://example.org/story/place#Plain> a owl:Class ;
    rdfs:label "Plain"@en ;
    rdfs:comment "Flat open land."@en ;
    rdfs:subClassOf <https://example.org/story/place#WildArea> .

<https://example.org/story/place#hasCapital> a owl:ObjectProperty ;
    rdfs:label "has capital"@en ;
    rdfs:comment "Inverse of isCapitalOf."@en ;
    owl:inverseOf <https://example.org/story/place#isCapitalOf> .

<https://example.org/story/place#hasFoundationDate> a owl:DatatypeProperty ;
    rdfs:label "has foundation date"@en ;
    rdfs:comment "When the place was established. String because fictional dates don't always fit xsd:date."@en ;
    rdfs:domain <https://example.org/story/place#Place> ;
    rdfs:range xsd:string .

<https://example.org/story/place#hasPart> a owl:ObjectProperty ;
    rdfs:label "has part"@en ;
    rdfs:comment "Inverse of partOf."@en ;
    owl:inverseOf <https://example.org/story/place#partOf> .

<https://example.org/story/place#hasPopulation> a owl:DatatypeProperty ;
    rdfs:label "has population"@en ;
    rdfs:comment "Number of inhabitants. Only makes sense for settlements."@en ;
    rdfs:domain <https://example.org/story/place#Settlement> ;
    rdfs:range xsd:nonNegativeInteger .

<https://example.org/story/plot#containsEvent> a owl:ObjectProperty ;
    rdfs:label "contains event"@en ;
    rdfs:comment "A section contains an in-world event. Inferred from containsPlotEvent and describesEvent."@en ;
    rdfs:domain <https://example.org/story/plot#StorySection> ;
    rdfs:range <https://example.org/story/event#Event> ;
    owl:propertyChainAxiom ( <https://example.org/story/plot#containsPlotEvent> <https://example.org/story/plot#describesEvent> ) .

<https://example.org/story/plot#endsWithEvent> a owl:ObjectProperty ;
    rdfs:label "ends with event"@en ;
    rdfs:comment "The in-world event that ends a story or section. Inferred from endsWith and describesEvent."@en ;
    rdfs:domain <https://example.org/story/plot#NarrativeContainer> ;
    rdfs:range <https://example.org/story/event#Event> ;
    owl:propertyChainAxiom ( <https://example.org/story/plot#endsWith> <https://example.org/story/plot#describesEvent> ) .

<https://example.org/story/plot#hasAuthor> a owl:ObjectProperty ;
    rdfs:label "has author"@en ;
    rdfs:comment "The original author of the narrative work."@en ;
    rdfs:domain <https://example.org/story/plot#NarrativeWork> ;
    rdfs:range <https://example.org/story/plot#Author> ;
    rdfs:subPropertyOf <https://example.org/story/plot#hasContributor> .

<https://example.org/story/plot#hasChapterNumber> a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has chapter number"@en ;
    rdfs:comment "The ordinal number of a chapter within the story."@en ;
    rdfs:domain <https://example.org/story/plot#Chapter> ;
    rdfs:range xsd:positiveInteger .

<https://example.org/story/plot#hasEditor> a owl:ObjectProperty ;
    rdfs:label "has editor"@en ;
    rdfs:comment "An editor or compiler responsible for the published work."@en ;
    rdfs:domain <https://example.org/story/plot#NarrativeWork> ;
    rdfs:range <https://example.org/story/plot#Editor> ;
    rdfs:subPropertyOf <https://example.org/story/plot#hasContributor> .

<https://example.org/story/plot#hasPublicationDate> a owl:DatatypeProperty ;
    rdfs:label "has publication date"@en ;
    rdfs:comment "The real-world date the narrative work was published."@en ;
    rdfs:domain <https://example.org/story/plot#NarrativeWork> ;
    rdfs:range xsd:dateTime .

<https://example.org/story/plot#hasPublisher> a owl:ObjectProperty ;
    rdfs:label "has publisher"@en ;
    rdfs:comment "The publishing organization of the narrative work."@en ;
    rdfs:domain <https://example.org/story/plot#NarrativeWork> ;
    rdfs:range <https://example.org/story/plot#Publisher> .

<https://example.org/story/plot#hasTextSummary> a owl:DatatypeProperty ;
    rdfs:label "has text summary"@en ;
    rdfs:comment "A textual summary. No domain restriction for the same reason as hasTitle."@en ;
    rdfs:range xsd:string .

<https://example.org/story/plot#hasTitle> a owl:DatatypeProperty ;
    rdfs:label "has title"@en ;
    rdfs:comment "The title of a story, section, or narrative work. No domain restriction because both NarrativeContainer and NarrativeWork can have titles."@en ;
    rdfs:range xsd:string .

<https://example.org/story/plot#isDescribedBy> a owl:ObjectProperty ;
    rdfs:label "is described by"@en ;
    rdfs:comment "Inverse of describesEvent. Links an in-world event back to the plot event that narrates it."@en ;
    owl:inverseOf <https://example.org/story/plot#describesEvent> .

<https://example.org/story/plot#narrates> a owl:ObjectProperty ;
    rdfs:label "narrates"@en ;
    rdfs:comment "Links the real-world work to the fictional story it tells."@en ;
    rdfs:domain <https://example.org/story/plot#NarrativeWork> ;
    rdfs:range <https://example.org/story/plot#Story> .

<https://example.org/story/plot#nextSection> a owl:ObjectProperty ;
    rdfs:label "next section"@en ;
    rdfs:comment "The next section in the narrative. Derived from plot event ordering via property chain."@en ;
    rdfs:domain <https://example.org/story/plot#StorySection> ;
    rdfs:range <https://example.org/story/plot#StorySection> ;
    owl:propertyChainAxiom ( <https://example.org/story/plot#endsWith> <https://example.org/story/plot#nextPlotEvent> [ owl:inverseOf <https://example.org/story/plot#startsWith> ] ) .

<https://example.org/story/plot#startsWithEvent> a owl:ObjectProperty ;
    rdfs:label "starts with event"@en ;
    rdfs:comment "The in-world event that starts a story or section. Inferred from startsWith and describesEvent."@en ;
    rdfs:domain <https://example.org/story/plot#NarrativeContainer> ;
    rdfs:range <https://example.org/story/event#Event> ;
    owl:propertyChainAxiom ( <https://example.org/story/plot#startsWith> <https://example.org/story/plot#describesEvent> ) .

<https://example.org/story/social#companionOf> a owl:IrreflexiveProperty,
        owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "companion of"@en ;
    rdfs:comment "Characters who travel together or spend significant time together in the story."@en ;
    rdfs:subPropertyOf <https://example.org/story/social#sociallyRelatedTo> .

<https://example.org/story/social#fosteredBy> a owl:ObjectProperty ;
    rdfs:label "fostered by"@en ;
    rdfs:comment "Inverse of fostersChild."@en ;
    rdfs:subPropertyOf <https://example.org/story/social#sociallyRelatedTo> ;
    owl:inverseOf <https://example.org/story/social#fostersChild> .

<https://example.org/story/social#friendOf> a owl:IrreflexiveProperty,
        owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "friend of"@en ;
    rdfs:comment "Friendship between two characters."@en ;
    rdfs:subPropertyOf <https://example.org/story/social#allyOf>,
        <https://example.org/story/social#sociallyRelatedTo> ;
    owl:propertyDisjointWith <https://example.org/story/social#serves> .

<https://example.org/story/social#livedIn> a owl:ObjectProperty ;
    rdfs:label "lived in"@en ;
    rdfs:comment "Where a character has resided. No rdfs:domain declared because characters, peoples, and other agents could all live somewhere. Range is Place."@en ;
    rdfs:range <https://example.org/story/place#Place> ;
    owl:propertyChainAxiom ( [ owl:inverseOf <https://example.org/story/event#hasResident> ] <https://example.org/story/event#hasLocation> ) .

<https://example.org/story/social#rulesOver> a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "rules over"@en ;
    rdfs:comment "Inverse of serves. The subject has authority over the object."@en ;
    rdfs:subPropertyOf <https://example.org/story/social#sociallyRelatedTo> ;
    owl:inverseOf <https://example.org/story/social#serves> .

<https://example.org/story/social#travelledFrom> a owl:ObjectProperty ;
    rdfs:label "travelled from"@en ;
    rdfs:comment "Inferred from Journey events via hasTraveler and hasOrigin."@en ;
    rdfs:range <https://example.org/story/place#Place> ;
    owl:propertyChainAxiom ( [ owl:inverseOf <https://example.org/story/event#hasTraveler> ] <https://example.org/story/event#hasOrigin> ) .

<https://example.org/story/social#travelledTo> a owl:ObjectProperty ;
    rdfs:label "travelled to"@en ;
    rdfs:comment "Inferred from Journey events via hasTraveler and hasDestination."@en ;
    rdfs:range <https://example.org/story/place#Place> ;
    owl:propertyChainAxiom ( [ owl:inverseOf <https://example.org/story/event#hasTraveler> ] <https://example.org/story/event#hasDestination> ) .

<https://example.org/story/time#FiniteInterval> a owl:Class ;
    rdfs:label "Finite interval"@en ;
    rdfs:comment "An interval with both start and end. Defined as StartingInterval âŠ“ EndingInterval."@en ;
    owl:disjointWith <https://example.org/story/time#InfiniteInterval> ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( <https://example.org/story/time#EndingInterval> <https://example.org/story/time#StartingInterval> ) ] .

<https://example.org/story/time#containsInterval> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "contains"@en ;
    rdfs:comment "Allen's 'contains': inverse of during."@en ;
    rdfs:domain <https://example.org/story/time#Interval> ;
    rdfs:range <https://example.org/story/time#Interval> ;
    owl:inverseOf <https://example.org/story/time#duringInterval> .

<https://example.org/story/time#finishedByInterval> a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "finished by"@en ;
    rdfs:comment "Allen's 'finished by': inverse of finishes."@en ;
    rdfs:domain <https://example.org/story/time#Interval> ;
    rdfs:range <https://example.org/story/time#Interval> ;
    owl:inverseOf <https://example.org/story/time#finishesInterval> ;
    owl:propertyDisjointWith <https://example.org/story/time#finishesInterval>,
        <https://example.org/story/time#startedByInterval>,
        <https://example.org/story/time#startsInterval> .

<https://example.org/story/time#intervalEquals> a owl:ObjectProperty,
        owl:SymmetricProperty,
        owl:TransitiveProperty ;
    rdfs:label "equals"@en ;
    rdfs:comment "Allen's 'equals': same start and end."@en ;
    rdfs:domain <https://example.org/story/time#Interval> ;
    rdfs:range <https://example.org/story/time#Interval> .

<https://example.org/story/time#metByInterval> a owl:ObjectProperty ;
    rdfs:label "met by"@en ;
    rdfs:comment "Allen's 'met by': inverse of meets."@en ;
    rdfs:domain <https://example.org/story/time#Interval> ;
    rdfs:range <https://example.org/story/time#Interval> ;
    owl:inverseOf <https://example.org/story/time#meetsInterval> .

<https://example.org/story/time#occursAfter> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "occurs after"@en ;
    rdfs:comment "Inverse of occursBefore."@en ;
    rdfs:domain <https://example.org/story/time#Instant> ;
    rdfs:range <https://example.org/story/time#Instant> ;
    owl:inverseOf <https://example.org/story/time#occursBefore> .

<https://example.org/story/time#occursDuring> a owl:ObjectProperty ;
    rdfs:label "occurs during"@en ;
    rdfs:comment "An instant that falls within an interval."@en ;
    rdfs:domain <https://example.org/story/time#Instant> ;
    rdfs:range <https://example.org/story/time#Interval> .

<https://example.org/story/time#occursSimultaneouslyWith> a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "occurs simultaneously with"@en ;
    rdfs:comment "Two distinct instants at the same point in time. Used when different IRIs represent the same moment."@en ;
    rdfs:domain <https://example.org/story/time#Instant> ;
    rdfs:range <https://example.org/story/time#Instant> .

<https://example.org/story/time#overlappedByInterval> a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "overlapped by"@en ;
    rdfs:comment "Allen's 'overlapped by': inverse of overlaps."@en ;
    rdfs:domain <https://example.org/story/time#Interval> ;
    rdfs:range <https://example.org/story/time#Interval> ;
    owl:inverseOf <https://example.org/story/time#overlapsInterval> .

<https://purl.org/region/rcc8/dc> a owl:IrreflexiveProperty,
        owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "disconnected"@en ;
    rdfs:comment "The two regions share no points at all."@en ;
    rdfs:domain <https://purl.org/region/rcc8/Region> ;
    rdfs:range <https://purl.org/region/rcc8/Region> ;
    owl:propertyDisjointWith <https://purl.org/region/rcc8/po> .

<https://purl.org/region/rcc8/ec> a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "externally connected"@en ;
    rdfs:comment "Boundaries touch but interiors don't overlap."@en ;
    rdfs:domain <https://purl.org/region/rcc8/Region> ;
    rdfs:range <https://purl.org/region/rcc8/Region> ;
    owl:propertyChainAxiom ( [ owl:inverseOf <https://example.org/story/place#occupiesRegion> ] <https://example.org/story/place#adjacentTo> <https://example.org/story/place#occupiesRegion> ) .

<https://purl.org/region/rcc8/eq> a owl:ObjectProperty,
        owl:SymmetricProperty,
        owl:TransitiveProperty ;
    rdfs:label "equal"@en ;
    rdfs:comment "Same spatial extent. Symmetric and transitive. Reflexivity is part of the intended RCC8 semantics but is not declared in OWL because ReflexiveProperty without domain/range would apply to all individuals, and with domain/range would force everything to be a Region."@en ;
    rdfs:domain <https://purl.org/region/rcc8/Region> ;
    rdfs:range <https://purl.org/region/rcc8/Region> .

<https://purl.org/region/rcc8/ntppi> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "non-tangential proper part inverse"@en ;
    rdfs:comment "Inverse of NTPP. First region completely contains the second."@en ;
    rdfs:domain <https://purl.org/region/rcc8/Region> ;
    rdfs:range <https://purl.org/region/rcc8/Region> ;
    owl:inverseOf <https://purl.org/region/rcc8/ntpp> .

<https://purl.org/region/rcc8/tppi> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "tangential proper part inverse"@en ;
    rdfs:comment "Inverse of TPP. First region contains the second, boundaries touching."@en ;
    rdfs:domain <https://purl.org/region/rcc8/Region> ;
    rdfs:range <https://purl.org/region/rcc8/Region> ;
    owl:inverseOf <https://purl.org/region/rcc8/tpp> .

<http://purl.org/family/isAnAncestorOf> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is an ancestor of"@en ;
    rdfs:comment "A relation between someone and one their of descendants."@en ;
    owl:inverseOf <http://purl.org/family/isADescendentOf> .

<http://purl.org/meo/Adan> a owl:Class ;
    rdfs:label "Man"@en,
        "Adan"@sjn ;
    rdfs:comment "The Edain (plural form of Adan) are the Men that belong to the Three Houses of Men that came to Beleriand in the elder days. Originally, â€œAdanâ€ (plural â€œEdainâ€) is the Sindarin equivalent of Quenya â€œAtanâ€ (plural â€œAtaniâ€) but eventually came to mean this narrow subgroup."@en ;
    rdfs:subClassOf <http://purl.org/meo/Atan> .

<http://purl.org/meo/God> a owl:Class ;
    rdfs:label "God"@en ;
    rdfs:comment "A sperior entity. A singleton class that only contains Eru IlÃºvatar, the One Allfather."@en ;
    owl:equivalentClass [ a owl:Class ;
            owl:oneOf ( <http://purl.org/meo/eru> ) ] .

<http://purl.org/meo/Peredhel> a owl:Class ;
    rdfs:label "Half-elf"@en,
        "Peredhel"@sjn ;
    rdfs:comment "Peredhil are descendent of both elves and humans."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <http://purl.org/family/isADescendentOf> ;
            owl:someValuesFrom <http://purl.org/meo/Atan> ],
        [ a owl:Restriction ;
            owl:onProperty <http://purl.org/family/isADescendentOf> ;
            owl:someValuesFrom <http://purl.org/meo/Elda> ],
        <http://purl.org/meo/Eruhin> .

<http://purl.org/meo/QuendÃ«> a owl:Class ;
    rdfs:label "Elf"@en,
        "QuendÃ«"@qya ;
    rdfs:comment "The Quendi (plural form of QuendÃ«) are the first born of the Children of IlÃºvatar, the Elves. They are named thus because they were the only ones who spoke when they first appeared, before Men and Dwarves came to be. They are more often called the Eldar."@en ;
    rdfs:subClassOf <http://purl.org/meo/Eruhin>,
        <http://purl.org/meo/Immortal> ;
    skos:altLabel "Firstborn"@en,
        "one that speaks"@en,
        "Elda"@qya .

<http://purl.org/meo/Vala> a owl:Class ;
    rdfs:label "angelic power"@en,
        "Vala"@qya ;
    rdfs:comment "The Valar (plural form of Vala) are the most powerful Ainur who entered Arda, the world."@en ;
    rdfs:subClassOf <http://purl.org/meo/Ainu> .

<http://purl.org/meo/eru> a <http://purl.org/meo/God>,
        owl:NamedIndividual ;
    rdfs:label "The One"@en,
        "Eru"@qya ;
    rdfs:comment "The one God creator of everything."@en ;
    skos:altLabel "God"@en,
        "The Allfather"@en,
        "Eru IlÃºvatar"@qya,
        "IlÃºvatar"@qya .

<http://purl.org/meo/served> a owl:ObjectProperty ;
    rdfs:label "serves"@en ;
    rdfs:comment "Relates someone to someone else that they serve. Relation servant-master."@en ;
    owl:equivalentProperty <https://example.org/story/social#serves> .

<https://example.org/story/action#SpeechAction> a owl:Class ;
    rdfs:label "Speech action"@en ;
    rdfs:comment "Deliberate speech: commands, declarations, curses, prophecies."@en ;
    rdfs:subClassOf <https://example.org/story/action#Action> .

<https://example.org/story/event#Conversation> a owl:Class ;
    rdfs:label "Conversation"@en ;
    rdfs:comment "A meeting involving verbal exchange."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onProperty <https://example.org/story/event#hasSpeaker> ],
        <https://example.org/story/event#Meeting> .

<https://example.org/story/event#Coronation> a owl:Class ;
    rdfs:label "Coronation"@en ;
    rdfs:comment "An event in which a character is crowned or given authority."@en ;
    rdfs:subClassOf <https://example.org/story/event#SocialEvent> .

<https://example.org/story/event#NaturalDisaster> a owl:Class ;
    rdfs:label "Natural disaster"@en ;
    rdfs:comment "A catastrophic natural event such as a flood, earthquake, or volcanic eruption."@en ;
    rdfs:subClassOf <https://example.org/story/event#PhysicalEvent> .

<https://example.org/story/event#Reign> a owl:Class ;
    rdfs:label "Reign"@en ;
    rdfs:comment "A state of ruling over a realm or people."@en ;
    rdfs:subClassOf <https://example.org/story/event#State> .

<https://example.org/story/event#Weapon> a owl:Class ;
    rdfs:label "Weapon"@en ;
    rdfs:comment "An object designed or used for combat. Example: Gurthang (TÃºrin's sword)."@en ;
    rdfs:subClassOf <https://example.org/story/event#Item> .

<https://example.org/story/event#beforeEvent> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "before event"@en ;
    rdfs:comment "E1 happens entirely before E2."@en ;
    rdfs:domain <https://example.org/story/event#Event> ;
    rdfs:range <https://example.org/story/event#Event> ;
    owl:propertyChainAxiom ( <https://example.org/story/event#hasTemporalExtent> <https://example.org/story/time#beforeInterval> <https://example.org/story/event#isTemporalExtentOf> ) .

<https://example.org/story/event#hasCaptive> a owl:ObjectProperty ;
    rdfs:label "has captive"@en ;
    rdfs:comment "The character held prisoner."@en ;
    rdfs:domain <https://example.org/story/event#Captivity> ;
    rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> .

<https://example.org/story/event#hasCaptor> a owl:ObjectProperty ;
    rdfs:label "has captor"@en ;
    rdfs:comment "The character or entity holding the captive."@en ;
    rdfs:domain <https://example.org/story/event#Captivity> ;
    rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> .

<https://example.org/story/event#hasOfficiant> a owl:ObjectProperty ;
    rdfs:label "has officiant"@en ;
    rdfs:comment "The authority who validates the marriage (priest, king, etc.)."@en ;
    rdfs:domain <https://example.org/story/event#Marriage> ;
    rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> .

<https://example.org/story/event#hasPatient> a owl:ObjectProperty ;
    rdfs:label "has patient"@en ;
    rdfs:comment "The character affected by the event."@en ;
    rdfs:domain <https://example.org/story/event#Event> ;
    rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> .

<https://example.org/story/event#hasSpeaker> a owl:ObjectProperty ;
    rdfs:label "has speaker"@en ;
    rdfs:comment "A character who speaks during the conversation."@en ;
    rdfs:domain <https://example.org/story/event#Conversation> ;
    rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> .

<https://example.org/story/event#usesItem> a owl:ObjectProperty ;
    rdfs:label "uses item"@en ;
    rdfs:comment "An item used in the event."@en ;
    rdfs:domain <https://example.org/story/event#Event> ;
    rdfs:range <https://example.org/story/event#Item> .

<https://example.org/story/place#City> a owl:Class ;
    rdfs:label "City"@en ;
    rdfs:comment "A large settlement with political importance."@en ;
    rdfs:subClassOf <https://example.org/story/place#Settlement> .

<https://example.org/story/place#Fortress> a owl:Class ;
    rdfs:label "Fortress"@en ;
    rdfs:comment "A fortified settlement or stronghold, like Nargothrond or Menegroth. Not disjoint with City since some fortresses are city-sized."@en ;
    rdfs:subClassOf <https://example.org/story/place#Settlement> .

<https://example.org/story/place#Hamlet> a owl:Class ;
    rdfs:label "Hamlet"@en ;
    rdfs:comment "A very small settlement."@en ;
    rdfs:subClassOf <https://example.org/story/place#Settlement> .

<https://example.org/story/place#Lake> a owl:Class ;
    rdfs:label "Lake"@en ;
    rdfs:comment "Standing water surrounded by land."@en ;
    rdfs:subClassOf <https://example.org/story/place#WaterArea> .

<https://example.org/story/place#River> a owl:Class ;
    rdfs:label "River"@en ;
    rdfs:comment "A flowing watercourse."@en ;
    rdfs:subClassOf <https://example.org/story/place#WaterArea> .

<https://example.org/story/place#Road> a owl:Class ;
    rdfs:label "Road"@en ;
    rdfs:comment "A path or route connecting places."@en ;
    rdfs:subClassOf <https://example.org/story/place#Place> .

<https://example.org/story/place#Room> a owl:Class ;
    rdfs:label "Room"@en ;
    rdfs:comment "A space inside a building or fortified complex."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://example.org/story/place#partOf> ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:unionOf ( <https://example.org/story/place#Building> <https://example.org/story/place#Fortress> ) ] ],
        <https://example.org/story/place#Place> .

<https://example.org/story/place#Sea> a owl:Class ;
    rdfs:label "Sea"@en ;
    rdfs:comment "A large body of salt water."@en ;
    rdfs:subClassOf <https://example.org/story/place#WaterArea> .

<https://example.org/story/place#Town> a owl:Class ;
    rdfs:label "Town"@en ;
    rdfs:comment "Bigger than a hamlet, smaller than a city."@en ;
    rdfs:subClassOf <https://example.org/story/place#Settlement> .

<https://example.org/story/place#WoodedArea> a owl:Class ;
    rdfs:label "Wooded area"@en ;
    rdfs:comment "Area covered mostly by trees."@en ;
    rdfs:subClassOf <https://example.org/story/place#WildArea> .

<https://example.org/story/place#adjacentTo> a owl:IrreflexiveProperty,
        owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "adjacent to"@en ;
    rdfs:comment "Two places that share a boundary or are next to each other."@en ;
    rdfs:domain <https://example.org/story/place#Place> ;
    rdfs:range <https://example.org/story/place#Place> .

<https://example.org/story/place#interiorPartOf> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "interior part of"@en ;
    rdfs:comment "Proper part relation where the subject lies wholly inside the larger place, corresponding to RCC8 NTPP at region level."@en ;
    rdfs:domain <https://example.org/story/place#Place> ;
    rdfs:range <https://example.org/story/place#Place> ;
    rdfs:subPropertyOf <https://example.org/story/place#partOf> .

<https://example.org/story/place#isCapitalOf> a owl:FunctionalProperty,
        owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "is capital of"@en ;
    rdfs:comment "The settlement is the capital of this realm. Functional and inverse-functional (one capital per realm, one realm per capital)."@en ;
    rdfs:domain <https://example.org/story/place#Settlement> ;
    rdfs:range <https://example.org/story/place#Realm> ;
    rdfs:subPropertyOf <https://example.org/story/place#partOf> .

<https://example.org/story/place#tangentialPartOf> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "tangential part of"@en ;
    rdfs:comment "Proper part relation where the subject touches the boundary of the larger place, corresponding to RCC8 TPP at region level."@en ;
    rdfs:domain <https://example.org/story/place#Place> ;
    rdfs:range <https://example.org/story/place#Place> ;
    rdfs:subPropertyOf <https://example.org/story/place#partOf> .

<https://example.org/story/plot#Author> a owl:Class ;
    rdfs:label "Author"@en ;
    rdfs:comment "A real-world person who originally wrote the work."@en ;
    rdfs:seeAlso foaf:Person ;
    rdfs:subClassOf <https://example.org/story/plot#Contributor> .

<https://example.org/story/plot#Editor> a owl:Class ;
    rdfs:label "Editor"@en ;
    rdfs:comment "A real-world person who edited or compiled the published work."@en ;
    rdfs:subClassOf <https://example.org/story/plot#Contributor> .

<https://example.org/story/plot#Epilogue> a owl:Class ;
    rdfs:label "Epilogue"@en ;
    rdfs:comment "A concluding section that follows the main narrative."@en ;
    rdfs:subClassOf <https://example.org/story/plot#StorySection> .

<https://example.org/story/plot#Prologue> a owl:Class ;
    rdfs:label "Prologue"@en ;
    rdfs:comment "An introductory section that precedes the main narrative."@en ;
    rdfs:subClassOf <https://example.org/story/plot#StorySection> .

<https://example.org/story/plot#nextPlotEvent> a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "next plot event"@en ;
    rdfs:comment "The next plot event in the narrative."@en ;
    rdfs:domain <https://example.org/story/plot#PlotEvent> ;
    rdfs:range <https://example.org/story/plot#PlotEvent> ;
    rdfs:subPropertyOf <https://example.org/story/plot#precedesPlotEvent> .

<https://example.org/story/plot#precedesPlotEvent> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "precedes plot event"@en ;
    rdfs:comment "A plot event earlier in the narrative. Transitive."@en ;
    rdfs:domain <https://example.org/story/plot#PlotEvent> ;
    rdfs:range <https://example.org/story/plot#PlotEvent> .

<https://example.org/story/plot#sectionOf> a owl:ObjectProperty ;
    rdfs:label "section of"@en ;
    rdfs:comment "Inverse of hasSection."@en ;
    owl:inverseOf <https://example.org/story/plot#hasSection> .

<https://example.org/story/social#allyOf> a owl:IrreflexiveProperty,
        owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "ally of"@en ;
    rdfs:comment "Alliance, cooperating towards a common goal. Not necessarily friends."@en ;
    rdfs:subPropertyOf <https://example.org/story/social#sociallyRelatedTo> .

<https://example.org/story/social#enemyOf> a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "enemy of"@en ;
    rdfs:comment "Enmity between two characters."@en ;
    rdfs:subPropertyOf <https://example.org/story/social#sociallyRelatedTo> ;
    owl:propertyChainAxiom ( <https://example.org/story/social#serves> <https://example.org/story/social#enemyOf> ) .

<https://example.org/story/social#fostersChild> a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "fosters child"@en ;
    rdfs:comment "Raising someone as a foster-child. E.g. Thingol fosters TÃºrin."@en ;
    rdfs:subPropertyOf <https://example.org/story/social#sociallyRelatedTo> .

<https://example.org/story/time#EndingInterval> a owl:Class ;
    rdfs:label "Ending interval"@en ;
    rdfs:comment "An interval with a known end."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://example.org/story/time#endsAt> ;
            owl:someValuesFrom <https://example.org/story/time#Instant> ],
        <https://example.org/story/time#Interval> .

<https://example.org/story/time#InfiniteInterval> a owl:Class ;
    rdfs:label "Infinite interval"@en ;
    rdfs:comment "An interval unbounded on at least one side."@en ;
    rdfs:subClassOf <https://example.org/story/time#Interval> .

<https://example.org/story/time#StartingInterval> a owl:Class ;
    rdfs:label "Starting interval"@en ;
    rdfs:comment "An interval with a known start."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://example.org/story/time#startsAt> ;
            owl:someValuesFrom <https://example.org/story/time#Instant> ],
        <https://example.org/story/time#Interval> .

<https://example.org/story/time#afterInterval> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "after"@en ;
    rdfs:comment "Allen's 'after': inverse of before."@en ;
    rdfs:domain <https://example.org/story/time#Interval> ;
    rdfs:range <https://example.org/story/time#Interval> ;
    owl:inverseOf <https://example.org/story/time#beforeInterval> .

<https://purl.org/region/rcc8/ntpp> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "non-tangential proper part"@en ;
    rdfs:comment "First region is completely inside the second, boundaries don't touch."@en ;
    rdfs:domain <https://purl.org/region/rcc8/Region> ;
    rdfs:range <https://purl.org/region/rcc8/Region> ;
    owl:propertyChainAxiom ( [ owl:inverseOf <https://example.org/story/place#occupiesRegion> ] <https://example.org/story/place#interiorPartOf> <https://example.org/story/place#occupiesRegion> ) .

<https://purl.org/region/rcc8/po> a owl:IrreflexiveProperty,
        owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "partially overlapping"@en ;
    rdfs:comment "The regions partially overlap. Each has parts not in the other."@en ;
    rdfs:domain <https://purl.org/region/rcc8/Region> ;
    rdfs:range <https://purl.org/region/rcc8/Region> .

<https://purl.org/region/rcc8/tpp> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "tangential proper part"@en ;
    rdfs:comment "First region is inside the second and their boundaries touch."@en ;
    rdfs:domain <https://purl.org/region/rcc8/Region> ;
    rdfs:range <https://purl.org/region/rcc8/Region> ;
    owl:propertyChainAxiom ( [ owl:inverseOf <https://example.org/story/place#occupiesRegion> ] <https://example.org/story/place#tangentialPartOf> <https://example.org/story/place#occupiesRegion> ) .

<http://purl.org/family/isTheFatherOf> a owl:ObjectProperty ;
    rdfs:label "is the father of"@en ;
    rdfs:comment "A relation between a father and his child."@en ;
    rdfs:domain <http://purl.org/family/Male> ;
    rdfs:subPropertyOf <http://purl.org/family/isAParentOf> .

<http://purl.org/family/isTheMotherOf> a owl:ObjectProperty ;
    rdfs:label "is the mother of"@en ;
    rdfs:comment "A relation between a mother and his child."@en ;
    rdfs:domain <http://purl.org/family/Female> ;
    rdfs:subPropertyOf <http://purl.org/family/isAParentOf> .

<http://purl.org/meo/Ainu> a owl:Class ;
    rdfs:label "Holy one"@en,
        "Ainu"@qya ;
    rdfs:comment "The Ainur (plural form of Ainu) are the spirits created by Eru IlÃºvatar before time existed"@en ;
    rdfs:subClassOf <http://purl.org/meo/Immortal> .

<http://purl.org/meo/Immortal> a owl:Class ;
    rdfs:label "immortal"@en ;
    rdfs:comment "An individual that does not die of natural death. Some immortals may die from wounds inflicted to them by violence or accident (like Elves), but some are truly eternal, like the Ainur)."@en ;
    owl:disjointWith <http://purl.org/meo/Mortal> .

<http://purl.org/meo/morgoth> a <http://purl.org/meo/EvilBeing>,
        owl:NamedIndividual ;
    rdfs:label "The Black Enemy"@en,
        "Morgoth"@sjn ;
    rdfs:comment "The only Vala who became evil. The enemy of all other Valar."@en ;
    skos:altLabel "The Constrainer"@en,
        "Bauglir"@sjn .

<https://example.org/story/action#hasPatient> a owl:ObjectProperty ;
    rdfs:label "has patient"@en ;
    rdfs:comment "Who is affected by the action."@en ;
    rdfs:domain <https://example.org/story/action#Action> ;
    rdfs:subPropertyOf <https://example.org/story/event#hasPatient> .

<https://example.org/story/event#Meeting> a owl:Class ;
    rdfs:label "Meeting"@en ;
    rdfs:comment "Two or more characters encounter each other."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onProperty <https://example.org/story/event#hasParticipant> ],
        <https://example.org/story/event#SocialEvent> .

<https://example.org/story/event#Residence> a owl:Class ;
    rdfs:label "Residence"@en ;
    rdfs:comment "A state of living at a particular place for a period of time."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://example.org/story/event#hasResident> ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty <https://example.org/story/event#hasLocation> ;
            owl:someValuesFrom <https://example.org/story/place#Place> ],
        <https://example.org/story/event#State> .

<https://example.org/story/event#War> a owl:Class ;
    rdfs:label "War"@en ;
    rdfs:comment "A prolonged conflict made up of multiple battles."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://example.org/story/event#hasSubEvent> ;
            owl:someValuesFrom <https://example.org/story/event#Battle> ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a owl:Class ;
                    owl:unionOf ( <https://example.org/story/event#Battle> <https://example.org/story/event#War> ) ] ;
            owl:onProperty <https://example.org/story/event#hasSubEvent> ],
        <https://example.org/story/event#PhysicalEvent> .

<https://example.org/story/event#hasAgent> a owl:ObjectProperty ;
    rdfs:label "has agent"@en ;
    rdfs:comment "The active performer of the event."@en ;
    rdfs:domain <https://example.org/story/event#Event> ;
    rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> .

<https://example.org/story/event#hasCombatant> a owl:ObjectProperty ;
    rdfs:label "has combatant"@en ;
    rdfs:comment "A combatant side or individual fighting in the battle."@en ;
    rdfs:domain <https://example.org/story/event#Battle> ;
    rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> .

<https://example.org/story/event#hasFather> a owl:ObjectProperty ;
    rdfs:label "has father"@en ;
    rdfs:comment "The father. Range fo:Male."@en ;
    rdfs:domain <https://example.org/story/event#Birth> ;
    rdfs:range <http://purl.org/family/Male> ;
    rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
    owl:propertyDisjointWith <https://example.org/story/event#hasMother> .

<https://example.org/story/event#hasHusband> a owl:ObjectProperty ;
    rdfs:label "has husband"@en ;
    rdfs:comment "The husband in the marriage."@en ;
    rdfs:domain <https://example.org/story/event#Marriage> ;
    rdfs:range <http://purl.org/family/Male> ;
    rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
    owl:propertyDisjointWith <https://example.org/story/event#hasWife> .

<https://example.org/story/event#hasKiller> a owl:ObjectProperty ;
    rdfs:label "has killer"@en ;
    rdfs:comment "Who caused the death, if anyone."@en ;
    rdfs:domain <https://example.org/story/event#Death> ;
    rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> .

<https://example.org/story/event#hasLocation> a owl:ObjectProperty ;
    rdfs:label "has location"@en ;
    rdfs:comment "The place where an event occurs."@en ;
    rdfs:domain <https://example.org/story/event#Event> ;
    rdfs:range <https://example.org/story/place#Place> .

<https://example.org/story/event#hasResident> a owl:ObjectProperty ;
    rdfs:label "has resident"@en ;
    rdfs:comment "The character residing at a place."@en ;
    rdfs:domain <https://example.org/story/event#Residence> ;
    rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> .

<https://example.org/story/place#Building> a owl:Class ;
    rdfs:label "Building"@en ;
    rdfs:comment "A structure with walls and a roof."@en ;
    rdfs:subClassOf <https://example.org/story/place#Place> .

<https://example.org/story/place#Realm> a owl:Class ;
    rdfs:label "Realm"@en ;
    rdfs:comment "A kingdom or administrative region containing settlements and wild areas."@en ;
    rdfs:subClassOf <https://example.org/story/place#LandArea> .

<https://example.org/story/plot#Chapter> a owl:Class ;
    rdfs:label "Chapter"@en ;
    rdfs:comment "A main division of the narrative."@en ;
    rdfs:subClassOf <https://example.org/story/plot#StorySection> .

<https://example.org/story/plot#NarrativeElement> a owl:Class ;
    rdfs:label "Narrative element"@en ;
    rdfs:comment "An atomic narrative element, like a single plot event."@en .

<https://example.org/story/plot#Publisher> a owl:Class ;
    rdfs:label "Publisher"@en ;
    rdfs:comment "A real-world organization that publishes a narrative work."@en .

<https://example.org/story/plot#containsPlotEvent> a owl:ObjectProperty ;
    rdfs:label "contains plot event"@en ;
    rdfs:comment "A story section contains plot events."@en ;
    rdfs:domain <https://example.org/story/plot#StorySection> ;
    rdfs:range <https://example.org/story/plot#PlotEvent> .

<https://example.org/story/plot#endsWith> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ends with"@en ;
    rdfs:comment "The last plot event in a story or section."@en ;
    rdfs:domain <https://example.org/story/plot#NarrativeContainer> ;
    rdfs:range <https://example.org/story/plot#PlotEvent> .

<https://example.org/story/plot#hasContributor> a owl:ObjectProperty ;
    rdfs:label "has contributor"@en ;
    rdfs:comment "A person who contributed to the narrative work in any role."@en ;
    rdfs:domain <https://example.org/story/plot#NarrativeWork> ;
    rdfs:range <https://example.org/story/plot#Contributor> .

<https://example.org/story/plot#hasSection> a owl:ObjectProperty ;
    rdfs:label "has section"@en ;
    rdfs:comment "A story is divided into sections."@en ;
    rdfs:domain <https://example.org/story/plot#Story> ;
    rdfs:range <https://example.org/story/plot#StorySection> .

<https://example.org/story/plot#startsWith> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "starts with"@en ;
    rdfs:comment "The first plot event in a story or section."@en ;
    rdfs:domain <https://example.org/story/plot#NarrativeContainer> ;
    rdfs:range <https://example.org/story/plot#PlotEvent> .

<https://example.org/story/time#TemporalEntity> a owl:Class ;
    rdfs:label "Temporal entity"@en ;
    rdfs:comment "Superclass of instants and intervals."@en .

<https://example.org/story/time#beforeInterval> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "before"@en ;
    rdfs:comment "Allen's 'before': first interval ends before second starts."@en ;
    rdfs:domain <https://example.org/story/time#Interval> ;
    rdfs:range <https://example.org/story/time#Interval> ;
    owl:propertyChainAxiom ( <https://example.org/story/time#endsAt> <https://example.org/story/time#occursBefore> [ owl:inverseOf <https://example.org/story/time#startsAt> ] ) .

<https://example.org/story/time#duringInterval> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "during"@en ;
    rdfs:comment "Allen's 'during': first interval is entirely within the second."@en ;
    rdfs:domain <https://example.org/story/time#Interval> ;
    rdfs:range <https://example.org/story/time#Interval> .

<https://example.org/story/time#endsAt> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "ends at"@en ;
    rdfs:comment "When an interval ends."@en ;
    rdfs:domain <https://example.org/story/time#Interval> ;
    rdfs:range <https://example.org/story/time#Instant> .

<https://example.org/story/time#finishesInterval> a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "finishes"@en ;
    rdfs:comment "Allen's 'finishes': same end time, first starts after second."@en ;
    rdfs:domain <https://example.org/story/time#Interval> ;
    rdfs:range <https://example.org/story/time#Interval> ;
    owl:propertyDisjointWith <https://example.org/story/time#startedByInterval>,
        <https://example.org/story/time#startsInterval> .

<https://example.org/story/time#meetsInterval> a owl:ObjectProperty ;
    rdfs:label "meets"@en ;
    rdfs:comment "Allen's 'meets': first interval ends exactly when second starts."@en ;
    rdfs:domain <https://example.org/story/time#Interval> ;
    rdfs:range <https://example.org/story/time#Interval> .

<https://example.org/story/time#occursBefore> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "occurs before"@en ;
    rdfs:comment "Strict ordering between instants."@en ;
    rdfs:domain <https://example.org/story/time#Instant> ;
    rdfs:range <https://example.org/story/time#Instant> .

<https://example.org/story/time#overlapsInterval> a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "overlaps"@en ;
    rdfs:comment "Allen's 'overlaps': first starts before second and ends during it."@en ;
    rdfs:domain <https://example.org/story/time#Interval> ;
    rdfs:range <https://example.org/story/time#Interval> .

<https://example.org/story/time#startedByInterval> a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "started by"@en ;
    rdfs:comment "Allen's 'started by': inverse of starts."@en ;
    rdfs:domain <https://example.org/story/time#Interval> ;
    rdfs:range <https://example.org/story/time#Interval> ;
    owl:inverseOf <https://example.org/story/time#startsInterval> ;
    owl:propertyDisjointWith <https://example.org/story/time#startsInterval> .

<https://example.org/story/time#startsAt> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "starts at"@en ;
    rdfs:comment "When an interval begins."@en ;
    rdfs:domain <https://example.org/story/time#Interval> ;
    rdfs:range <https://example.org/story/time#Instant> .

<http://purl.org/family/isASiblingOf> a owl:IrreflexiveProperty,
        owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is a sibling of"@en ;
    rdfs:comment "Two individuals who share the same parent."@en .

<http://purl.org/meo/Eruhin> a owl:Class ;
    rdfs:label "Child of IlÃºvatar"@en,
        "Eruhin"@qya ;
    rdfs:comment "The EruhÃ­ni (plural form of Eruhin), literally â€œthe Children of Eruâ€, are usually called the â€œChildren of IlÃºvatarâ€. They are the Elves and Men. â€œChildren of IlÃºvatarâ€ is used to collectively refer to the two races of Men and Elves, and the singular form is rarely used."@en ;
    skos:altLabel "Child of Eru"@en .

<http://purl.org/meo/Mortal> a owl:Class ;
    rdfs:label "mortal"@en ;
    rdfs:comment "Mortal living being, such as Men and Dwarces."@en .

<https://example.org/story/event#Captivity> a owl:Class ;
    rdfs:label "Captivity"@en ;
    rdfs:comment "Being held prisoner."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://example.org/story/event#hasCaptor> ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty <https://example.org/story/event#hasCaptive> ;
            owl:someValuesFrom owl:Thing ],
        <https://example.org/story/event#State> .

<https://example.org/story/event#Death> a owl:Class ;
    rdfs:label "Death"@en ;
    rdfs:comment "The death of a character."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <https://example.org/story/event#hasDeceased> ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <https://example.org/story/event#hasKiller> ],
        <https://example.org/story/event#SocialEvent> ;
    owl:hasKey ( <https://example.org/story/event#hasDeceased> ) .

<https://example.org/story/event#hasDeceased> a owl:ObjectProperty ;
    rdfs:label "has deceased"@en ;
    rdfs:comment "The character who dies."@en ;
    rdfs:domain <https://example.org/story/event#Death> ;
    rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> .

<https://example.org/story/event#hasDestination> a owl:ObjectProperty ;
    rdfs:label "has destination"@en ;
    rdfs:comment "The destination place of a journey."@en ;
    rdfs:domain <https://example.org/story/event#Journey> ;
    rdfs:range <https://example.org/story/place#Place> .

<https://example.org/story/event#hasMother> a owl:ObjectProperty ;
    rdfs:label "has mother"@en ;
    rdfs:comment "The mother. Range fo:Female."@en ;
    rdfs:domain <https://example.org/story/event#Birth> ;
    rdfs:range <http://purl.org/family/Female> ;
    rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> .

<https://example.org/story/event#hasOrigin> a owl:ObjectProperty ;
    rdfs:label "has origin"@en ;
    rdfs:comment "The starting place of a journey."@en ;
    rdfs:domain <https://example.org/story/event#Journey> ;
    rdfs:range <https://example.org/story/place#Place> .

<https://example.org/story/event#hasSubEvent> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "has sub-event"@en ;
    rdfs:comment "An event contains another as a sub-event. Transitive."@en ;
    rdfs:domain <https://example.org/story/event#Event> ;
    rdfs:range <https://example.org/story/event#Event> .

<https://example.org/story/event#hasTraveler> a owl:ObjectProperty ;
    rdfs:label "has traveler"@en ;
    rdfs:comment "A character or group undertaking the journey."@en ;
    rdfs:domain <https://example.org/story/event#Journey> ;
    rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> .

<https://example.org/story/event#hasWife> a owl:ObjectProperty ;
    rdfs:label "has wife"@en ;
    rdfs:comment "The wife in the marriage."@en ;
    rdfs:domain <https://example.org/story/event#Marriage> ;
    rdfs:range <http://purl.org/family/Female> ;
    rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> .

<https://example.org/story/plot#Contributor> a owl:Class ;
    rdfs:label "Contributor"@en ;
    rdfs:comment "A real-world person who contributes to the production of a narrative work."@en ;
    owl:disjointWith <https://example.org/story/plot#Publisher> .

<https://example.org/story/plot#Story> a owl:Class ;
    rdfs:label "Story"@en ;
    rdfs:comment "The fictional story as a whole."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://example.org/story/plot#hasSection> ;
            owl:someValuesFrom <https://example.org/story/plot#StorySection> ],
        <https://example.org/story/plot#NarrativeContainer> ;
    owl:disjointWith <https://example.org/story/plot#StorySection> .

<http://purl.org/family/isADescendentOf> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is a descendent of"@en ;
    rdfs:comment "A relation between someone and one of their ancestors."@en .

<http://purl.org/family/isAParentOf> a owl:ObjectProperty ;
    rdfs:label "is a parent of"@en ;
    rdfs:comment "A relation between a parent and their child"@en ;
    rdfs:subPropertyOf <http://purl.org/family/isAnAncestorOf> .

<http://purl.org/meo/EvilBeing> a owl:Class ;
    rdfs:label "evil being"@en ;
    rdfs:comment "The evil beings are sentient agents that have chosen to do bad things, behave badly for the sake of doing bad, or became corrupted into doing evil. Some things are raised and bred to be evil. Some things are led to become evil by other evil beings by subversion. Some choose to become evil due to greed or as a way to overcome hardships of their lives."@en .

<https://example.org/story/event#Birth> a owl:Class ;
    rdfs:label "Birth"@en ;
    rdfs:comment "The birth of a character."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <https://example.org/story/event#hasFather> ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <https://example.org/story/event#hasNewborn> ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <https://example.org/story/event#hasMother> ],
        <https://example.org/story/event#SocialEvent> ;
    owl:hasKey ( <https://example.org/story/event#hasNewborn> ) .

<https://example.org/story/event#Journey> a owl:Class ;
    rdfs:label "Journey"@en ;
    rdfs:comment "Moving from one place to another."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://example.org/story/event#hasTraveler> ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onClass <https://example.org/story/place#Place> ;
            owl:onProperty <https://example.org/story/event#hasDestination> ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass <https://example.org/story/place#Place> ;
            owl:onProperty <https://example.org/story/event#hasOrigin> ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        <https://example.org/story/event#PhysicalEvent> .

<https://example.org/story/event#Marriage> a owl:Class ;
    rdfs:label "Marriage"@en ;
    rdfs:comment "A marriage event with husband, wife, and officiant roles."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <https://example.org/story/event#hasHusband> ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <https://example.org/story/event#hasOfficiant> ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <https://example.org/story/event#hasWife> ],
        <https://example.org/story/event#SocialEvent> .

<https://example.org/story/event#State> a owl:Class ;
    rdfs:label "State"@en ;
    rdfs:comment "An ongoing state of affairs: a residence, captivity, or reign."@en ;
    rdfs:subClassOf <https://example.org/story/event#Event> .

<https://example.org/story/event#hasNewborn> a owl:ObjectProperty ;
    rdfs:label "has newborn"@en ;
    rdfs:comment "The character born."@en ;
    rdfs:domain <https://example.org/story/event#Birth> ;
    rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> .

<https://example.org/story/place#LandArea> a owl:Class ;
    rdfs:label "Land area"@en ;
    rdfs:comment "A place on land."@en ;
    rdfs:subClassOf <https://example.org/story/place#Place> .

<https://example.org/story/place#WaterArea> a owl:Class ;
    rdfs:label "Water area"@en ;
    rdfs:comment "A body of water: river, lake, or sea."@en ;
    rdfs:subClassOf <https://example.org/story/place#Place> .

<https://example.org/story/place#WildArea> a owl:Class ;
    rdfs:label "Wild area"@en ;
    rdfs:comment "Uninhabited natural area."@en ;
    rdfs:subClassOf <https://example.org/story/place#LandArea> .

<https://example.org/story/social#serves> a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "serves"@en ;
    rdfs:comment "A vassal/servant relation. Linked to meo:served so facts work with both properties."@en ;
    rdfs:subPropertyOf <https://example.org/story/social#sociallyRelatedTo> .

<https://example.org/story/time#startsInterval> a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "starts"@en ;
    rdfs:comment "Allen's 'starts': same start time, first ends before second."@en ;
    rdfs:domain <https://example.org/story/time#Interval> ;
    rdfs:range <https://example.org/story/time#Interval> .

<http://purl.org/family/Female> a owl:Class ;
    rdfs:label "female"@en ;
    rdfs:comment "A female individual. The gender may be a 'natural' one, attributed at birth, or a given one by social conventions."@en ;
    owl:disjointWith <http://purl.org/family/Male> .

<https://example.org/story/event#Battle> a owl:Class ;
    rdfs:label "Battle"@en ;
    rdfs:comment "A violent confrontation."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onProperty <https://example.org/story/event#hasCombatant> ],
        <https://example.org/story/event#PhysicalEvent> .

<https://example.org/story/event#Item> a owl:Class ;
    rdfs:label "Item"@en ;
    rdfs:comment "A significant object that can be used in events. Items include weapons, vehicles, and artifacts."@en .

<https://example.org/story/event#PhysicalEvent> a owl:Class ;
    rdfs:label "Physical event"@en ;
    rdfs:comment "Events with physical consequences: battles, journeys, disasters."@en ;
    rdfs:subClassOf <https://example.org/story/event#Event> .

<https://example.org/story/event#isTemporalExtentOf> a owl:ObjectProperty ;
    rdfs:label "is temporal extent of"@en ;
    rdfs:comment "Inverse of hasTemporalExtent."@en ;
    owl:inverseOf <https://example.org/story/event#hasTemporalExtent> .

<https://example.org/story/place#partOf> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "part of"@en ;
    rdfs:comment "Spatial containment between places. E.g. Menegroth is part of Doriath."@en ;
    rdfs:domain <https://example.org/story/place#Place> ;
    rdfs:range <https://example.org/story/place#Place> .

<https://example.org/story/plot#describesEvent> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "describes event"@en ;
    rdfs:comment "Links a plot event to the in-world event it describes."@en ;
    rdfs:domain <https://example.org/story/plot#PlotEvent> ;
    rdfs:range <https://example.org/story/event#Event> .

<http://purl.org/family/Male> a owl:Class ;
    rdfs:label "male"@en ;
    rdfs:comment "A male individual. The gender may be a 'natural' one, attributed at birth, or a given one by social conventions."@en .

<https://example.org/story/event#SocialEvent> a owl:Class ;
    rdfs:label "Social event"@en ;
    rdfs:comment "Events with social significance: births, deaths, marriages, coronations."@en ;
    rdfs:subClassOf <https://example.org/story/event#Event> .

<https://example.org/story/place#occupiesRegion> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "occupies region"@en ;
    rdfs:comment "Links a place to its spatial region. Functional (one region per place). Enables RCC8 reasoning on places."@en ;
    rdfs:domain <https://example.org/story/place#Place> ;
    rdfs:range <https://purl.org/region/rcc8/Region> .

<http://purl.org/family/isAChildOf> a owl:ObjectProperty ;
    rdfs:label "is a child of"@en ;
    rdfs:comment "A relation between someone and their parent"@en ;
    rdfs:subPropertyOf <http://purl.org/family/isADescendentOf> ;
    owl:inverseOf <http://purl.org/family/isAParentOf> ;
    owl:propertyChainAxiom ( [ owl:inverseOf <https://example.org/story/event#hasNewborn> ] <https://example.org/story/event#hasMother> ),
        ( [ owl:inverseOf <https://example.org/story/event#hasNewborn> ] <https://example.org/story/event#hasFather> ) .

<http://purl.org/meo/Atan> a owl:Class ;
    rdfs:label "Man"@en,
        "Atan"@qya,
        "Adan"@sjn ;
    rdfs:comment "The Atani (plural form of Atan) are the second born of the Children of IlÃºvatar, the Men (i.e. Humans, not male people). They were given many names also by the Eldar."@en ;
    rdfs:subClassOf <http://purl.org/meo/Eruhin>,
        <http://purl.org/meo/Mortal> ;
    skos:altLabel "After-born"@en,
        "After-comer"@en,
        "Follower"@en,
        "Human"@en,
        "Mortal"@en,
        "Secondborn"@en,
        "Sickly"@en,
        "ApanÃ³na"@qya,
        "Engwa"@qya,
        "FÃ­rima"@qya,
        "Hildo"@qya .

<http://purl.org/meo/Elda> a owl:Class ;
    rdfs:label "Elf"@en,
        "Elda"@qya,
        "Eledh"@sjn ;
    rdfs:comment "The Eldar (plural form of Elda) are the Elves. They initially called themselves the Quendi, but the Vala OromÃ«, who met them at lake CuiviÃ©nen under the stars, called them the Eldar. Now only the Quendi who followed OromÃ« to the West call themselves Eldar."@en ;
    owl:equivalentClass <http://purl.org/meo/QuendÃ«> ;
    skos:altLabel "Firstborn"@en,
        "of the stars"@en,
        "person of the stars"@en .

<https://example.org/story/action#Action> a owl:Class ;
    rdfs:label "Action"@en ;
    rdfs:comment "An event with a deliberate agent. Defined as Action â‰¡ Event âŠ“ âˆƒevt:hasAgent.âŠ¤, so any event that has an agent gets classified as an action automatically."@en ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( <https://example.org/story/event#Event> [ a owl:Restriction ;
                        owl:onProperty <https://example.org/story/event#hasAgent> ;
                        owl:someValuesFrom owl:Thing ] ) ] .

<https://example.org/story/event#hasTemporalExtent> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has temporal extent"@en ;
    rdfs:comment "When the event occurs (as an interval)."@en ;
    rdfs:domain <https://example.org/story/event#Event> ;
    rdfs:range <https://example.org/story/time#Interval> .

<https://example.org/story/place#Settlement> a owl:Class ;
    rdfs:label "Settlement"@en ;
    rdfs:comment "An inhabited place. Has a population."@en ;
    rdfs:subClassOf <https://example.org/story/place#LandArea> .

<https://example.org/story/plot#NarrativeContainer> a owl:Class ;
    rdfs:label "Narrative container"@en ;
    rdfs:comment "A structural element that can contain other narrative parts."@en .

<https://example.org/story/plot#NarrativeWork> a owl:Class ;
    rdfs:label "Narrative work"@en ;
    rdfs:comment "A real-world book, manuscript, or film script with authorship, editorial, and publication metadata."@en ;
    rdfs:seeAlso <http://purl.org/ontology/bibo/Document>,
        <http://schema.org/Book> .

<https://example.org/story/social#sociallyRelatedTo> a owl:ObjectProperty ;
    rdfs:label "socially related to"@en ;
    rdfs:comment "Top-level property grouping all social relations."@en .

<https://example.org/story/plot#PlotEvent> a owl:Class ;
    rdfs:label "Plot event"@en ;
    rdfs:comment "A narrative element describing an in-world event. Bridges the plot layer and the event layer via describesEvent."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass <https://example.org/story/event#Event> ;
            owl:onProperty <https://example.org/story/plot#describesEvent> ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        <https://example.org/story/plot#NarrativeElement> .

<https://example.org/story/plot#StorySection> a owl:Class ;
    rdfs:label "Story section"@en ;
    rdfs:comment "A structural part of a story: prologue, chapter, or epilogue."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass <https://example.org/story/plot#Story> ;
            owl:onProperty <https://example.org/story/plot#sectionOf> ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onProperty <https://example.org/story/plot#containsPlotEvent> ;
            owl:someValuesFrom <https://example.org/story/plot#PlotEvent> ],
        <https://example.org/story/plot#NarrativeContainer> .

<https://example.org/story/time#Instant> a owl:Class ;
    rdfs:label "Instant"@en ;
    rdfs:comment "A single point in time."@en ;
    rdfs:seeAlso time:Instant ;
    rdfs:subClassOf <https://example.org/story/time#TemporalEntity> ;
    owl:disjointWith <https://example.org/story/time#Interval> .

<https://purl.org/region/rcc8/Region> a owl:Class ;
    rdfs:label "region"@en ;
    rdfs:comment "A continuous extent of space. In story modelling, places occupy regions."@en .

<https://example.org/story/event#hasParticipant> a owl:ObjectProperty ;
    rdfs:label "has participant"@en ;
    rdfs:comment "A character or collective actor involved in the event."@en ;
    rdfs:domain <https://example.org/story/event#Event> .

<https://example.org/story/event#Event> a owl:Class ;
    rdfs:label "Event"@en ;
    rdfs:comment "Something that happens in the story world, with a time, place, and participants."@en ;
    rdfs:seeAlso <http://purl.org/NET/c4dm/event.owl#Event>,
        <http://schema.org/Event> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://example.org/story/event#hasTemporalExtent> ;
            owl:someValuesFrom <https://example.org/story/time#Interval> ] .

<https://example.org/story/place#Place> a owl:Class ;
    rdfs:label "Place"@en ;
    rdfs:comment "A named location in the story world."@en .

<https://example.org/story/time#Interval> a owl:Class ;
    rdfs:label "Interval"@en ;
    rdfs:comment "A stretch of time between two instants."@en ;
    rdfs:seeAlso time:Interval ;
    rdfs:subClassOf <https://example.org/story/time#TemporalEntity> .

[] a owl:AllDisjointClasses ;
    owl:members ( <https://example.org/story/place#Lake> <https://example.org/story/place#River> <https://example.org/story/place#Sea> ) .

[] a owl:AllDisjointClasses ;
    owl:members ( <https://example.org/story/event#Captivity> <https://example.org/story/event#Reign> <https://example.org/story/event#Residence> ) .

[] a owl:Class ;
    rdfs:subClassOf <http://purl.org/meo/Peredhel> ;
    owl:intersectionOf ( [ a owl:Restriction ;
                owl:onProperty <http://purl.org/family/isAChildOf> ;
                owl:someValuesFrom <http://purl.org/meo/Adan> ] [ a owl:Restriction ;
                owl:onProperty <http://purl.org/family/isAChildOf> ;
                owl:someValuesFrom <http://purl.org/meo/Elda> ] ) .

[] a owl:AllDisjointClasses ;
    owl:members ( <https://example.org/story/event#Battle> <https://example.org/story/event#Journey> <https://example.org/story/event#NaturalDisaster> <https://example.org/story/event#War> ) .

[] a owl:Class ;
    rdfs:subClassOf <http://purl.org/meo/Atan> ;
    owl:intersectionOf ( [ a owl:Restriction ;
                owl:onProperty [ owl:inverseOf <http://purl.org/family/isTheFatherOf> ] ;
                owl:someValuesFrom <http://purl.org/meo/Atan> ] [ a owl:Restriction ;
                owl:onProperty [ owl:inverseOf <http://purl.org/family/isTheMotherOf> ] ;
                owl:someValuesFrom <http://purl.org/meo/Atan> ] ) .

[] a owl:AllDisjointClasses ;
    owl:members ( <https://example.org/story/event#PhysicalEvent> <https://example.org/story/event#SocialEvent> <https://example.org/story/event#State> ) .

[] a owl:Restriction ;
    rdfs:subClassOf <http://purl.org/meo/Elda> ;
    owl:allValuesFrom <http://purl.org/meo/Elda> ;
    owl:onProperty <http://purl.org/family/isAChildOf> .

[] a owl:AllDisjointClasses ;
    owl:members ( <https://example.org/story/place#City> <https://example.org/story/place#Hamlet> <https://example.org/story/place#Town> ) .

[] a owl:Restriction ;
    rdfs:subClassOf <http://purl.org/meo/Atan> ;
    owl:allValuesFrom <http://purl.org/meo/Atan> ;
    owl:onProperty <http://purl.org/family/isAChildOf> .

[] a owl:AllDisjointClasses ;
    owl:members ( <https://example.org/story/place#Realm> <https://example.org/story/place#Settlement> <https://example.org/story/place#WildArea> ) .

[] a owl:Restriction ;
    rdfs:subClassOf <http://purl.org/meo/EvilBeing> ;
    owl:hasValue <http://purl.org/meo/morgoth> ;
    owl:onProperty <http://purl.org/meo/served> .

[] a owl:AllDisjointClasses ;
    owl:members ( <https://example.org/story/event#Birth> <https://example.org/story/event#Coronation> <https://example.org/story/event#Death> <https://example.org/story/event#Marriage> <https://example.org/story/event#Meeting> ) .

[] a owl:Class ;
    rdfs:subClassOf <http://purl.org/meo/Elda> ;
    owl:intersectionOf ( [ a owl:Restriction ;
                owl:onProperty [ owl:inverseOf <http://purl.org/family/isTheFatherOf> ] ;
                owl:someValuesFrom <http://purl.org/meo/Elda> ] [ a owl:Restriction ;
                owl:onProperty [ owl:inverseOf <http://purl.org/family/isTheMotherOf> ] ;
                owl:someValuesFrom <http://purl.org/meo/Elda> ] ) .

[] a owl:AllDisjointClasses ;
    owl:members ( <https://example.org/story/place#Building> <https://example.org/story/place#LandArea> <https://example.org/story/place#Road> <https://example.org/story/place#Room> <https://example.org/story/place#WaterArea> ) .

[] a owl:AllDisjointClasses ;
    owl:members ( <https://example.org/story/plot#NarrativeContainer> <https://example.org/story/plot#NarrativeElement> <https://example.org/story/plot#NarrativeWork> ) .

[] a owl:AllDisjointClasses ;
    owl:members ( <https://example.org/story/plot#Chapter> <https://example.org/story/plot#Epilogue> <https://example.org/story/plot#Prologue> ) .

