@prefix : <http://purl.org/family/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://purl.org/family/> .

<http://purl.org/family/> rdf:type owl:Ontology ;
                           <http://purl.org/dc/terms/created> "2023-11-19T07:42:42+01:00"^^xsd:dateTime ,
                                                              "2023-11-19T14:42:42+01:00"^^xsd:dateTime ,
                                                              "2026-03-28T00:00:00+00:00"^^xsd:dateTime ;
                           <http://purl.org/dc/terms/creator> <https://w3id.org/people/az/me> ;
                           <http://purl.org/dc/terms/modified> "2026-01-23T13:42:42+01:00"^^xsd:dateTime ;
                           <http://purl.org/dc/terms/title> "Action Ontology"@en ,
                                                            "Event Ontology"@en ,
                                                            "Place Ontology"@en ,
                                                            "Plot Structure Ontology"@en ,
                                                            "Region Connection Calculus (RCC8) Ontology"@en ,
                                                            "Social Relations Ontology"@en ,
                                                            "The Family Ontology"@en ,
                                                            "The Middle-earth ontology"@en ,
                                                            "Time Ontology"@en ;
                           rdfs:comment "Actions as a subclass of events, defined by having an intentional agent."@en ,
                                        "An ontology for J.R.R. Tolkienʼs legendarium."@en ,
                                        "An ontology for family relationships."@en ,
                                        "Events in story plots: occurrences involving characters, places, and time. Includes an event hierarchy, participant roles, and temporal relations."@en ,
                                        "Instants, intervals, and Allen's 13 temporal relations."@en ,
                                        "Narrative and literary structure of stories, with a real-world layer (authors, books) and a fictional layer (sections, plot events)."@en ,
                                        "Non-familial social relations between characters: friendship, enmity, alliance, service, etc."@en ,
                                        "Place categories and spatial relations for story plots."@en ,
                                        "RCC8 spatial relations between regions, encoded with DL-safe OWL axioms."@en ;
                           rdfs:label "Action Ontology"@en ,
                                      "Event Ontology"@en ,
                                      "Place Ontology"@en ,
                                      "Plot Structure Ontology"@en ,
                                      "Social Relations Ontology"@en ,
                                      "The Middle-earth ontology"@en ,
                                      "The RCC8 ontology"@en ,
                                      "The family ontology"@en ,
                                      "Time Ontology"@en ;
                           owl:versionInfo "1.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
<http://purl.org/dc/terms/modified> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
<http://www.w3.org/2004/02/skos/core#altLabel> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://purl.org/family/isABrotherOf
:isABrotherOf rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :isASiblingOf ;
              rdfs:domain :Male ;
              rdfs:comment "A male sibling of someone."@en ;
              rdfs:label "is a brother of"@en .


###  http://purl.org/family/isAChildOf
:isAChildOf rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :isADescendentOf ;
            owl:inverseOf :isAParentOf ;
            owl:propertyChainAxiom ( [ owl:inverseOf <https://example.org/story/event#hasNewborn>
                                     ]
                                     <https://example.org/story/event#hasFather>
                                   ) ,
                                   ( [ owl:inverseOf <https://example.org/story/event#hasNewborn>
                                     ]
                                     <https://example.org/story/event#hasMother>
                                   ) ;
            rdfs:comment "A relation between someone and their parent"@en ;
            rdfs:label "is a child of"@en .


###  http://purl.org/family/isACousinOf
:isACousinOf rdf:type owl:ObjectProperty ,
                      owl:SymmetricProperty ;
             owl:propertyChainAxiom ( :isAChildOf
                                      :isASiblingOf
                                      :isAParentOf
                                    ) ;
             rdfs:comment "One that is the child of a sibling of the parent of someone else."@en ;
             rdfs:label "is a cousin of"@en .


###  http://purl.org/family/isADaughterOf
:isADaughterOf rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :isAChildOf ;
               rdfs:domain :Female ;
               rdfs:comment "A relation between a female child and his parent."@en ;
               rdfs:label "is a daughter of"@en .


###  http://purl.org/family/isADescendentOf
:isADescendentOf rdf:type owl:ObjectProperty ,
                          owl:TransitiveProperty ;
                 rdfs:comment "A relation between someone and one of their ancestors."@en ;
                 rdfs:label "is a descendent of"@en .


###  http://purl.org/family/isAParentOf
:isAParentOf rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :isAnAncestorOf ;
             rdfs:comment "A relation between a parent and their child"@en ;
             rdfs:label "is a parent of"@en .


###  http://purl.org/family/isASiblingOf
:isASiblingOf rdf:type owl:ObjectProperty ,
                       owl:SymmetricProperty ,
                       owl:IrreflexiveProperty ;
              rdfs:comment "Two individuals who share the same parent."@en ;
              rdfs:label "is a sibling of"@en .


###  http://purl.org/family/isASisterOf
:isASisterOf rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :isASiblingOf ;
             rdfs:domain :Female ;
             rdfs:comment "A female sibling of someone."@en ;
             rdfs:label "is a sister of"@en .


###  http://purl.org/family/isASonOf
:isASonOf rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :isAChildOf ;
          rdfs:domain :Male ;
          rdfs:comment "A relation between a male child and his parent."@en ;
          rdfs:label "is a son of"@en .


###  http://purl.org/family/isAnAncestorOf
:isAnAncestorOf rdf:type owl:ObjectProperty ;
                owl:inverseOf :isADescendentOf ;
                rdf:type owl:TransitiveProperty ;
                rdfs:comment "A relation between someone and one their of descendants."@en ;
                rdfs:label "is an ancestor of"@en .


###  http://purl.org/family/isMarriedTo
:isMarriedTo rdf:type owl:ObjectProperty ,
                      owl:SymmetricProperty ;
             owl:propertyChainAxiom ( [ owl:inverseOf <https://example.org/story/event#hasHusband>
                                      ]
                                      <https://example.org/story/event#hasWife>
                                    ) ;
             rdfs:comment "People united through marriage."@en ;
             rdfs:label "is married to"@en .


###  http://purl.org/family/isTheFatherOf
:isTheFatherOf rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :isAParentOf ;
               rdfs:domain :Male ;
               rdfs:comment "A relation between a father and his child."@en ;
               rdfs:label "is the father of"@en .


###  http://purl.org/family/isTheMotherOf
:isTheMotherOf rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :isAParentOf ;
               rdfs:domain :Female ;
               rdfs:comment "A relation between a mother and his child."@en ;
               rdfs:label "is the mother of"@en .


###  http://purl.org/meo/served
<http://purl.org/meo/served> rdf:type owl:ObjectProperty ;
                             owl:equivalentProperty <https://example.org/story/social#serves> ;
                             rdfs:comment "Relates someone to someone else that they serve. Relation servant-master."@en ;
                             rdfs:label "serves"@en .


###  https://example.org/story/action#hasAgent
<https://example.org/story/action#hasAgent> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <https://example.org/story/event#hasAgent> ;
                                            rdfs:comment "Who deliberately performs the action. Sub-property of evt:hasAgent."@en ;
                                            rdfs:label "has agent"@en .


###  https://example.org/story/action#hasPatient
<https://example.org/story/action#hasPatient> rdf:type owl:ObjectProperty ;
                                              rdfs:subPropertyOf <https://example.org/story/event#hasPatient> ;
                                              rdfs:domain <https://example.org/story/action#Action> ;
                                              rdfs:comment "Who is affected by the action."@en ;
                                              rdfs:label "has patient"@en .


###  https://example.org/story/action#resultsIn
<https://example.org/story/action#resultsIn> rdf:type owl:ObjectProperty ;
                                             rdfs:domain <https://example.org/story/action#Action> ;
                                             rdfs:range <https://example.org/story/event#Event> ;
                                             rdfs:comment "What happens as a consequence of the action, e.g. an attack results in a death."@en ;
                                             rdfs:label "results in"@en .


###  https://example.org/story/event#afterEvent
<https://example.org/story/event#afterEvent> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <https://example.org/story/event#beforeEvent> ;
                                             rdf:type owl:TransitiveProperty ;
                                             owl:propertyChainAxiom ( <https://example.org/story/event#hasTemporalExtent>
                                                                      <https://example.org/story/time#afterInterval>
                                                                      <https://example.org/story/event#isTemporalExtentOf>
                                                                    ) ;
                                             rdfs:comment "Inverse of beforeEvent."@en ;
                                             rdfs:label "after event"@en .


###  https://example.org/story/event#beforeEvent
<https://example.org/story/event#beforeEvent> rdf:type owl:ObjectProperty ,
                                                       owl:TransitiveProperty ;
                                              rdfs:domain <https://example.org/story/event#Event> ;
                                              rdfs:range <https://example.org/story/event#Event> ;
                                              owl:propertyChainAxiom ( <https://example.org/story/event#hasTemporalExtent>
                                                                       <https://example.org/story/time#beforeInterval>
                                                                       <https://example.org/story/event#isTemporalExtentOf>
                                                                     ) ;
                                              rdfs:comment "E1 happens entirely before E2."@en ;
                                              rdfs:label "before event"@en .


###  https://example.org/story/event#duringEvent
<https://example.org/story/event#duringEvent> rdf:type owl:ObjectProperty ,
                                                       owl:TransitiveProperty ;
                                              rdfs:domain <https://example.org/story/event#Event> ;
                                              rdfs:range <https://example.org/story/event#Event> ;
                                              owl:propertyChainAxiom ( <https://example.org/story/event#hasTemporalExtent>
                                                                       <https://example.org/story/time#duringInterval>
                                                                       <https://example.org/story/event#isTemporalExtentOf>
                                                                     ) ;
                                              rdfs:comment "Event E1 occurs entirely within the time span of event E2."@en ;
                                              rdfs:label "during event"@en .


###  https://example.org/story/event#hasAgent
<https://example.org/story/event#hasAgent> rdf:type owl:ObjectProperty ;
                                           rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                           rdfs:domain <https://example.org/story/event#Event> ;
                                           rdfs:comment "The active performer of the event."@en ;
                                           rdfs:label "has agent"@en .


###  https://example.org/story/event#hasCaptive
<https://example.org/story/event#hasCaptive> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                             rdfs:domain <https://example.org/story/event#Captivity> ;
                                             rdfs:comment "The character held prisoner."@en ;
                                             rdfs:label "has captive"@en .


###  https://example.org/story/event#hasCaptor
<https://example.org/story/event#hasCaptor> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                            rdfs:domain <https://example.org/story/event#Captivity> ;
                                            rdfs:comment "The character or entity holding the captive."@en ;
                                            rdfs:label "has captor"@en .


###  https://example.org/story/event#hasCombatant
<https://example.org/story/event#hasCombatant> rdf:type owl:ObjectProperty ;
                                               rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                               rdfs:domain <https://example.org/story/event#Battle> ;
                                               rdfs:comment "A character fighting in the battle."@en ;
                                               rdfs:label "has combatant"@en .


###  https://example.org/story/event#hasDeceased
<https://example.org/story/event#hasDeceased> rdf:type owl:ObjectProperty ;
                                              rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                              rdfs:domain <https://example.org/story/event#Death> ;
                                              rdfs:comment "The character who dies."@en ;
                                              rdfs:label "has deceased"@en .


###  https://example.org/story/event#hasDestination
<https://example.org/story/event#hasDestination> rdf:type owl:ObjectProperty ;
                                                 rdfs:domain <https://example.org/story/event#Journey> ;
                                                 rdfs:range <https://example.org/story/place#Place> ;
                                                 rdfs:comment "The destination place of a journey."@en ;
                                                 rdfs:label "has destination"@en .


###  https://example.org/story/event#hasFather
<https://example.org/story/event#hasFather> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                            rdfs:domain <https://example.org/story/event#Birth> ;
                                            rdfs:range :Male ;
                                            owl:propertyDisjointWith <https://example.org/story/event#hasMother> ;
                                            rdfs:comment "The father. Range fo:Male."@en ;
                                            rdfs:label "has father"@en .


###  https://example.org/story/event#hasHusband
<https://example.org/story/event#hasHusband> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                             rdfs:domain <https://example.org/story/event#Marriage> ;
                                             rdfs:range :Male ;
                                             owl:propertyDisjointWith <https://example.org/story/event#hasWife> ;
                                             rdfs:comment "The husband in the marriage."@en ;
                                             rdfs:label "has husband"@en .


###  https://example.org/story/event#hasKiller
<https://example.org/story/event#hasKiller> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                            rdfs:domain <https://example.org/story/event#Death> ;
                                            rdfs:comment "Who caused the death, if anyone."@en ;
                                            rdfs:label "has killer"@en .


###  https://example.org/story/event#hasLocation
<https://example.org/story/event#hasLocation> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <https://example.org/story/event#Event> ;
                                              rdfs:range <https://example.org/story/place#Place> ;
                                              rdfs:comment "The place where an event occurs."@en ;
                                              rdfs:label "has location"@en .


###  https://example.org/story/event#hasMother
<https://example.org/story/event#hasMother> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                            rdfs:domain <https://example.org/story/event#Birth> ;
                                            rdfs:range :Female ;
                                            rdfs:comment "The mother. Range fo:Female."@en ;
                                            rdfs:label "has mother"@en .


###  https://example.org/story/event#hasNewborn
<https://example.org/story/event#hasNewborn> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                             rdfs:domain <https://example.org/story/event#Birth> ;
                                             rdfs:comment "The character born."@en ;
                                             rdfs:label "has newborn"@en .


###  https://example.org/story/event#hasOfficiant
<https://example.org/story/event#hasOfficiant> rdf:type owl:ObjectProperty ;
                                               rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                               rdfs:domain <https://example.org/story/event#Marriage> ;
                                               rdfs:comment "The authority who validates the marriage (priest, king, etc.)."@en ;
                                               rdfs:label "has officiant"@en .


###  https://example.org/story/event#hasOrigin
<https://example.org/story/event#hasOrigin> rdf:type owl:ObjectProperty ;
                                            rdfs:domain <https://example.org/story/event#Journey> ;
                                            rdfs:range <https://example.org/story/place#Place> ;
                                            rdfs:comment "The starting place of a journey."@en ;
                                            rdfs:label "has origin"@en .


###  https://example.org/story/event#hasParticipant
<https://example.org/story/event#hasParticipant> rdf:type owl:ObjectProperty ;
                                                 rdfs:domain <https://example.org/story/event#Event> ;
                                                 rdfs:comment "A character involved in the event."@en ;
                                                 rdfs:label "has participant"@en .


###  https://example.org/story/event#hasPatient
<https://example.org/story/event#hasPatient> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                             rdfs:domain <https://example.org/story/event#Event> ;
                                             rdfs:comment "The character affected by the event."@en ;
                                             rdfs:label "has patient"@en .


###  https://example.org/story/event#hasResident
<https://example.org/story/event#hasResident> rdf:type owl:ObjectProperty ;
                                              rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                              rdfs:domain <https://example.org/story/event#Residence> ;
                                              rdfs:comment "The character residing at a place."@en ;
                                              rdfs:label "has resident"@en .


###  https://example.org/story/event#hasSpeaker
<https://example.org/story/event#hasSpeaker> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                             rdfs:domain <https://example.org/story/event#Conversation> ;
                                             rdfs:comment "A character who speaks during the conversation."@en ;
                                             rdfs:label "has speaker"@en .


###  https://example.org/story/event#hasSubEvent
<https://example.org/story/event#hasSubEvent> rdf:type owl:ObjectProperty ,
                                                       owl:TransitiveProperty ;
                                              rdfs:domain <https://example.org/story/event#Event> ;
                                              rdfs:range <https://example.org/story/event#Event> ;
                                              rdfs:comment "An event contains another as a sub-event. Transitive."@en ;
                                              rdfs:label "has sub-event"@en .


###  https://example.org/story/event#hasTemporalExtent
<https://example.org/story/event#hasTemporalExtent> rdf:type owl:ObjectProperty ,
                                                             owl:FunctionalProperty ;
                                                    rdfs:domain <https://example.org/story/event#Event> ;
                                                    rdfs:range <https://example.org/story/time#Interval> ;
                                                    rdfs:comment "When the event occurs (as an interval)."@en ;
                                                    rdfs:label "has temporal extent"@en .


###  https://example.org/story/event#hasTraveler
<https://example.org/story/event#hasTraveler> rdf:type owl:ObjectProperty ;
                                              rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                              rdfs:domain <https://example.org/story/event#Journey> ;
                                              rdfs:comment "A character undertaking the journey."@en ;
                                              rdfs:label "has traveler"@en .


###  https://example.org/story/event#hasVictor
<https://example.org/story/event#hasVictor> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <https://example.org/story/event#hasCombatant> ;
                                            rdfs:domain <https://example.org/story/event#Battle> ;
                                            rdfs:comment "The winning side of a battle."@en ;
                                            rdfs:label "has victor"@en .


###  https://example.org/story/event#hasWife
<https://example.org/story/event#hasWife> rdf:type owl:ObjectProperty ;
                                          rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                          rdfs:domain <https://example.org/story/event#Marriage> ;
                                          rdfs:range :Female ;
                                          rdfs:comment "The wife in the marriage."@en ;
                                          rdfs:label "has wife"@en .


###  https://example.org/story/event#isTemporalExtentOf
<https://example.org/story/event#isTemporalExtentOf> rdf:type owl:ObjectProperty ;
                                                     owl:inverseOf <https://example.org/story/event#hasTemporalExtent> ;
                                                     rdfs:comment "Inverse of hasTemporalExtent."@en ;
                                                     rdfs:label "is temporal extent of"@en .


###  https://example.org/story/event#killed
<https://example.org/story/event#killed> rdf:type owl:ObjectProperty ;
                                         owl:propertyChainAxiom ( [ owl:inverseOf <https://example.org/story/event#hasKiller>
                                                                  ]
                                                                  <https://example.org/story/event#hasDeceased>
                                                                ) ;
                                         rdfs:comment "X killed Y. Inferred from Death events via hasKiller and hasDeceased."@en ;
                                         rdfs:label "killed"@en .


###  https://example.org/story/event#meetsEvent
<https://example.org/story/event#meetsEvent> rdf:type owl:ObjectProperty ;
                                             rdfs:domain <https://example.org/story/event#Event> ;
                                             rdfs:range <https://example.org/story/event#Event> ;
                                             owl:propertyChainAxiom ( <https://example.org/story/event#hasTemporalExtent>
                                                                      <https://example.org/story/time#meetsInterval>
                                                                      <https://example.org/story/event#isTemporalExtentOf>
                                                                    ) ;
                                             rdfs:comment "Event E1 ends exactly when event E2 starts."@en ;
                                             rdfs:label "meets event"@en .


###  https://example.org/story/event#overlapsEvent
<https://example.org/story/event#overlapsEvent> rdf:type owl:ObjectProperty ;
                                                rdfs:domain <https://example.org/story/event#Event> ;
                                                rdfs:range <https://example.org/story/event#Event> ;
                                                owl:propertyChainAxiom ( <https://example.org/story/event#hasTemporalExtent>
                                                                         <https://example.org/story/time#overlapsInterval>
                                                                         <https://example.org/story/event#isTemporalExtentOf>
                                                                       ) ;
                                                rdfs:comment "Event E1 starts before and partially overlaps event E2."@en ;
                                                rdfs:label "overlaps event"@en .


###  https://example.org/story/event#partOfEvent
<https://example.org/story/event#partOfEvent> rdf:type owl:ObjectProperty ;
                                              owl:inverseOf <https://example.org/story/event#hasSubEvent> ;
                                              rdf:type owl:TransitiveProperty ;
                                              rdfs:comment "Inverse of hasSubEvent."@en ;
                                              rdfs:label "part of event"@en .


###  https://example.org/story/event#participatesIn
<https://example.org/story/event#participatesIn> rdf:type owl:ObjectProperty ;
                                                 owl:inverseOf <https://example.org/story/event#hasParticipant> ;
                                                 rdfs:comment "Inverse of hasParticipant."@en ;
                                                 rdfs:label "participates in"@en .


###  https://example.org/story/event#usesItem
<https://example.org/story/event#usesItem> rdf:type owl:ObjectProperty ;
                                           rdfs:domain <https://example.org/story/event#Event> ;
                                           rdfs:range <https://example.org/story/event#Item> ;
                                           rdfs:comment "An item used in the event."@en ;
                                           rdfs:label "uses item"@en .


###  https://example.org/story/place#adjacentTo
<https://example.org/story/place#adjacentTo> rdf:type owl:ObjectProperty ,
                                                      owl:SymmetricProperty ,
                                                      owl:IrreflexiveProperty ;
                                             rdfs:domain <https://example.org/story/place#Place> ;
                                             rdfs:range <https://example.org/story/place#Place> ;
                                             rdfs:comment "Two places that share a boundary or are next to each other."@en ;
                                             rdfs:label "adjacent to"@en .


###  https://example.org/story/place#hasCapital
<https://example.org/story/place#hasCapital> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <https://example.org/story/place#isCapitalOf> ;
                                             rdfs:comment "Inverse of isCapitalOf."@en ;
                                             rdfs:label "has capital"@en .


###  https://example.org/story/place#hasPart
<https://example.org/story/place#hasPart> rdf:type owl:ObjectProperty ;
                                          owl:inverseOf <https://example.org/story/place#partOf> ;
                                          rdfs:comment "Inverse of partOf."@en ;
                                          rdfs:label "has part"@en .


###  https://example.org/story/place#interiorPartOf
<https://example.org/story/place#interiorPartOf> rdf:type owl:ObjectProperty ;
                                                 rdfs:subPropertyOf <https://example.org/story/place#partOf> ;
                                                 rdf:type owl:TransitiveProperty ;
                                                 rdfs:domain <https://example.org/story/place#Place> ;
                                                 rdfs:range <https://example.org/story/place#Place> ;
