                                                   owl:propertyChainAxiom ( [ owl:inverseOf <https://example.org/story/event#hasRecognizer>
                                                                            ]
                                                                            <https://example.org/story/event#hasRecognizedCharacter>
                                                                          ) ,
                                                                          ( [ owl:inverseOf <https://example.org/story/social#hasKnower>
