                                                            <https://purl.org/region/rcc8/eq>
                                                          ) ,
                                                          ( [ owl:inverseOf <https://example.org/story/place#occupiesRegion>
                                                            ]
                                                            <https://example.org/story/place#tangentialPartOf>
                                                            <https://example.org/story/place#occupiesRegion>
                                                          ) ;
                                   rdfs:comment "First region is inside the second and their boundaries touch."@en ;
                                   rdfs:label "tangential proper part"@en .


###  https://purl.org/region/rcc8/tppi
<https://purl.org/region/rcc8/tppi> rdf:type owl:ObjectProperty ;
                                    owl:inverseOf <https://purl.org/region/rcc8/tpp> ;
                                    rdf:type owl:TransitiveProperty ;
