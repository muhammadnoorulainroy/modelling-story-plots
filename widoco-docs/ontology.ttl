@prefix : <http://purl.org/family/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://purl.org/family/> .

<http://purl.org/family/> rdf:type owl:Ontology ;
                           <http://purl.org/dc/terms/created> "2023-11-19T07:42:42+01:00"^^xsd:dateTime ,
                                                              "2023-11-19T14:42:42+01:00"^^xsd:dateTime ,
                                                              "2026-03-28T00:00:00+00:00"^^xsd:dateTime ;
                           <http://purl.org/dc/terms/creator> <https://w3id.org/people/az/me> ;
                           <http://purl.org/dc/terms/modified> "2026-01-23T13:42:42+01:00"^^xsd:dateTime ;
                           <http://purl.org/dc/terms/title> "Action Ontology"@en ,
                                                            "Event Ontology"@en ,
                                                            "Place Ontology"@en ,
                                                            "Plot Structure Ontology"@en ,
                                                            "Region Connection Calculus (RCC8) Ontology"@en ,
                                                            "Social Relations Ontology"@en ,
                                                            "The Family Ontology"@en ,
                                                            "The Middle-earth ontology"@en ,
                                                            "Time Ontology"@en ;
                           rdfs:comment "Actions as a subclass of events, defined by having an intentional agent."@en ,
                                        "An ontology for J.R.R. Tolkienʼs legendarium."@en ,
                                        "An ontology for family relationships."@en ,
                                        "Events in story plots: occurrences involving characters, places, and time. Includes an event hierarchy, participant roles, and temporal relations."@en ,
                                        "Instants, intervals, and Allen's 13 temporal relations."@en ,
                                        "Narrative and literary structure of stories, with a real-world layer (authors, books) and a fictional layer (sections, plot events)."@en ,
                                        "Non-familial social relations between characters: friendship, enmity, alliance, service, etc."@en ,
                                        "Place categories and spatial relations for story plots."@en ,
                                        "RCC8 spatial relations between regions, encoded with DL-safe OWL axioms."@en ;
                           rdfs:label "Action Ontology"@en ,
                                      "Event Ontology"@en ,
                                      "Place Ontology"@en ,
                                      "Plot Structure Ontology"@en ,
                                      "Social Relations Ontology"@en ,
                                      "The Middle-earth ontology"@en ,
                                      "The RCC8 ontology"@en ,
                                      "The family ontology"@en ,
                                      "Time Ontology"@en ;
                           owl:versionInfo "1.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
<http://purl.org/dc/terms/modified> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
<http://www.w3.org/2004/02/skos/core#altLabel> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://purl.org/family/hasChildInLaw
:hasChildInLaw rdf:type owl:ObjectProperty ;
               owl:inverseOf :hasParentInLaw ;
               rdfs:comment "Inverse of hasParentInLaw."@en ;
               rdfs:label "has child-in-law"@en .


###  http://purl.org/family/hasParentInLaw
:hasParentInLaw rdf:type owl:ObjectProperty ;
                owl:propertyChainAxiom ( :isMarriedTo
                                         :isAChildOf
                                       ) ;
                rdfs:comment "Inferred: if X isMarriedTo Y and Y isAChildOf Z, then X hasParentInLaw Z."@en ;
                rdfs:label "has parent-in-law"@en .


###  http://purl.org/family/hasRelative
:hasRelative rdf:type owl:ObjectProperty ,
                      owl:SymmetricProperty ;
             rdfs:comment "Top-level family relatedness. Super-property of all family relations."@en ;
             rdfs:label "has relative"@en .


###  http://purl.org/family/hasSiblingInLaw
:hasSiblingInLaw rdf:type owl:ObjectProperty ;
                 owl:propertyChainAxiom ( :isMarriedTo
                                          :isASiblingOf
                                        ) ;
                 rdfs:comment "Inferred: if X isMarriedTo Y and Y isASiblingOf Z, then X hasSiblingInLaw Z."@en ;
                 rdfs:label "has sibling-in-law"@en .


###  http://purl.org/family/isABrotherOf
:isABrotherOf rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :isASiblingOf ;
              rdf:type owl:IrreflexiveProperty ;
              rdfs:domain :Male ;
              rdfs:comment "A male sibling of someone. Irreflexive: nobody is their own brother."@en ;
              rdfs:label "is a brother of"@en .


###  http://purl.org/family/isAChildOf
:isAChildOf rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :isADescendentOf ;
            owl:inverseOf :isAParentOf ;
            owl:propertyChainAxiom ( [ owl:inverseOf <https://example.org/story/event#hasNewborn>
                                     ]
                                     <https://example.org/story/event#hasFather>
                                   ) ,
                                   ( [ owl:inverseOf <https://example.org/story/event#hasNewborn>
                                     ]
                                     <https://example.org/story/event#hasMother>
                                   ) ;
            rdfs:comment "A relation between someone and their parent"@en ;
            rdfs:label "is a child of"@en .


###  http://purl.org/family/isACousinOf
:isACousinOf rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :hasRelative ;
             rdf:type owl:SymmetricProperty ;
             owl:propertyChainAxiom ( :isAChildOf
                                      :isASiblingOf
                                      :isAParentOf
                                    ) ;
             rdfs:comment "One that is the child of a sibling of the parent of someone else."@en ;
             rdfs:label "is a cousin of"@en .


###  http://purl.org/family/isADaughterOf
:isADaughterOf rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :isAChildOf ;
               rdfs:domain :Female ;
               rdfs:comment "A relation between a female child and her parent. Asymmetric and irreflexive."@en ;
               rdfs:label "is a daughter of"@en .


###  http://purl.org/family/isADescendentOf
:isADescendentOf rdf:type owl:ObjectProperty ,
                          owl:TransitiveProperty ;
                 rdfs:comment "A relation between someone and one of their ancestors."@en ;
                 rdfs:label "is a descendent of"@en .


###  http://purl.org/family/isAGrandchildOf
:isAGrandchildOf rdf:type owl:ObjectProperty ;
                 owl:inverseOf :isAGrandparentOf ;
                 rdfs:comment "Grandchild: inverse of grandparent."@en ;
                 rdfs:label "is a grandchild of"@en .


###  http://purl.org/family/isAGrandparentOf
:isAGrandparentOf rdf:type owl:ObjectProperty ;
                  owl:propertyChainAxiom ( :isAParentOf
                                           :isAParentOf
                                         ) ;
                  rdfs:comment "Grandparent: parent of a parent. Inferred via chain."@en ;
                  rdfs:label "is a grandparent of"@en .


###  http://purl.org/family/isANephewOrNieceOf
:isANephewOrNieceOf rdf:type owl:ObjectProperty ;
                    owl:inverseOf :isAnUncleOrAuntOf ;
                    rdfs:comment "Child of a sibling. Inverse of uncle/aunt."@en ;
                    rdfs:label "is a nephew or niece of"@en .


###  http://purl.org/family/isAParentOf
:isAParentOf rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :hasRelative ,
                                :isAnAncestorOf ;
             rdfs:comment "A relation between a parent and their child. Asymmetric (your child is not your parent) and irreflexive (nobody is their own parent)."@en ;
             rdfs:label "is a parent of"@en .


###  http://purl.org/family/isASiblingOf
:isASiblingOf rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :hasRelative ;
              rdf:type owl:SymmetricProperty ,
                       owl:IrreflexiveProperty ;
              rdfs:comment "Two individuals who share the same parent."@en ;
              rdfs:label "is a sibling of"@en .


###  http://purl.org/family/isASisterOf
:isASisterOf rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :isASiblingOf ;
             rdf:type owl:IrreflexiveProperty ;
             rdfs:domain :Female ;
             rdfs:comment "A female sibling of someone. Irreflexive: nobody is their own sister."@en ;
             rdfs:label "is a sister of"@en .


###  http://purl.org/family/isASonOf
:isASonOf rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :isAChildOf ;
          rdfs:domain :Male ;
          rdfs:comment "A relation between a male child and his parent. Asymmetric and irreflexive."@en ;
          rdfs:label "is a son of"@en .


###  http://purl.org/family/isAnAncestorOf
:isAnAncestorOf rdf:type owl:ObjectProperty ;
                owl:inverseOf :isADescendentOf ;
                rdf:type owl:TransitiveProperty ;
                rdfs:comment "A relation between someone and one their of descendants."@en ;
                rdfs:label "is an ancestor of"@en .


###  http://purl.org/family/isAnAuntOf
:isAnAuntOf rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :isAnUncleOrAuntOf ;
            rdfs:domain :Female ;
            owl:propertyChainAxiom ( :isASisterOf
                                     :isAParentOf
                                   ) ;
            rdfs:comment "A female sibling of a parent."@en ;
            rdfs:label "is an aunt of"@en .


###  http://purl.org/family/isAnUncleOf
:isAnUncleOf rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :isAnUncleOrAuntOf ;
             rdfs:domain :Male ;
             owl:propertyChainAxiom ( :isABrotherOf
                                      :isAParentOf
                                    ) ;
             rdfs:comment "A male sibling of a parent."@en ;
             rdfs:label "is an uncle of"@en .


###  http://purl.org/family/isAnUncleOrAuntOf
:isAnUncleOrAuntOf rdf:type owl:ObjectProperty ;
                   owl:propertyChainAxiom ( :isASiblingOf
                                            :isAParentOf
                                          ) ,
                                          ( :isMarriedTo
                                            :isASiblingOf
                                            :isAParentOf
                                          ) ;
                   rdfs:comment "Sibling of a parent. Inferred via chain."@en ;
                   rdfs:label "is an uncle or aunt of"@en .


###  http://purl.org/family/isMarriedTo
:isMarriedTo rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :hasRelative ;
             rdf:type owl:SymmetricProperty ;
             owl:propertyChainAxiom ( [ owl:inverseOf <https://example.org/story/event#hasHusband>
                                      ]
                                      <https://example.org/story/event#hasWife>
                                    ) ;
             rdfs:comment "People united through marriage. Functional enforces monogamy: each individual can have at most one spouse. Combined with SymmetricProperty, this also makes the inverse functional (if two people are married to the same person, they must be the same person)."@en ;
             rdfs:label "is married to"@en .


###  http://purl.org/family/isTheFatherOf
:isTheFatherOf rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :isAParentOf ;
               rdfs:domain :Male ;
               rdfs:comment "A relation between a father and his child. Asymmetric (a child is not its father's father) and irreflexive (nobody is their own father)."@en ;
               rdfs:label "is the father of"@en .


###  http://purl.org/family/isTheMotherOf
:isTheMotherOf rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :isAParentOf ;
               rdfs:domain :Female ;
               rdfs:comment "A relation between a mother and her child. Asymmetric and irreflexive."@en ;
               rdfs:label "is the mother of"@en .


###  http://purl.org/meo/served
<http://purl.org/meo/served> rdf:type owl:ObjectProperty ;
                             owl:equivalentProperty <https://example.org/story/social#serves> ;
                             rdfs:comment "Relates someone to someone else that they serve. Relation servant-master."@en ;
                             rdfs:label "serves"@en .


###  https://example.org/story/action#hasAgent
<https://example.org/story/action#hasAgent> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <https://example.org/story/event#hasAgent> ;
                                            rdfs:comment "Who deliberately performs the action. Sub-property of evt:hasAgent."@en ;
                                            rdfs:label "has agent"@en .


###  https://example.org/story/action#hasPatient
<https://example.org/story/action#hasPatient> rdf:type owl:ObjectProperty ;
                                              rdfs:subPropertyOf <https://example.org/story/event#hasPatient> ;
                                              rdfs:domain <https://example.org/story/action#Action> ;
                                              rdfs:comment "Who is affected by the action."@en ;
                                              rdfs:label "has patient"@en .


###  https://example.org/story/action#resultsIn
<https://example.org/story/action#resultsIn> rdf:type owl:ObjectProperty ;
                                             rdfs:domain <https://example.org/story/action#Action> ;
                                             rdfs:range <https://example.org/story/event#Event> ;
                                             rdfs:comment "What happens as a consequence of the action, e.g. an attack results in a death."@en ;
                                             rdfs:label "results in"@en .


###  https://example.org/story/event#afterEvent
<https://example.org/story/event#afterEvent> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <https://example.org/story/event#beforeEvent> ;
                                             rdf:type owl:TransitiveProperty ;
                                             owl:propertyChainAxiom ( <https://example.org/story/event#hasTemporalExtent>
                                                                      <https://example.org/story/time#afterInterval>
                                                                      <https://example.org/story/event#isTemporalExtentOf>
                                                                    ) ;
                                             rdfs:comment "Inverse of beforeEvent."@en ;
                                             rdfs:label "after event"@en .


###  https://example.org/story/event#beforeEvent
<https://example.org/story/event#beforeEvent> rdf:type owl:ObjectProperty ,
                                                       owl:TransitiveProperty ;
                                              rdfs:domain <https://example.org/story/event#Event> ;
                                              rdfs:range <https://example.org/story/event#Event> ;
                                              owl:propertyChainAxiom ( <https://example.org/story/event#hasNewborn>
                                                                       [ owl:inverseOf <https://example.org/story/event#hasDeceased>
                                                                       ]
                                                                     ) ,
                                                                     ( <https://example.org/story/event#hasTemporalExtent>
                                                                       <https://example.org/story/time#beforeInterval>
                                                                       <https://example.org/story/event#isTemporalExtentOf>
                                                                     ) ;
                                              rdfs:comment "E1 happens entirely before E2."@en ;
                                              rdfs:label "before event"@en .


###  https://example.org/story/event#duringEvent
<https://example.org/story/event#duringEvent> rdf:type owl:ObjectProperty ,
                                                       owl:TransitiveProperty ;
                                              rdfs:domain <https://example.org/story/event#Event> ;
                                              rdfs:range <https://example.org/story/event#Event> ;
                                              owl:propertyChainAxiom ( <https://example.org/story/event#hasTemporalExtent>
                                                                       <https://example.org/story/time#duringInterval>
                                                                       <https://example.org/story/event#isTemporalExtentOf>
                                                                     ) ;
                                              rdfs:comment "Event E1 occurs entirely within the time span of event E2."@en ;
                                              rdfs:label "during event"@en .


###  https://example.org/story/event#foughtInBattle
<https://example.org/story/event#foughtInBattle> rdf:type owl:ObjectProperty ;
                                                 rdfs:range <https://example.org/story/event#Battle> ;
                                                 owl:propertyChainAxiom ( <https://example.org/story/event#memberOfFaction>
                                                                          [ owl:inverseOf <https://example.org/story/event#hasCombatant>
                                                                          ]
                                                                        ) ;
                                                 rdfs:comment "A character or creature fought in a battle as a member of one of its factions. Inferred from memberOfFaction and hasCombatant."@en ;
                                                 rdfs:label "fought in battle"@en .


###  https://example.org/story/event#hasAgent
<https://example.org/story/event#hasAgent> rdf:type owl:ObjectProperty ;
                                           rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                           rdf:type owl:IrreflexiveProperty ;
                                           rdfs:domain <https://example.org/story/event#Event> ;
                                           owl:propertyDisjointWith <https://example.org/story/event#hasPatient> ;
                                           rdfs:comment "The active performer of the event."@en ;
                                           rdfs:label "has agent"@en .


###  https://example.org/story/event#hasCaptive
<https://example.org/story/event#hasCaptive> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <https://example.org/story/event#hasPresentEntity> ;
                                             rdf:type owl:IrreflexiveProperty ;
                                             rdfs:domain <https://example.org/story/event#Captivity> ;
                                             owl:propertyDisjointWith <https://example.org/story/event#hasCaptor> ;
                                             rdfs:comment "The character held prisoner."@en ;
                                             rdfs:label "has captive"@en .


###  https://example.org/story/event#hasCaptor
<https://example.org/story/event#hasCaptor> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                            rdf:type owl:IrreflexiveProperty ;
                                            rdfs:domain <https://example.org/story/event#Captivity> ;
                                            owl:propertyDisjointWith <https://example.org/story/event#hasResident> ;
                                            rdfs:comment "The character or entity holding the captive."@en ;
                                            rdfs:label "has captor"@en .


###  https://example.org/story/event#hasCombatant
<https://example.org/story/event#hasCombatant> rdf:type owl:ObjectProperty ;
                                               rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                               rdf:type owl:IrreflexiveProperty ;
                                               rdfs:domain <https://example.org/story/event#Battle> ;
                                               rdfs:comment "A combatant side or individual fighting in the battle."@en ;
                                               rdfs:label "has combatant"@en .


###  https://example.org/story/event#hasCrownedEntity
<https://example.org/story/event#hasCrownedEntity> rdf:type owl:ObjectProperty ;
                                                   rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                                   rdf:type owl:IrreflexiveProperty ;
                                                   rdfs:domain <https://example.org/story/event#Coronation> ;
                                                   owl:propertyDisjointWith <https://example.org/story/event#hasCrowner> ;
                                                   rdfs:comment "The character being crowned or given authority."@en ;
                                                   rdfs:label "has crowned entity"@en .


###  https://example.org/story/event#hasCrowner
<https://example.org/story/event#hasCrowner> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <https://example.org/story/event#hasAgent> ,
                                                                <https://example.org/story/event#hasParticipant> ;
                                             rdf:type owl:IrreflexiveProperty ;
                                             rdfs:domain <https://example.org/story/event#Coronation> ;
                                             rdfs:comment "The authority performing the coronation. Sub-property of hasAgent."@en ;
                                             rdfs:label "has crowner"@en .


###  https://example.org/story/event#hasDeceased
<https://example.org/story/event#hasDeceased> rdf:type owl:ObjectProperty ;
                                              rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                              rdf:type owl:IrreflexiveProperty ;
                                              rdfs:domain <https://example.org/story/event#Death> ;
                                              rdfs:comment "The character who dies."@en ;
                                              rdfs:label "has deceased"@en .


###  https://example.org/story/event#hasDestination
<https://example.org/story/event#hasDestination> rdf:type owl:ObjectProperty ,
                                                          owl:IrreflexiveProperty ;
                                                 rdfs:domain <https://example.org/story/event#Journey> ;
                                                 rdfs:range <https://example.org/story/place#Place> ;
                                                 owl:propertyDisjointWith <https://example.org/story/event#hasOrigin> ;
                                                 rdfs:comment "The destination place of a journey."@en ;
                                                 rdfs:label "has destination"@en .


###  https://example.org/story/event#hasFather
<https://example.org/story/event#hasFather> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                            rdf:type owl:AsymmetricProperty ,
                                                     owl:IrreflexiveProperty ;
                                            rdfs:domain <https://example.org/story/event#Birth> ;
                                            rdfs:range :Male ;
                                            owl:propertyDisjointWith <https://example.org/story/event#hasMother> ,
                                                                     <https://example.org/story/event#hasNewborn> ;
                                            rdfs:comment "The father. Range fo:Male."@en ;
                                            rdfs:label "has father"@en .


###  https://example.org/story/event#hasHusband
<https://example.org/story/event#hasHusband> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                             rdf:type owl:IrreflexiveProperty ;
                                             rdfs:domain <https://example.org/story/event#Marriage> ;
                                             rdfs:range :Male ;
                                             owl:propertyDisjointWith <https://example.org/story/event#hasOfficiant> ,
                                                                      <https://example.org/story/event#hasWife> ;
                                             rdfs:comment "The husband in the marriage."@en ;
                                             rdfs:label "has husband"@en .


###  https://example.org/story/event#hasKiller
<https://example.org/story/event#hasKiller> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                            rdf:type owl:IrreflexiveProperty ;
                                            rdfs:domain <https://example.org/story/event#Death> ;
                                            rdfs:comment "Who caused the death, if anyone."@en ;
                                            rdfs:label "has killer"@en .


###  https://example.org/story/event#hasLocation
<https://example.org/story/event#hasLocation> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <https://example.org/story/event#Event> ;
                                              rdfs:range <https://example.org/story/place#Place> ;
                                              rdfs:comment "The place where an event occurs."@en ;
                                              rdfs:label "has location"@en .


###  https://example.org/story/event#hasMember
<https://example.org/story/event#hasMember> rdf:type owl:ObjectProperty ;
                                            rdfs:domain <https://example.org/story/event#Faction> ;
                                            rdfs:comment "A character or creature that belongs to a faction."@en ;
                                            rdfs:label "has member"@en .


###  https://example.org/story/event#hasMother
<https://example.org/story/event#hasMother> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                            rdf:type owl:AsymmetricProperty ,
                                                     owl:IrreflexiveProperty ;
                                            rdfs:domain <https://example.org/story/event#Birth> ;
                                            rdfs:range :Female ;
                                            owl:propertyDisjointWith <https://example.org/story/event#hasNewborn> ;
                                            rdfs:comment "The mother. Range fo:Female."@en ;
                                            rdfs:label "has mother"@en .


###  https://example.org/story/event#hasNewborn
<https://example.org/story/event#hasNewborn> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                             rdf:type owl:AsymmetricProperty ,
                                                      owl:IrreflexiveProperty ;
                                             rdfs:domain <https://example.org/story/event#Birth> ;
                                             rdfs:comment "The character born."@en ;
                                             rdfs:label "has newborn"@en .


###  https://example.org/story/event#hasOfficiant
<https://example.org/story/event#hasOfficiant> rdf:type owl:ObjectProperty ;
                                               rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                               rdf:type owl:IrreflexiveProperty ;
                                               rdfs:domain <https://example.org/story/event#Marriage> ;
                                               owl:propertyDisjointWith <https://example.org/story/event#hasWife> ;
                                               rdfs:comment "The authority who validates the marriage (priest, king, etc.)."@en ;
                                               rdfs:label "has officiant"@en .


###  https://example.org/story/event#hasOrigin
<https://example.org/story/event#hasOrigin> rdf:type owl:ObjectProperty ,
                                                     owl:IrreflexiveProperty ;
                                            rdfs:domain <https://example.org/story/event#Journey> ;
                                            rdfs:range <https://example.org/story/place#Place> ;
                                            rdfs:comment "The starting place of a journey."@en ;
                                            rdfs:label "has origin"@en .


###  https://example.org/story/event#hasParticipant
<https://example.org/story/event#hasParticipant> rdf:type owl:ObjectProperty ;
                                                 rdfs:domain <https://example.org/story/event#Event> ;
                                                 rdfs:comment "A character or collective actor involved in the event."@en ;
                                                 rdfs:label "has participant"@en .


###  https://example.org/story/event#hasPatient
<https://example.org/story/event#hasPatient> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                             rdf:type owl:IrreflexiveProperty ;
                                             rdfs:domain <https://example.org/story/event#Event> ;
                                             rdfs:comment "The character affected by the event."@en ;
                                             rdfs:label "has patient"@en .


###  https://example.org/story/event#hasPresentEntity
<https://example.org/story/event#hasPresentEntity> rdf:type owl:ObjectProperty ;
                                                   rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                                   rdf:type owl:IrreflexiveProperty ;
                                                   rdfs:domain <https://example.org/story/event#Presence> ;
                                                   rdfs:comment "An entity explicitly present in a place during a Presence state."@en ;
                                                   rdfs:label "has present entity"@en .


###  https://example.org/story/event#hasRecognizedCharacter
<https://example.org/story/event#hasRecognizedCharacter> rdf:type owl:ObjectProperty ;
                                                         rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                                         rdf:type owl:IrreflexiveProperty ;
                                                         rdfs:domain <https://example.org/story/event#Recognition> ;
                                                         owl:propertyDisjointWith <https://example.org/story/event#hasRecognizer> ;
                                                         rdfs:comment "The character whose identity is recognized in the Recognition event."@en ;
                                                         rdfs:label "has recognized character"@en .


###  https://example.org/story/event#hasRecognizer
<https://example.org/story/event#hasRecognizer> rdf:type owl:ObjectProperty ;
                                                rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                                rdf:type owl:IrreflexiveProperty ;
                                                rdfs:domain <https://example.org/story/event#Recognition> ;
                                                rdfs:comment "The individual who recognizes or identifies someone in the Recognition event."@en ;
                                                rdfs:label "has recognizer"@en .


###  https://example.org/story/event#hasResident
<https://example.org/story/event#hasResident> rdf:type owl:ObjectProperty ;
                                              rdfs:subPropertyOf <https://example.org/story/event#hasPresentEntity> ;
                                              rdf:type owl:IrreflexiveProperty ;
                                              rdfs:domain <https://example.org/story/event#Residence> ;
                                              rdfs:comment "The character residing at a place."@en ;
                                              rdfs:label "has resident"@en .


###  https://example.org/story/event#hasRuler
<https://example.org/story/event#hasRuler> rdf:type owl:ObjectProperty ;
                                           rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                           rdf:type owl:IrreflexiveProperty ;
                                           rdfs:domain <https://example.org/story/event#Reign> ;
                                           rdfs:comment "The ruler whose reign is being described."@en ;
                                           rdfs:label "has ruler"@en .


###  https://example.org/story/event#hasSpeaker
<https://example.org/story/event#hasSpeaker> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <https://example.org/story/event#hasAgent> ,
                                                                <https://example.org/story/event#hasParticipant> ;
                                             rdf:type owl:IrreflexiveProperty ;
                                             rdfs:domain <https://example.org/story/event#Conversation> ;
                                             rdfs:comment "A character who speaks during the conversation. Sub-property of hasAgent because speaking is intentional."@en ;
                                             rdfs:label "has speaker"@en .


###  https://example.org/story/event#hasSubEvent
<https://example.org/story/event#hasSubEvent> rdf:type owl:ObjectProperty ,
                                                       owl:TransitiveProperty ;
                                              rdfs:domain <https://example.org/story/event#Event> ;
                                              rdfs:range <https://example.org/story/event#Event> ;
                                              rdfs:comment "An event contains another as a sub-event. Transitive."@en ;
                                              rdfs:label "has sub-event"@en .


###  https://example.org/story/event#hasTemporalExtent
<https://example.org/story/event#hasTemporalExtent> rdf:type owl:ObjectProperty ,
                                                             owl:FunctionalProperty ;
                                                    rdfs:domain <https://example.org/story/event#Event> ;
                                                    rdfs:range <https://example.org/story/time#Interval> ;
                                                    rdfs:comment "When the event occurs (as an interval)."@en ;
                                                    rdfs:label "has temporal extent"@en .


###  https://example.org/story/event#hasTraveler
<https://example.org/story/event#hasTraveler> rdf:type owl:ObjectProperty ;
                                              rdfs:subPropertyOf <https://example.org/story/event#hasAgent> ,
                                                                 <https://example.org/story/event#hasParticipant> ;
                                              rdf:type owl:IrreflexiveProperty ;
                                              rdfs:domain <https://example.org/story/event#Journey> ;
                                              rdfs:comment "A character or group undertaking the journey. Also sub-property of hasAgent because travel is intentional, so every Journey with a traveler is automatically classified as an Action."@en ;
                                              rdfs:label "has traveler"@en .


###  https://example.org/story/event#hasVictor
<https://example.org/story/event#hasVictor> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <https://example.org/story/event#hasCombatant> ;
                                            rdf:type owl:IrreflexiveProperty ;
                                            rdfs:domain <https://example.org/story/event#Battle> ;
                                            rdfs:comment "The winning side of a battle."@en ;
                                            rdfs:label "has victor"@en .


###  https://example.org/story/event#hasWife
<https://example.org/story/event#hasWife> rdf:type owl:ObjectProperty ;
                                          rdfs:subPropertyOf <https://example.org/story/event#hasParticipant> ;
                                          rdf:type owl:IrreflexiveProperty ;
                                          rdfs:domain <https://example.org/story/event#Marriage> ;
                                          rdfs:range :Female ;
                                          rdfs:comment "The wife in the marriage."@en ;
                                          rdfs:label "has wife"@en .


###  https://example.org/story/event#involvesFactionMember
<https://example.org/story/event#involvesFactionMember> rdf:type owl:ObjectProperty ;
                                                        rdfs:domain <https://example.org/story/event#Battle> ;
                                                        owl:propertyChainAxiom ( <https://example.org/story/event#hasCombatant>
                                                                                 <https://example.org/story/event#hasMember>
                                                                               ) ;
                                                        rdfs:comment "A battle involves a member of one of its combatant factions. Inferred from hasCombatant and hasMember."@en ;
                                                        rdfs:label "involves faction member"@en .


###  https://example.org/story/event#isTemporalExtentOf
<https://example.org/story/event#isTemporalExtentOf> rdf:type owl:ObjectProperty ;
                                                     owl:inverseOf <https://example.org/story/event#hasTemporalExtent> ;
                                                     rdfs:comment "Inverse of hasTemporalExtent."@en ;
                                                     rdfs:label "is temporal extent of"@en .


###  https://example.org/story/event#killed
<https://example.org/story/event#killed> rdf:type owl:ObjectProperty ;
                                         owl:propertyChainAxiom ( [ owl:inverseOf <https://example.org/story/action#hasAgent>
                                                                  ]
                                                                  <https://example.org/story/action#resultsIn>
                                                                  <https://example.org/story/event#hasDeceased>
                                                                ) ,
                                                                ( [ owl:inverseOf <https://example.org/story/event#hasKiller>
                                                                  ]
                                                                  <https://example.org/story/event#hasDeceased>
                                                                ) ;
                                         rdfs:comment "X killed Y. Inferred from Death events via hasKiller and hasDeceased."@en ;
                                         rdfs:label "killed"@en .


###  https://example.org/story/event#meetsEvent
<https://example.org/story/event#meetsEvent> rdf:type owl:ObjectProperty ;
                                             rdfs:domain <https://example.org/story/event#Event> ;
                                             rdfs:range <https://example.org/story/event#Event> ;
                                             owl:propertyChainAxiom ( <https://example.org/story/event#hasTemporalExtent>
                                                                      <https://example.org/story/time#meetsInterval>
                                                                      <https://example.org/story/event#isTemporalExtentOf>
                                                                    ) ;
                                             rdfs:comment "Event E1 ends exactly when event E2 starts."@en ;
                                             rdfs:label "meets event"@en .


###  https://example.org/story/event#memberOfFaction
<https://example.org/story/event#memberOfFaction> rdf:type owl:ObjectProperty ;
                                                  owl:inverseOf <https://example.org/story/event#hasMember> ;
                                                  rdfs:comment "Inverse of hasMember."@en ;
                                                  rdfs:label "member of faction"@en .


###  https://example.org/story/event#overlapsEvent
<https://example.org/story/event#overlapsEvent> rdf:type owl:ObjectProperty ;
                                                rdfs:domain <https://example.org/story/event#Event> ;
                                                rdfs:range <https://example.org/story/event#Event> ;
                                                owl:propertyChainAxiom ( <https://example.org/story/event#hasTemporalExtent>
                                                                         <https://example.org/story/time#overlapsInterval>
                                                                         <https://example.org/story/event#isTemporalExtentOf>
                                                                       ) ;
                                                rdfs:comment "Event E1 starts before and partially overlaps event E2."@en ;
                                                rdfs:label "overlaps event"@en .


###  https://example.org/story/event#partOfEvent
<https://example.org/story/event#partOfEvent> rdf:type owl:ObjectProperty ;
                                              owl:inverseOf <https://example.org/story/event#hasSubEvent> ;
                                              rdf:type owl:TransitiveProperty ;
                                              rdfs:comment "Inverse of hasSubEvent."@en ;
                                              rdfs:label "part of event"@en .


###  https://example.org/story/event#participatesIn
<https://example.org/story/event#participatesIn> rdf:type owl:ObjectProperty ;
                                                 owl:inverseOf <https://example.org/story/event#hasParticipant> ;
                                                 rdfs:comment "Inverse of hasParticipant."@en ;
                                                 rdfs:label "participates in"@en .


###  https://example.org/story/event#recognizesAppellation
<https://example.org/story/event#recognizesAppellation> rdf:type owl:ObjectProperty ;
                                                        rdfs:domain <https://example.org/story/event#Recognition> ;
                                                        rdfs:range <https://example.org/story/social#Appellation> ;
                                                        rdfs:comment "The appellation under which a character is recognized in the Recognition event."@en ;
                                                        rdfs:label "recognizes appellation"@en .


###  https://example.org/story/event#usesItem
<https://example.org/story/event#usesItem> rdf:type owl:ObjectProperty ;
                                           rdfs:domain <https://example.org/story/event#Event> ;
                                           rdfs:range <https://example.org/story/event#Item> ;
                                           rdfs:comment "An item used in the event."@en ;
                                           rdfs:label "uses item"@en .


###  https://example.org/story/place#adjacentTo
<https://example.org/story/place#adjacentTo> rdf:type owl:ObjectProperty ,
                                                      owl:SymmetricProperty ,
                                                      owl:IrreflexiveProperty ;
                                             rdfs:domain <https://example.org/story/place#Place> ;
                                             rdfs:range <https://example.org/story/place#Place> ;
                                             rdfs:comment "Two places that share a boundary or are next to each other."@en ;
                                             rdfs:label "adjacent to"@en .


###  https://example.org/story/place#hasCapital
<https://example.org/story/place#hasCapital> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <https://example.org/story/place#isCapitalOf> ;
                                             rdfs:comment "Inverse of isCapitalOf."@en ;
                                             rdfs:label "has capital"@en .


###  https://example.org/story/place#hasPart
<https://example.org/story/place#hasPart> rdf:type owl:ObjectProperty ;
                                          owl:inverseOf <https://example.org/story/place#partOf> ;
                                          rdfs:comment "Inverse of partOf."@en ;
                                          rdfs:label "has part"@en .


###  https://example.org/story/place#interiorPartOf
<https://example.org/story/place#interiorPartOf> rdf:type owl:ObjectProperty ;
                                                 rdfs:subPropertyOf <https://example.org/story/place#partOf> ;
                                                 rdf:type owl:TransitiveProperty ;
                                                 rdfs:domain <https://example.org/story/place#Place> ;
                                                 rdfs:range <https://example.org/story/place#Place> ;
                                                 rdfs:comment "Proper part relation where the subject lies wholly inside the larger place, corresponding to RCC8 NTPP at region level."@en ;
                                                 rdfs:label "interior part of"@en .


###  https://example.org/story/place#isCapitalOf
<https://example.org/story/place#isCapitalOf> rdf:type owl:ObjectProperty ,
                                                       owl:FunctionalProperty ,
                                                       owl:InverseFunctionalProperty ,
                                                       owl:AsymmetricProperty ,
                                                       owl:IrreflexiveProperty ;
                                              rdfs:domain <https://example.org/story/place#Settlement> ;
                                              rdfs:range <https://example.org/story/place#Realm> ;
                                              rdfs:comment "The settlement is the capital of this realm. Functional and inverse-functional (one capital per realm, one realm per capital). Asymmetric and irreflexive (a realm is not the capital of itself)."@en ;
                                              rdfs:label "is capital of"@en .


###  https://example.org/story/place#occupiesRegion
<https://example.org/story/place#occupiesRegion> rdf:type owl:ObjectProperty ,
                                                          owl:FunctionalProperty ,
                                                          owl:InverseFunctionalProperty ,
                                                          owl:IrreflexiveProperty ;
                                                 rdfs:domain <https://example.org/story/place#Place> ;
                                                 rdfs:range <https://purl.org/region/rcc8/Region> ;
                                                 rdfs:comment "Links a place to its spatial region. Functional (one region per place) AND InverseFunctional (one place per region). Together these mean: if two places occupy the same region, they are the same place."@en ;
                                                 rdfs:label "occupies region"@en .


###  https://example.org/story/place#partOf
<https://example.org/story/place#partOf> rdf:type owl:ObjectProperty ,
                                                  owl:TransitiveProperty ;
                                         rdfs:domain <https://example.org/story/place#Place> ;
                                         rdfs:range <https://example.org/story/place#Place> ;
                                         owl:propertyChainAxiom ( [ owl:inverseOf <https://example.org/story/event#hasLocation>
                                                                  ]
                                                                  <https://example.org/story/event#partOfEvent>
                                                                  <https://example.org/story/event#hasLocation>
                                                                ) ;
                                         rdfs:comment "Spatial containment between places. E.g. Menegroth is part of Doriath."@en ;
                                         rdfs:label "part of"@en .


###  https://example.org/story/place#ruledBy
<https://example.org/story/place#ruledBy> rdf:type owl:ObjectProperty ;
                                          owl:inverseOf <https://example.org/story/place#rulesPlace> ;
                                          rdfs:domain <https://example.org/story/place#Place> ;
                                          rdfs:comment "Inverse of rulesPlace."@en ;
                                          rdfs:label "ruled by"@en .


###  https://example.org/story/place#rulesPlace
<https://example.org/story/place#rulesPlace> rdf:type owl:ObjectProperty ;
                                             rdfs:range <https://example.org/story/place#Place> ;
                                             owl:propertyChainAxiom ( [ owl:inverseOf <https://example.org/story/event#hasRuler>
                                                                      ]
                                                                      <https://example.org/story/event#hasLocation>
                                                                    ) ;
                                             rdfs:comment "A ruler governs a place. This can be inferred from Reign events."@en ;
                                             rdfs:label "rules place"@en .


###  https://example.org/story/place#tangentialPartOf
<https://example.org/story/place#tangentialPartOf> rdf:type owl:ObjectProperty ;
                                                   rdfs:subPropertyOf <https://example.org/story/place#partOf> ;
                                                   rdf:type owl:TransitiveProperty ;
                                                   rdfs:domain <https://example.org/story/place#Place> ;
                                                   rdfs:range <https://example.org/story/place#Place> ;
                                                   rdfs:comment "Proper part relation where the subject touches the boundary of the larger place, corresponding to RCC8 TPP at region level."@en ;
                                                   rdfs:label "tangential part of"@en .


###  https://example.org/story/plot#causallyPrecedesPlotEvent
<https://example.org/story/plot#causallyPrecedesPlotEvent> rdf:type owl:ObjectProperty ,
                                                                    owl:TransitiveProperty ;
                                                           rdfs:domain <https://example.org/story/plot#PlotEvent> ;
                                                           rdfs:range <https://example.org/story/plot#PlotEvent> ;
                                                           rdfs:comment "A plot event is causally upstream of another plot event. Transitive superproperty of leadsTo."@en ;
                                                           rdfs:label "causally precedes plot event"@en .


###  https://example.org/story/plot#containsEvent
<https://example.org/story/plot#containsEvent> rdf:type owl:ObjectProperty ;
                                               rdfs:domain <https://example.org/story/plot#StorySection> ;
                                               rdfs:range <https://example.org/story/event#Event> ;
                                               owl:propertyChainAxiom ( <https://example.org/story/plot#containsPlotEvent>
                                                                        <https://example.org/story/plot#describesEvent>
                                                                      ) ;
                                               rdfs:comment "A section contains an in-world event. Inferred from containsPlotEvent and describesEvent."@en ;
                                               rdfs:label "contains event"@en .


###  https://example.org/story/plot#containsPlotEvent
<https://example.org/story/plot#containsPlotEvent> rdf:type owl:ObjectProperty ,
                                                            owl:AsymmetricProperty ,
                                                            owl:IrreflexiveProperty ;
                                                   rdfs:domain <https://example.org/story/plot#StorySection> ;
                                                   rdfs:range <https://example.org/story/plot#PlotEvent> ;
                                                   rdfs:comment "A story section contains plot events."@en ;
                                                   rdfs:label "contains plot event"@en .


###  https://example.org/story/plot#describesEvent
<https://example.org/story/plot#describesEvent> rdf:type owl:ObjectProperty ,
                                                         owl:FunctionalProperty ,
                                                         owl:IrreflexiveProperty ;
                                                rdfs:domain <https://example.org/story/plot#PlotEvent> ;
                                                rdfs:range <https://example.org/story/event#Event> ;
                                                rdfs:comment "Links a plot event to the in-world event it describes. Irreflexive: a plot event is not the event it describes."@en ;
                                                rdfs:label "describes event"@en .


###  https://example.org/story/plot#endsWith
<https://example.org/story/plot#endsWith> rdf:type owl:ObjectProperty ,
                                                   owl:FunctionalProperty ,
                                                   owl:AsymmetricProperty ,
                                                   owl:IrreflexiveProperty ;
                                          rdfs:domain <https://example.org/story/plot#NarrativeContainer> ;
                                          rdfs:range <https://example.org/story/plot#PlotEvent> ;
                                          rdfs:comment "The last plot event in a story or section."@en ;
                                          rdfs:label "ends with"@en .


###  https://example.org/story/plot#endsWithEvent
<https://example.org/story/plot#endsWithEvent> rdf:type owl:ObjectProperty ;
                                               rdfs:domain <https://example.org/story/plot#NarrativeContainer> ;
                                               rdfs:range <https://example.org/story/event#Event> ;
                                               owl:propertyChainAxiom ( <https://example.org/story/plot#endsWith>
                                                                        <https://example.org/story/plot#describesEvent>
                                                                      ) ;
                                               rdfs:comment "The in-world event that ends a story or section. Inferred from endsWith and describesEvent."@en ;
                                               rdfs:label "ends with event"@en .


###  https://example.org/story/plot#followsSection
<https://example.org/story/plot#followsSection> rdf:type owl:ObjectProperty ;
                                                owl:inverseOf <https://example.org/story/plot#precedesSection> ;
                                                rdfs:comment "Inverse of precedesSection."@en ;
                                                rdfs:label "follows section"@en .


###  https://example.org/story/plot#hasAuthor
<https://example.org/story/plot#hasAuthor> rdf:type owl:ObjectProperty ;
                                           rdfs:subPropertyOf <https://example.org/story/plot#hasContributor> ;
                                           rdf:type owl:IrreflexiveProperty ;
                                           rdfs:domain <https://example.org/story/plot#NarrativeWork> ;
                                           rdfs:range <https://example.org/story/plot#Author> ;
                                           rdfs:comment "The original author of the narrative work."@en ;
                                           rdfs:label "has author"@en .


###  https://example.org/story/plot#hasContributor
<https://example.org/story/plot#hasContributor> rdf:type owl:ObjectProperty ,
                                                         owl:AsymmetricProperty ,
                                                         owl:IrreflexiveProperty ;
                                                rdfs:domain <https://example.org/story/plot#NarrativeWork> ;
                                                rdfs:range <https://example.org/story/plot#Contributor> ;
                                                rdfs:comment "A person who contributed to the narrative work in any role."@en ;
                                                rdfs:label "has contributor"@en .


###  https://example.org/story/plot#hasEditor
<https://example.org/story/plot#hasEditor> rdf:type owl:ObjectProperty ;
                                           rdfs:subPropertyOf <https://example.org/story/plot#hasContributor> ;
                                           rdf:type owl:IrreflexiveProperty ;
                                           rdfs:domain <https://example.org/story/plot#NarrativeWork> ;
                                           rdfs:range <https://example.org/story/plot#Editor> ;
                                           rdfs:comment "An editor or compiler responsible for the published work."@en ;
                                           rdfs:label "has editor"@en .


###  https://example.org/story/plot#hasPublisher
<https://example.org/story/plot#hasPublisher> rdf:type owl:ObjectProperty ,
                                                       owl:IrreflexiveProperty ;
                                              rdfs:domain <https://example.org/story/plot#NarrativeWork> ;
                                              rdfs:range <https://example.org/story/plot#Publisher> ;
                                              rdfs:comment "The publishing organization of the narrative work."@en ;
                                              rdfs:label "has publisher"@en .


###  https://example.org/story/plot#hasSection
<https://example.org/story/plot#hasSection> rdf:type owl:ObjectProperty ,
                                                     owl:AsymmetricProperty ,
                                                     owl:IrreflexiveProperty ;
                                            rdfs:domain <https://example.org/story/plot#Story> ;
                                            rdfs:range <https://example.org/story/plot#StorySection> ;
                                            rdfs:comment "A story is divided into sections."@en ;
                                            rdfs:label "has section"@en .


###  https://example.org/story/plot#isDescribedBy
<https://example.org/story/plot#isDescribedBy> rdf:type owl:ObjectProperty ;
                                               owl:inverseOf <https://example.org/story/plot#describesEvent> ;
                                               rdfs:comment "Inverse of describesEvent. Links an in-world event back to the plot event that narrates it."@en ;
                                               rdfs:label "is described by"@en .


###  https://example.org/story/plot#leadsTo
<https://example.org/story/plot#leadsTo> rdf:type owl:ObjectProperty ;
                                         rdfs:subPropertyOf <https://example.org/story/plot#causallyPrecedesPlotEvent> ;
                                         rdfs:domain <https://example.org/story/plot#PlotEvent> ;
                                         rdfs:range <https://example.org/story/plot#PlotEvent> ;
                                         owl:propertyChainAxiom ( <https://example.org/story/plot#describesEvent>
                                                                  <https://example.org/story/action#resultsIn>
                                                                  [ owl:inverseOf <https://example.org/story/plot#describesEvent>
                                                                  ]
                                                                ) ;
                                         rdfs:comment "A plot event causally leads to another plot event. Inferred from describesEvent, act:resultsIn, and inverse describesEvent."@en ;
                                         rdfs:label "leads to"@en .


###  https://example.org/story/plot#mentionsAppellation
<https://example.org/story/plot#mentionsAppellation> rdf:type owl:ObjectProperty ;
                                                     rdfs:domain <https://example.org/story/plot#StorySection> ;
                                                     rdfs:range <https://example.org/story/social#Appellation> ;
                                                     owl:propertyChainAxiom ( <https://example.org/story/plot#containsPlotEvent>
                                                                              <https://example.org/story/plot#describesEvent>
                                                                              <https://example.org/story/event#recognizesAppellation>
                                                                            ) ;
                                                     rdfs:comment "A section mentions an appellation through a recognition event it describes."@en ;
                                                     rdfs:label "mentions appellation"@en .


###  https://example.org/story/plot#mentionsItem
<https://example.org/story/plot#mentionsItem> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <https://example.org/story/plot#StorySection> ;
