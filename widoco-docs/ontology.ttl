                                    rdfs:label "tangential proper part inverse"@en .


#################################################################
#    Data properties
#################################################################

###  https://example.org/story/action#hasPurpose
<https://example.org/story/action#hasPurpose> rdf:type owl:DatatypeProperty ;
                                              rdfs:domain <https://example.org/story/action#Action> ;
                                              rdfs:range xsd:string ;
                                              rdfs:comment "Why the agent performed the action (textual description)."@en ;
                                              rdfs:label "has purpose"@en .


###  https://example.org/story/place#hasFoundationDate
<https://example.org/story/place#hasFoundationDate> rdf:type owl:DatatypeProperty ,
                                                             owl:FunctionalProperty ;
                                                    rdfs:domain <https://example.org/story/place#Place> ;
                                                    rdfs:range xsd:string ;
                                                    rdfs:comment "When the place was established. String because fictional dates don't always fit xsd:date."@en ;
                                                    rdfs:label "has foundation date"@en .


###  https://example.org/story/place#hasPopulation
<https://example.org/story/place#hasPopulation> rdf:type owl:DatatypeProperty ,
                                                         owl:FunctionalProperty ;
                                                rdfs:domain <https://example.org/story/place#Settlement> ;
                                                rdfs:range xsd:nonNegativeInteger ;
                                                rdfs:comment "Number of inhabitants. Only makes sense for settlements."@en ;
                                                rdfs:label "has population"@en .


###  https://example.org/story/plot#hasChapterNumber
<https://example.org/story/plot#hasChapterNumber> rdf:type owl:DatatypeProperty ,
                                                           owl:FunctionalProperty ;
                                                  rdfs:domain <https://example.org/story/plot#Chapter> ;
                                                  rdfs:range xsd:positiveInteger ;
                                                  rdfs:comment "The ordinal number of a chapter within the story."@en ;
                                                  rdfs:label "has chapter number"@en .


###  https://example.org/story/plot#hasPublicationDate
<https://example.org/story/plot#hasPublicationDate> rdf:type owl:DatatypeProperty ;
                                                    rdfs:domain <https://example.org/story/plot#NarrativeWork> ;
                                                    rdfs:range xsd:dateTime ;
                                                    rdfs:comment "The real-world date the narrative work was published."@en ;
                                                    rdfs:label "has publication date"@en .


###  https://example.org/story/plot#hasTextSummary
<https://example.org/story/plot#hasTextSummary> rdf:type owl:DatatypeProperty ;
                                                rdfs:range xsd:string ;
                                                rdfs:comment "A textual summary. No domain restriction for the same reason as hasTitle."@en ;
                                                rdfs:label "has text summary"@en .


###  https://example.org/story/plot#hasTitle
<https://example.org/story/plot#hasTitle> rdf:type owl:DatatypeProperty ;
                                          rdfs:range xsd:string ;
                                          rdfs:comment "The title of a story, section, or narrative work. No domain restriction because both NarrativeContainer and NarrativeWork can have titles."@en ;
                                          rdfs:label "has title"@en .


#################################################################
#    Classes
#################################################################

###  http://purl.org/family/BerevedParent
:BerevedParent rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                            owl:onProperty :isAParentOf ;
                                                            owl:someValuesFrom owl:Thing
                                                          ]
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :isAParentOf ;
                                                            owl:someValuesFrom [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty [ owl:inverseOf <https://example.org/story/event#hasDeceased>
                                                                                                ] ;
                                                                                 owl:someValuesFrom <https://example.org/story/event#Death>
                                                                               ]
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
               rdfs:comment "A parent at least one of whose children has died. In the Narn, Hurin and Morwen are bereaved parents."@en ;
               rdfs:label "bereaved parent"@en .


###  http://purl.org/family/Childless
:Childless rdf:type owl:Class ;
           owl:equivalentClass [ rdf:type owl:Class ;
                                 owl:complementOf [ rdf:type owl:Restriction ;
                                                    owl:onProperty :isAParentOf ;
                                                    owl:someValuesFrom owl:Thing
                                                  ]
                               ] ;
           rdfs:comment "An individual with no known children. Under the open world assumption, anyone not yet asserted to be a parent qualifies."@en ;
           rdfs:label "childless"@en .


###  http://purl.org/family/Female
:Female rdf:type owl:Class ;
        owl:disjointWith :Male ;
        rdfs:comment "A female individual. The gender may be a 'natural' one, attributed at birth, or a given one by social conventions."@en ;
        rdfs:label "female"@en .


###  http://purl.org/family/Male
:Male rdf:type owl:Class ;
      rdfs:comment "A male individual. The gender may be a 'natural' one, attributed at birth, or a given one by social conventions."@en ;
      rdfs:label "male"@en .


###  http://purl.org/family/MarriedParent
:MarriedParent rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                            owl:onProperty :isAParentOf ;
                                                            owl:someValuesFrom owl:Thing
                                                          ]
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :isMarriedTo ;
                                                            owl:someValuesFrom owl:Thing
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
               rdfs:comment "A character who is both married and a parent. Classified from marriage and parent data."@en ;
               rdfs:label "married parent"@en .


###  http://purl.org/family/OnlyChild
:OnlyChild rdf:type owl:Class ;
           owl:equivalentClass [ owl:intersectionOf ( [ rdf:type owl:Class ;
                                                        owl:complementOf [ rdf:type owl:Restriction ;
                                                                           owl:onProperty :isASiblingOf ;
                                                                           owl:someValuesFrom owl:Thing
                                                                         ]
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty [ owl:inverseOf :isAParentOf
                                                                       ] ;
                                                        owl:someValuesFrom owl:Thing
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] ;
           rdfs:comment "A character who has a parent but no known siblings. Anyone without asserted siblings qualifies under the open world assumption."@en ;
           rdfs:label "Only child"@en .


###  http://purl.org/family/Orphan
:Orphan rdf:type owl:Class ;
        owl:equivalentClass [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                     owl:onProperty [ owl:inverseOf :isTheFatherOf
                                                                    ] ;
                                                     owl:someValuesFrom [ rdf:type owl:Restriction ;
                                                                          owl:onProperty [ owl:inverseOf <https://example.org/story/event#hasDeceased>
                                                                                         ] ;
                                                                          owl:someValuesFrom <https://example.org/story/event#Death>
                                                                        ]
                                                   ]
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty [ owl:inverseOf :isTheMotherOf
                                                                    ] ;
                                                     owl:someValuesFrom [ rdf:type owl:Restriction ;
                                                                          owl:onProperty [ owl:inverseOf <https://example.org/story/event#hasDeceased>
                                                                                         ] ;
                                                                          owl:someValuesFrom <https://example.org/story/event#Death>
                                                                        ]
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
        rdfs:comment "A character whose father AND mother are both deceased. Uses nested restrictions: has a father who is the deceased of some Death AND has a mother who is the deceased of some Death."@en ;
        rdfs:label "Orphan"@en .


###  http://purl.org/family/Widowed
:Widowed rdf:type owl:Class ;
         owl:equivalentClass [ rdf:type owl:Restriction ;
                               owl:onProperty :isMarriedTo ;
                               owl:someValuesFrom [ rdf:type owl:Restriction ;
                                                    owl:onProperty [ owl:inverseOf <https://example.org/story/event#hasDeceased>
                                                                   ] ;
                                                    owl:someValuesFrom <https://example.org/story/event#Death>
                                                  ]
                             ] ;
         rdfs:comment "A character whose spouse has died. Classified via marriage and death event data."@en ;
         rdfs:label "widowed"@en .


###  http://purl.org/meo/Adan
<http://purl.org/meo/Adan> rdf:type owl:Class ;
                           rdfs:subClassOf <http://purl.org/meo/Atan> ;
                           rdfs:comment "The Edain (plural form of Adan) are the Men that belong to the Three Houses of Men that came to Beleriand in the elder days. Originally, “Adan” (plural “Edain”) is the Sindarin equivalent of Quenya “Atan” (plural “Atani”) but eventually came to mean this narrow subgroup."@en ;
                           rdfs:label "Adan"@sjn ,
                                      "Man"@en .


###  http://purl.org/meo/Ainu
<http://purl.org/meo/Ainu> rdf:type owl:Class ;
                           rdfs:subClassOf <http://purl.org/meo/Immortal> ;
                           owl:disjointWith <http://purl.org/meo/Casar> ,
                                            <http://purl.org/meo/Eruhin> ,
                                            <http://purl.org/meo/God> ,
                                            <http://purl.org/meo/Lócë> ,
                                            <http://purl.org/meo/Torog> ;
                           owl:disjointUnionOf ( <http://purl.org/meo/Maia>
                                                 <http://purl.org/meo/Vala>
                                               ) ;
                           rdfs:comment "The Ainur (plural form of Ainu) are the spirits created by Eru Ilúvatar before time existed"@en ;
                           rdfs:label "Ainu"@qya ,
                                      "Holy one"@en .


###  http://purl.org/meo/Atan
<http://purl.org/meo/Atan> rdf:type owl:Class ;
                           rdfs:subClassOf <http://purl.org/meo/Eruhin> ,
                                           <http://purl.org/meo/Mortal> ;
                           owl:disjointWith <http://purl.org/meo/Casar> ,
                                            <http://purl.org/meo/Quendë> ;
                           rdfs:comment "The Atani (plural form of Atan) are the second born of the Children of Ilúvatar, the Men (i.e. Humans, not male people). They were given many names also by the Eldar."@en ;
                           rdfs:label "Adan"@sjn ,
                                      "Atan"@qya ,
                                      "Man"@en ;
                           <http://www.w3.org/2004/02/skos/core#altLabel> "After-born"@en ,
                                                                          "After-comer"@en ,
                                                                          "Apanóna"@qya ,
                                                                          "Engwa"@qya ,
                                                                          "Follower"@en ,
                                                                          "Fírima"@qya ,
                                                                          "Hildo"@qya ,
                                                                          "Human"@en ,
                                                                          "Mortal"@en ,
                                                                          "Secondborn"@en ,
                                                                          "Sickly"@en .


###  http://purl.org/meo/Casar
<http://purl.org/meo/Casar> rdf:type owl:Class ;
                            rdfs:subClassOf <http://purl.org/meo/Mortal> ;
                            owl:disjointWith <http://purl.org/meo/God> ,
                                             <http://purl.org/meo/Lócë> ,
                                             <http://purl.org/meo/Quendë> ,
                                             <http://purl.org/meo/Torog> ;
                            rdfs:comment "The Casari (plural form of Casar in Quenya), more often called with the Sindarin variant Naugrim (plural of Naug in Sindarin), are the Dwarves created by the Vala Aulë."@en ;
                            rdfs:label "Casar"@qya ,
                                       "Dwarf"@en ,
                                       "Naug"@sjn ;
                            <http://www.w3.org/2004/02/skos/core#altLabel> "Aulëonna"@qya ,
                                                                           "Child of Aulë"@en .


###  http://purl.org/meo/Elda
<http://purl.org/meo/Elda> rdf:type owl:Class ;
                           owl:equivalentClass <http://purl.org/meo/Quendë> ;
                           rdfs:comment "The Eldar (plural form of Elda) are the Elves. They initially called themselves the Quendi, but the Vala Oromë, who met them at lake Cuiviénen under the stars, called them the Eldar. Now only the Quendi who followed Oromë to the West call themselves Eldar."@en ;
                           rdfs:label "Elda"@qya ,
                                      "Eledh"@sjn ,
                                      "Elf"@en ;
                           <http://www.w3.org/2004/02/skos/core#altLabel> "Firstborn"@en ,
                                                                          "of the stars"@en ,
                                                                          "person of the stars"@en .


###  http://purl.org/meo/Eruhin
<http://purl.org/meo/Eruhin> rdf:type owl:Class ;
                             owl:disjointWith <http://purl.org/meo/God> ,
                                              <http://purl.org/meo/Lócë> ,
                                              <http://purl.org/meo/Torog> ;
                             rdfs:comment "The Eruhíni (plural form of Eruhin), literally “the Children of Eru”, are usually called the “Children of Ilúvatar”. They are the Elves and Men. “Children of Ilúvatar” is used to collectively refer to the two races of Men and Elves, and the singular form is rarely used."@en ;
                             rdfs:label "Child of Ilúvatar"@en ,
                                        "Eruhin"@qya ;
                             <http://www.w3.org/2004/02/skos/core#altLabel> "Child of Eru"@en .


###  http://purl.org/meo/EvilBeing
<http://purl.org/meo/EvilBeing> rdf:type owl:Class ;
                                owl:disjointWith <http://purl.org/meo/God> ;
                                rdfs:comment "The evil beings are sentient agents that have chosen to do bad things, behave badly for the sake of doing bad, or became corrupted into doing evil. Some things are raised and bred to be evil. Some things are led to become evil by other evil beings by subversion. Some choose to become evil due to greed or as a way to overcome hardships of their lives."@en ;
                                rdfs:label "evil being"@en .


###  http://purl.org/meo/God
<http://purl.org/meo/God> rdf:type owl:Class ;
                          owl:equivalentClass [ rdf:type owl:Class ;
                                                owl:oneOf ( <http://purl.org/meo/eru>
                                                          )
                                              ] ;
                          rdfs:subClassOf <http://purl.org/meo/Immortal> ;
                          owl:disjointWith <http://purl.org/meo/Mortal> ;
                          rdfs:comment "A sperior entity. A singleton class that only contains Eru Ilúvatar, the One Allfather."@en ;
                          rdfs:label "God"@en .


###  http://purl.org/meo/Immortal
<http://purl.org/meo/Immortal> rdf:type owl:Class ;
                               owl:disjointWith <http://purl.org/meo/Mortal> ;
                               rdfs:comment "An individual that does not die of natural death. Some immortals may die from wounds inflicted to them by violence or accident (like Elves), but some are truly eternal, like the Ainur)."@en ;
                               rdfs:label "immortal"@en .


###  http://purl.org/meo/Lócë
<http://purl.org/meo/Lócë> rdf:type owl:Class ;
                           rdfs:subClassOf <http://purl.org/meo/EvilBeing> ;
                           owl:disjointWith <http://purl.org/meo/Torog> ;
                           rdfs:comment "Evil and powerful monster."@en ;
                           rdfs:label "Dragon"@en ,
                                      "Lócë"@qya .


###  http://purl.org/meo/Maia
<http://purl.org/meo/Maia> rdf:type owl:Class ;
                           rdfs:subClassOf <http://purl.org/meo/Ainu> ;
                           owl:disjointWith <http://purl.org/meo/Vala> ;
                           rdfs:comment "The Maiar (plural form of Maia) are Ainur who entered Arda and serve the Valar."@en ;
                           rdfs:label "Beautiful"@en ,
                                      "Maia"@qya .


###  http://purl.org/meo/Mortal
<http://purl.org/meo/Mortal> rdf:type owl:Class ;
                             rdfs:comment "Mortal living being, such as Men and Dwarces."@en ;
                             rdfs:label "mortal"@en .


###  http://purl.org/meo/Peredhel
<http://purl.org/meo/Peredhel> rdf:type owl:Class ;
                               rdfs:subClassOf <http://purl.org/meo/Eruhin> ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty :isADescendentOf ;
                                                 owl:someValuesFrom <http://purl.org/meo/Atan>
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty :isADescendentOf ;
                                                 owl:someValuesFrom <http://purl.org/meo/Elda>
                                               ] ;
                               rdfs:comment "Peredhil are descendent of both elves and humans."@en ;
                               rdfs:label "Half-elf"@en ,
                                          "Peredhel"@sjn .


###  http://purl.org/meo/Quendë
<http://purl.org/meo/Quendë> rdf:type owl:Class ;
                             rdfs:subClassOf <http://purl.org/meo/Eruhin> ,
                                             <http://purl.org/meo/Immortal> ;
                             rdfs:comment "The Quendi (plural form of Quendë) are the first born of the Children of Ilúvatar, the Elves. They are named thus because they were the only ones who spoke when they first appeared, before Men and Dwarves came to be. They are more often called the Eldar."@en ;
                             rdfs:label "Elf"@en ,
                                        "Quendë"@qya ;
                             <http://www.w3.org/2004/02/skos/core#altLabel> "Elda"@qya ,
                                                                            "Firstborn"@en ,
                                                                            "one that speaks"@en .


###  http://purl.org/meo/Torog
<http://purl.org/meo/Torog> rdf:type owl:Class ;
                            rdfs:subClassOf <http://purl.org/meo/EvilBeing> ;
                            rdfs:comment "The *Teryg (probably the plural form of Torog in Sindarin) are the Trolls, large humanoid monsters of great physical strength and weak intellect."@en ;
                            rdfs:label "torog"@sjn ,
                                       "troll"@en .


###  http://purl.org/meo/Vala
<http://purl.org/meo/Vala> rdf:type owl:Class ;
                           rdfs:subClassOf <http://purl.org/meo/Ainu> ;
                           rdfs:comment "The Valar (plural form of Vala) are the most powerful Ainur who entered Arda, the world."@en ;
                           rdfs:label "Vala"@qya ,
                                      "angelic power"@en .


###  https://example.org/story/action#Action
<https://example.org/story/action#Action> rdf:type owl:Class ;
                                          owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/event#Event>
                                                                                     [ rdf:type owl:Restriction ;
                                                                                       owl:onProperty <https://example.org/story/event#hasAgent> ;
                                                                                       owl:someValuesFrom owl:Thing
                                                                                     ]
                                                                                   ) ;
                                                                rdf:type owl:Class
                                                              ] ;
                                          rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                            owl:onProperty <https://example.org/story/action#hasPurpose> ;
                                                            owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                          ] ;
                                          rdfs:comment "An event with a deliberate agent. Any event that has an agent gets classified as an action."@en ;
                                          rdfs:label "Action"@en .


###  https://example.org/story/action#AttackAction
<https://example.org/story/action#AttackAction> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://example.org/story/action#Action> ,
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty <https://example.org/story/action#hasPatient> ;
                                                                  owl:someValuesFrom owl:Thing
                                                                ] ,
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty <https://example.org/story/action#resultsIn> ;
                                                                  owl:someValuesFrom <https://example.org/story/event#Event>
                                                                ] ,
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty <https://example.org/story/action#resultsIn> ;
                                                                  owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                      owl:unionOf ( <https://example.org/story/event#PhysicalEvent>
                                                                                                    <https://example.org/story/event#SocialEvent>
                                                                                                  )
                                                                                    ]
                                                                ] ;
                                                rdfs:comment "A hostile action directed at a patient. Left as a conservative subclass rather than a defined class, because patienthood alone would wrongly classify non-violent actions such as curses as attacks."@en ;
                                                rdfs:label "Attack action"@en .


###  https://example.org/story/action#CurseAction
<https://example.org/story/action#CurseAction> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://example.org/story/action#SpeechAction> ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <https://example.org/story/action#hasPatient> ;
                                                                 owl:someValuesFrom owl:Thing
                                                               ] ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <https://example.org/story/action#resultsIn> ;
                                                                 owl:allValuesFrom <https://example.org/story/event#State>
                                                               ] ;
                                               rdfs:comment "Placing a curse on someone. In the Narn, Morgoth curses the children of Húrin."@en ;
                                               rdfs:label "Curse action"@en .


###  https://example.org/story/action#MoveAction
<https://example.org/story/action#MoveAction> rdf:type owl:Class ;
                                              owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/event#Journey>
                                                                                         [ rdf:type owl:Restriction ;
                                                                                           owl:onProperty <https://example.org/story/event#hasAgent> ;
                                                                                           owl:someValuesFrom owl:Thing
                                                                                         ]
                                                                                       ) ;
                                                                    rdf:type owl:Class
                                                                  ] ;
                                              rdfs:comment "A journey performed by a deliberate agent. Since hasTraveler is a sub-property of hasAgent, every journey with a traveler is a MoveAction."@en ;
                                              rdfs:label "Move action"@en .


###  https://example.org/story/action#SpeechAction
<https://example.org/story/action#SpeechAction> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://example.org/story/action#Action> ,
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty <https://example.org/story/event#hasSpeaker> ;
                                                                  owl:someValuesFrom owl:Thing
                                                                ] ;
                                                rdfs:comment "Deliberate speech: commands, declarations, curses, prophecies."@en ;
                                                rdfs:label "Speech action"@en .


###  https://example.org/story/action#UseItemAction
<https://example.org/story/action#UseItemAction> rdf:type owl:Class ;
                                                 owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/action#Action>
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <https://example.org/story/event#usesItem> ;
                                                                                              owl:someValuesFrom <https://example.org/story/event#Item>
                                                                                            ]
                                                                                          ) ;
                                                                       rdf:type owl:Class
                                                                     ] ;
                                                 rdfs:comment "An action that involves an item. Any action with usesItem is classified here."@en ;
                                                 rdfs:label "Use-item action"@en .


###  https://example.org/story/event#ArmedEvent
<https://example.org/story/event#ArmedEvent> rdf:type owl:Class ;
                                             owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/event#Event>
                                                                                        [ rdf:type owl:Restriction ;
                                                                                          owl:onProperty <https://example.org/story/event#usesItem> ;
                                                                                          owl:someValuesFrom <https://example.org/story/event#Weapon>
                                                                                        ]
                                                                                      ) ;
                                                                   rdf:type owl:Class
                                                                 ] ;
                                             rdfs:comment "Any event involving a weapon."@en ;
                                             rdfs:label "Armed event"@en .


###  https://example.org/story/event#Artifact
<https://example.org/story/event#Artifact> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://example.org/story/event#Item> ;
                                           rdfs:comment "A crafted object of special significance, such as a jewel, ring, or magical item."@en ;
                                           rdfs:label "Artifact"@en .


###  https://example.org/story/event#Battle
<https://example.org/story/event#Battle> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://example.org/story/event#PhysicalEvent> ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://example.org/story/event#hasLocation> ;
                                                           owl:someValuesFrom <https://example.org/story/place#Place>
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://example.org/story/event#hasCombatant> ;
                                                           owl:minCardinality "2"^^xsd:nonNegativeInteger
                                                         ] ;
                                         rdfs:comment "A violent confrontation."@en ;
                                         rdfs:label "Battle"@en .


###  https://example.org/story/event#BattleVeteran
<https://example.org/story/event#BattleVeteran> rdf:type owl:Class ;
                                                owl:equivalentClass [ rdf:type owl:Restriction ;
                                                                      owl:onProperty <https://example.org/story/event#participatesIn> ;
                                                                      owl:someValuesFrom <https://example.org/story/event#Battle>
                                                                    ] ;
                                                rdfs:comment "Any character who participated in a battle."@en ;
                                                rdfs:label "Battle veteran"@en .


###  https://example.org/story/event#Birth
<https://example.org/story/event#Birth> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://example.org/story/event#SocialEvent> ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <https://example.org/story/event#hasMother> ;
                                                          owl:cardinality "1"^^xsd:nonNegativeInteger
                                                        ] ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <https://example.org/story/event#hasNewborn> ;
                                                          owl:cardinality "1"^^xsd:nonNegativeInteger
                                                        ] ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <https://example.org/story/event#hasFather> ;
                                                          owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                        ] ;
                                        rdfs:comment "The birth of a character."@en ;
                                        rdfs:label "Birth"@en .


###  https://example.org/story/event#Captive
<https://example.org/story/event#Captive> rdf:type owl:Class ;
                                          owl:equivalentClass [ rdf:type owl:Restriction ;
                                                                owl:onProperty [ owl:inverseOf <https://example.org/story/event#hasCaptive>
                                                                               ] ;
                                                                owl:someValuesFrom <https://example.org/story/event#Captivity>
                                                              ] ;
                                          rdfs:comment "Any character held captive in some Captivity event."@en ;
                                          rdfs:label "Captive"@en .


###  https://example.org/story/event#Captivity
<https://example.org/story/event#Captivity> rdf:type owl:Class ;
                                            rdfs:subClassOf <https://example.org/story/event#Presence> ,
                                                            <https://example.org/story/event#State> ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <https://example.org/story/event#hasCaptive> ;
                                                              owl:someValuesFrom owl:Thing
                                                            ] ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <https://example.org/story/event#hasCaptor> ;
                                                              owl:someValuesFrom owl:Thing
                                                            ] ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <https://example.org/story/event#hasLocation> ;
                                                              owl:someValuesFrom <https://example.org/story/place#Place>
                                                            ] ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <https://example.org/story/event#hasCaptor> ;
                                                              owl:allValuesFrom <http://purl.org/meo/EvilBeing>
                                                            ] ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <https://example.org/story/event#hasCaptive> ;
                                                              owl:cardinality "1"^^xsd:nonNegativeInteger
                                                            ] ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <https://example.org/story/event#hasCaptor> ;
                                                              owl:cardinality "1"^^xsd:nonNegativeInteger
                                                            ] ;
                                            rdfs:comment "Being held prisoner."@en ;
                                            rdfs:label "Captivity"@en .


###  https://example.org/story/event#Conversation
<https://example.org/story/event#Conversation> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://example.org/story/event#Meeting> ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <https://example.org/story/event#hasSpeaker> ;
                                                                 owl:minCardinality "2"^^xsd:nonNegativeInteger
                                                               ] ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <https://example.org/story/event#hasLocation> ;
                                                                 owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                 owl:onClass <https://example.org/story/place#Place>
                                                               ] ;
                                               rdfs:comment "A meeting involving verbal exchange."@en ;
                                               rdfs:label "Conversation"@en .


###  https://example.org/story/event#Coronation
<https://example.org/story/event#Coronation> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://example.org/story/event#SocialEvent> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <https://example.org/story/event#hasLocation> ;
                                                               owl:someValuesFrom <https://example.org/story/place#Place>
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <https://example.org/story/event#hasCrownedEntity> ;
                                                               owl:cardinality "1"^^xsd:nonNegativeInteger
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <https://example.org/story/event#hasCrowner> ;
                                                               owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                             ] ;
                                             rdfs:comment "An event in which a character is crowned or given authority."@en ;
                                             rdfs:label "Coronation"@en .


###  https://example.org/story/event#Death
<https://example.org/story/event#Death> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://example.org/story/event#SocialEvent> ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <https://example.org/story/event#hasDeceased> ;
                                                          owl:cardinality "1"^^xsd:nonNegativeInteger
                                                        ] ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <https://example.org/story/event#hasKiller> ;
                                                          owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                        ] ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <https://example.org/story/event#hasLocation> ;
                                                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                          owl:onClass <https://example.org/story/place#Place>
                                                        ] ;
                                        rdfs:comment "The death of a character."@en ;
                                        rdfs:label "Death"@en .


###  https://example.org/story/event#DecisiveBattle
<https://example.org/story/event#DecisiveBattle> rdf:type owl:Class ;
                                                 owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/event#Battle>
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <https://example.org/story/event#hasVictor> ;
                                                                                              owl:someValuesFrom owl:Thing
                                                                                            ]
                                                                                          ) ;
                                                                       rdf:type owl:Class
                                                                     ] ;
                                                 rdfs:comment "A battle with an identified victor."@en ;
                                                 rdfs:label "Decisive battle"@en .


###  https://example.org/story/event#Event
<https://example.org/story/event#Event> rdf:type owl:Class ;
                                        rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                          owl:onProperty <https://example.org/story/event#hasTemporalExtent> ;
                                                          owl:someValuesFrom <https://example.org/story/time#Interval>
                                                        ] ;
                                        owl:disjointWith <https://example.org/story/event#Item> ;
                                        owl:disjointUnionOf ( <https://example.org/story/event#PhysicalEvent>
                                                              <https://example.org/story/event#SocialEvent>
                                                              <https://example.org/story/event#State>
                                                            ) ;
                                        rdfs:comment "Something that happens in the story world, with a time, place, and participants."@en ;
                                        rdfs:label "Event"@en ;
                                        rdfs:seeAlso <http://purl.org/NET/c4dm/event.owl#Event> ,
                                                     <http://schema.org/Event> .


###  https://example.org/story/event#Faction
<https://example.org/story/event#Faction> rdf:type owl:Class ;
                                          rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                            owl:onProperty <https://example.org/story/event#hasMember> ;
                                                            owl:minCardinality "1"^^xsd:nonNegativeInteger
                                                          ] ;
                                          owl:disjointWith <https://example.org/story/event#Item> ;
                                          rdfs:comment "A collective side in a conflict. Used as combatant in battles instead of individual characters when the conflict involves armies rather than individuals."@en ;
                                          rdfs:label "Faction"@en .


###  https://example.org/story/event#Item
<https://example.org/story/event#Item> rdf:type owl:Class ;
                                       rdfs:subClassOf [ rdf:type owl:Class ;
                                                         owl:unionOf ( <https://example.org/story/event#Artifact>
                                                                       <https://example.org/story/event#Vehicle>
                                                                       <https://example.org/story/event#Weapon>
                                                                     )
                                                       ] ;
                                       owl:disjointWith <https://example.org/story/place#Place> ;
                                       rdfs:comment "A significant object that can be used in events. Items include weapons, vehicles, and artifacts."@en ;
                                       rdfs:label "Item"@en .


###  https://example.org/story/event#Journey
<https://example.org/story/event#Journey> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://example.org/story/event#PhysicalEvent> ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <https://example.org/story/event#hasTraveler> ;
                                                            owl:someValuesFrom owl:Thing
                                                          ] ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <https://example.org/story/event#hasDestination> ;
                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                            owl:onClass <https://example.org/story/place#Place>
                                                          ] ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <https://example.org/story/event#hasOrigin> ;
                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                            owl:onClass <https://example.org/story/place#Place>
                                                          ] ;
                                          rdfs:comment "Moving from one place to another."@en ;
                                          rdfs:label "Journey"@en .


###  https://example.org/story/event#Killer
<https://example.org/story/event#Killer> rdf:type owl:Class ;
                                         owl:equivalentClass [ rdf:type owl:Restriction ;
                                                               owl:onProperty [ owl:inverseOf <https://example.org/story/event#hasKiller>
                                                                              ] ;
                                                               owl:someValuesFrom <https://example.org/story/event#Death>
                                                             ] ;
                                         rdfs:comment "Any individual who is the killer in some Death event."@en ;
                                         rdfs:label "Killer"@en .


###  https://example.org/story/event#LethalWeapon
<https://example.org/story/event#LethalWeapon> rdf:type owl:Class ;
                                               owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/event#Weapon>
                                                                                          [ rdf:type owl:Restriction ;
                                                                                            owl:onProperty [ owl:inverseOf <https://example.org/story/event#usesItem>
                                                                                                           ] ;
                                                                                            owl:someValuesFrom <https://example.org/story/event#Death>
                                                                                          ]
                                                                                        ) ;
                                                                     rdf:type owl:Class
                                                                   ] ;
                                               rdfs:comment "A weapon that was used in at least one death event. Gurthang qualifies because it was used in the deaths of Beleg and Turin."@en ;
                                               rdfs:label "Lethal weapon"@en .


###  https://example.org/story/event#Marriage
<https://example.org/story/event#Marriage> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://example.org/story/event#SocialEvent> ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://example.org/story/event#hasHusband> ;
                                                             owl:cardinality "1"^^xsd:nonNegativeInteger
                                                           ] ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://example.org/story/event#hasLocation> ;
                                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                             owl:onClass <https://example.org/story/place#Place>
                                                           ] ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://example.org/story/event#hasWife> ;
                                                             owl:cardinality "1"^^xsd:nonNegativeInteger
                                                           ] ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://example.org/story/event#hasOfficiant> ;
                                                             owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                           ] ;
                                           rdfs:comment "A marriage event with husband, wife, and officiant roles."@en ;
                                           rdfs:label "Marriage"@en .


###  https://example.org/story/event#Meeting
<https://example.org/story/event#Meeting> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://example.org/story/event#SocialEvent> ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <https://example.org/story/event#hasLocation> ;
                                                            owl:someValuesFrom <https://example.org/story/place#Place>
                                                          ] ;
                                          rdfs:comment "Two or more characters encounter each other."@en ;
                                          rdfs:label "Meeting"@en .


###  https://example.org/story/event#MorgothEvent
<https://example.org/story/event#MorgothEvent> rdf:type owl:Class ;
                                               owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/event#Event>
                                                                                          [ rdf:type owl:Restriction ;
                                                                                            owl:onProperty <https://example.org/story/event#hasParticipant> ;
                                                                                            owl:hasValue <http://purl.org/meo/morgoth>
                                                                                          ]
                                                                                        ) ;
                                                                     rdf:type owl:Class
                                                                   ] ;
                                               rdfs:comment "Any event in which Morgoth participates."@en ;
                                               rdfs:label "Morgoth event"@en .


###  https://example.org/story/event#NaturalDisaster
<https://example.org/story/event#NaturalDisaster> rdf:type owl:Class ;
                                                  owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/event#PhysicalEvent>
                                                                                             [ rdf:type owl:Class ;
                                                                                               owl:complementOf [ rdf:type owl:Restriction ;
                                                                                                                  owl:onProperty <https://example.org/story/event#hasAgent> ;
                                                                                                                  owl:someValuesFrom owl:Thing
                                                                                                                ]
                                                                                             ]
                                                                                           ) ;
                                                                        rdf:type owl:Class
                                                                      ] ;
                                                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                    owl:onProperty <https://example.org/story/event#hasLocation> ;
                                                                    owl:someValuesFrom <https://example.org/story/place#Place>
                                                                  ] ;
                                                  rdfs:comment "A physical event with no deliberate agent. The complement of Action within PhysicalEvent: if a physical event has an agent it is an Action, not a NaturalDisaster."@en ;
                                                  rdfs:label "Natural disaster"@en .


###  https://example.org/story/event#PhysicalEvent
<https://example.org/story/event#PhysicalEvent> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://example.org/story/event#Event> ;
                                                rdfs:comment "Events with physical consequences: battles, journeys, disasters."@en ;
                                                rdfs:label "Physical event"@en .


###  https://example.org/story/event#Presence
<https://example.org/story/event#Presence> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://example.org/story/event#State> ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://example.org/story/event#hasLocation> ;
                                                             owl:someValuesFrom <https://example.org/story/place#Place>
                                                           ] ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://example.org/story/event#hasPresentEntity> ;
                                                             owl:someValuesFrom owl:Thing
                                                           ] ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://example.org/story/event#hasLocation> ;
                                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                             owl:onClass <https://example.org/story/place#Place>
                                                           ] ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://example.org/story/event#hasPresentEntity> ;
                                                             owl:cardinality "1"^^xsd:nonNegativeInteger
                                                           ] ;
                                           rdfs:comment "A state in which an entity is explicitly present in a place during an interval."@en ;
                                           rdfs:label "Presence"@en .


###  https://example.org/story/event#Recognition
<https://example.org/story/event#Recognition> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://example.org/story/event#SocialEvent> ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <https://example.org/story/event#hasRecognizedCharacter> ;
                                                                owl:someValuesFrom owl:Thing
                                                              ] ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <https://example.org/story/event#hasRecognizer> ;
                                                                owl:someValuesFrom owl:Thing
                                                              ] ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <https://example.org/story/event#hasLocation> ;
                                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                owl:onClass <https://example.org/story/place#Place>
                                                              ] ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <https://example.org/story/event#hasRecognizedCharacter> ;
                                                                owl:cardinality "1"^^xsd:nonNegativeInteger
                                                              ] ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <https://example.org/story/event#hasRecognizer> ;
                                                                owl:cardinality "1"^^xsd:nonNegativeInteger
                                                              ] ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <https://example.org/story/event#recognizesAppellation> ;
                                                                owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                owl:onClass <https://example.org/story/social#Appellation>
                                                              ] ;
                                              rdfs:comment "A social event in which someone identifies or recognizes a character, optionally under a specific appellation."@en ;
                                              rdfs:label "Recognition"@en .


###  https://example.org/story/event#Reign
<https://example.org/story/event#Reign> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://example.org/story/event#State> ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <https://example.org/story/event#hasLocation> ;
                                                          owl:someValuesFrom <https://example.org/story/place#Place>
                                                        ] ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <https://example.org/story/event#hasRuler> ;
                                                          owl:someValuesFrom owl:Thing
                                                        ] ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <https://example.org/story/event#hasLocation> ;
                                                          owl:allValuesFrom <https://example.org/story/place#Realm>
                                                        ] ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <https://example.org/story/event#hasRuler> ;
                                                          owl:cardinality "1"^^xsd:nonNegativeInteger
                                                        ] ;
                                        rdfs:comment "A state of ruling over a realm or people."@en ;
                                        rdfs:label "Reign"@en .


###  https://example.org/story/event#Residence
<https://example.org/story/event#Residence> rdf:type owl:Class ;
                                            rdfs:subClassOf <https://example.org/story/event#Presence> ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <https://example.org/story/event#hasLocation> ;
                                                              owl:someValuesFrom <https://example.org/story/place#Place>
                                                            ] ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <https://example.org/story/event#hasResident> ;
                                                              owl:someValuesFrom owl:Thing
                                                            ] ;
                                            rdfs:comment "A state of living at a particular place for a period of time."@en ;
                                            rdfs:label "Residence"@en .


###  https://example.org/story/event#Ruler
<https://example.org/story/event#Ruler> rdf:type owl:Class ;
                                        owl:equivalentClass [ rdf:type owl:Restriction ;
                                                              owl:onProperty [ owl:inverseOf <https://example.org/story/event#hasRuler>
                                                                             ] ;
                                                              owl:someValuesFrom <https://example.org/story/event#Reign>
                                                            ] ;
                                        rdfs:comment "Any character who rules in some Reign event."@en ;
                                        rdfs:label "Ruler"@en .


###  https://example.org/story/event#SlainCharacter
<https://example.org/story/event#SlainCharacter> rdf:type owl:Class ;
                                                 owl:equivalentClass [ rdf:type owl:Restriction ;
                                                                       owl:onProperty [ owl:inverseOf <https://example.org/story/event#hasDeceased>
                                                                                      ] ;
                                                                       owl:someValuesFrom <https://example.org/story/event#Death>
                                                                     ] ;
                                                 rdfs:comment "Any individual who is the deceased of some Death event."@en ;
                                                 rdfs:label "Slain character"@en .


###  https://example.org/story/event#SocialEvent
<https://example.org/story/event#SocialEvent> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://example.org/story/event#Event> ;
                                              rdfs:comment "Events with social significance: births, deaths, marriages, coronations."@en ;
                                              rdfs:label "Social event"@en .


###  https://example.org/story/event#State
<https://example.org/story/event#State> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://example.org/story/event#Event> ;
                                        rdfs:comment "An ongoing state of affairs: a residence, captivity, or reign."@en ;
                                        rdfs:label "State"@en .


###  https://example.org/story/event#Traveler
<https://example.org/story/event#Traveler> rdf:type owl:Class ;
                                           owl:equivalentClass [ rdf:type owl:Restriction ;
                                                                 owl:onProperty [ owl:inverseOf <https://example.org/story/event#hasTraveler>
                                                                                ] ;
                                                                 owl:someValuesFrom <https://example.org/story/event#Journey>
                                                               ] ;
                                           rdfs:comment "Any character who is the traveler in some Journey event."@en ;
                                           rdfs:label "Traveler"@en .


###  https://example.org/story/event#Vehicle
<https://example.org/story/event#Vehicle> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://example.org/story/event#Item> ;
                                          rdfs:comment "A means of transport used in a journey."@en ;
                                          rdfs:label "Vehicle"@en .


###  https://example.org/story/event#War
<https://example.org/story/event#War> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://example.org/story/event#PhysicalEvent> ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <https://example.org/story/event#hasSubEvent> ;
                                                        owl:someValuesFrom <https://example.org/story/event#Battle>
                                                      ] ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <https://example.org/story/event#hasSubEvent> ;
                                                        owl:allValuesFrom [ rdf:type owl:Class ;
                                                                            owl:unionOf ( <https://example.org/story/event#Battle>
                                                                                          <https://example.org/story/event#War>
                                                                                        )
                                                                          ]
                                                      ] ;
                                      rdfs:comment "A prolonged conflict made up of multiple battles."@en ;
                                      rdfs:label "War"@en .


###  https://example.org/story/event#Weapon
<https://example.org/story/event#Weapon> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://example.org/story/event#Item> ;
                                         rdfs:comment "An object designed or used for combat. Example: Gurthang (Túrin's sword)."@en ;
                                         rdfs:label "Weapon"@en .


###  https://example.org/story/place#BattleSite
<https://example.org/story/place#BattleSite> rdf:type owl:Class ;
                                             owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/place#Place>
                                                                                        [ rdf:type owl:Restriction ;
                                                                                          owl:onProperty [ owl:inverseOf <https://example.org/story/event#hasLocation>
                                                                                                         ] ;
                                                                                          owl:someValuesFrom <https://example.org/story/event#Battle>
                                                                                        ]
                                                                                      ) ;
                                                                   rdf:type owl:Class
                                                                 ] ;
                                             rdfs:comment "A place where a battle occurred."@en ;
                                             rdfs:label "Battle site"@en .


###  https://example.org/story/place#Building
<https://example.org/story/place#Building> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://example.org/story/place#Place> ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://example.org/story/place#hasPart> ;
                                                             owl:someValuesFrom <https://example.org/story/place#Room>
                                                           ] ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://example.org/story/place#partOf> ;
                                                             owl:someValuesFrom <https://example.org/story/place#LandArea>
                                                           ] ;
                                           rdfs:comment "A structure with walls and a roof."@en ;
                                           rdfs:label "Building"@en .


###  https://example.org/story/place#City
<https://example.org/story/place#City> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://example.org/story/place#Settlement> ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://example.org/story/place#isCapitalOf> ;
                                                         owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                         owl:onClass <https://example.org/story/place#Realm>
                                                       ] ;
                                       rdfs:comment "A large settlement with political importance."@en ;
                                       rdfs:label "City"@en .


###  https://example.org/story/place#CursedPlace
<https://example.org/story/place#CursedPlace> rdf:type owl:Class ;
                                              owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/place#Place>
                                                                                         [ rdf:type owl:Restriction ;
                                                                                           owl:onProperty [ owl:inverseOf <https://example.org/story/event#hasLocation>
                                                                                                          ] ;
                                                                                           owl:someValuesFrom <https://example.org/story/action#CurseAction>
                                                                                         ]
                                                                                       ) ;
                                                                    rdf:type owl:Class
                                                                  ] ;
                                              rdfs:comment "A place where a curse was pronounced."@en ;
                                              rdfs:label "Cursed place"@en .


###  https://example.org/story/place#DeathSite
<https://example.org/story/place#DeathSite> rdf:type owl:Class ;
                                            owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/place#Place>
                                                                                       [ rdf:type owl:Restriction ;
                                                                                         owl:onProperty [ owl:inverseOf <https://example.org/story/event#hasLocation>
                                                                                                        ] ;
                                                                                         owl:someValuesFrom <https://example.org/story/event#Death>
                                                                                       ]
                                                                                     ) ;
                                                                  rdf:type owl:Class
                                                                ] ;
                                            rdfs:comment "A place where a character died."@en ;
                                            rdfs:label "Death site"@en .


###  https://example.org/story/place#Forest
<https://example.org/story/place#Forest> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://example.org/story/place#WoodedArea> ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://example.org/story/place#partOf> ;
                                                           owl:allValuesFrom [ rdf:type owl:Class ;
                                                                               owl:complementOf <https://example.org/story/place#Building>
                                                                             ]
                                                         ] ;
                                         rdfs:comment "A large wooded area. E.g. Brethil in the Narn."@en ;
                                         rdfs:label "Forest"@en .


###  https://example.org/story/place#FortifiedCity
<https://example.org/story/place#FortifiedCity> rdf:type owl:Class ;
                                                owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/place#City>
                                                                                           <https://example.org/story/place#Fortress>
                                                                                         ) ;
                                                                      rdf:type owl:Class
                                                                    ] ;
                                                rdfs:comment "A settlement that is both a fortress and a city."@en ;
                                                rdfs:label "Fortified city"@en .


###  https://example.org/story/place#Fortress
<https://example.org/story/place#Fortress> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://example.org/story/place#Settlement> ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://example.org/story/place#hasPart> ;
                                                             owl:someValuesFrom <https://example.org/story/place#Room>
                                                           ] ;
                                           rdfs:comment "A fortified settlement or stronghold, like Nargothrond or Menegroth. Not disjoint with City since some fortresses are city-sized."@en ;
                                           rdfs:label "Fortress"@en .


###  https://example.org/story/place#Hamlet
<https://example.org/story/place#Hamlet> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://example.org/story/place#Settlement> ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://example.org/story/place#isCapitalOf> ;
                                                           owl:allValuesFrom owl:Nothing
                                                         ] ;
                                         rdfs:comment "A very small settlement."@en ;
                                         rdfs:label "Hamlet"@en .


###  https://example.org/story/place#InhabitedPlace
<https://example.org/story/place#InhabitedPlace> rdf:type owl:Class ;
                                                 owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/place#Place>
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty [ owl:inverseOf <https://example.org/story/event#hasLocation>
                                                                                                             ] ;
                                                                                              owl:someValuesFrom <https://example.org/story/event#Residence>
                                                                                            ]
                                                                                          ) ;
                                                                       rdf:type owl:Class
                                                                     ] ;
                                                 rdfs:comment "A place where someone has resided. E.g. Menegroth, Nargothrond."@en ;
                                                 rdfs:label "Inhabited place"@en .


###  https://example.org/story/place#Lake
<https://example.org/story/place#Lake> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://example.org/story/place#WaterArea> ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://example.org/story/place#adjacentTo> ;
                                                         owl:allValuesFrom <https://example.org/story/place#LandArea>
                                                       ] ;
                                       rdfs:comment "Standing water surrounded by land."@en ;
                                       rdfs:label "Lake"@en .


###  https://example.org/story/place#LandArea
<https://example.org/story/place#LandArea> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://example.org/story/place#Place> ;
                                           owl:disjointUnionOf ( <https://example.org/story/place#Realm>
                                                                 <https://example.org/story/place#Settlement>
                                                                 <https://example.org/story/place#WildArea>
                                                               ) ;
                                           rdfs:comment "A place on land."@en ;
                                           rdfs:label "Land area"@en .


###  https://example.org/story/place#MountainRange
<https://example.org/story/place#MountainRange> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://example.org/story/place#WildArea> ;
                                                rdfs:comment "A chain of mountains."@en ;
                                                rdfs:label "Mountain range"@en .


###  https://example.org/story/place#Place
<https://example.org/story/place#Place> rdf:type owl:Class ;
                                        rdfs:comment "A named location in the story world."@en ;
                                        rdfs:label "Place"@en .


###  https://example.org/story/place#Plain
<https://example.org/story/place#Plain> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://example.org/story/place#WildArea> ;
                                        rdfs:comment "Flat open land."@en ;
                                        rdfs:label "Plain"@en .


###  https://example.org/story/place#PrisonPlace
<https://example.org/story/place#PrisonPlace> rdf:type owl:Class ;
                                              owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/place#Place>
                                                                                         [ rdf:type owl:Restriction ;
                                                                                           owl:onProperty [ owl:inverseOf <https://example.org/story/event#hasLocation>
                                                                                                          ] ;
                                                                                           owl:someValuesFrom <https://example.org/story/event#Captivity>
                                                                                         ]
                                                                                       ) ;
                                                                    rdf:type owl:Class
                                                                  ] ;
                                              rdfs:comment "A place of captivity."@en ;
                                              rdfs:label "Prison place"@en .


###  https://example.org/story/place#Realm
<https://example.org/story/place#Realm> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://example.org/story/place#LandArea> ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <https://example.org/story/place#hasPart> ;
                                                          owl:someValuesFrom <https://example.org/story/place#Settlement>
                                                        ] ;
                                        rdfs:comment "A kingdom or administrative region containing settlements and wild areas."@en ;
                                        rdfs:label "Realm"@en .


###  https://example.org/story/place#River
<https://example.org/story/place#River> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://example.org/story/place#WaterArea> ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <https://example.org/story/place#adjacentTo> ;
                                                          owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                          owl:onClass <https://example.org/story/place#LandArea>
                                                        ] ;
                                        rdfs:comment "A flowing watercourse."@en ;
                                        rdfs:label "River"@en .


###  https://example.org/story/place#Road
<https://example.org/story/place#Road> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://example.org/story/place#Place> ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://example.org/story/place#adjacentTo> ;
                                                         owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                         owl:onClass <https://example.org/story/place#Place>
                                                       ] ;
                                       rdfs:comment "A path or route connecting places."@en ;
                                       rdfs:label "Road"@en .


###  https://example.org/story/place#Room
<https://example.org/story/place#Room> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://example.org/story/place#Place> ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://example.org/story/place#partOf> ;
                                                         owl:someValuesFrom [ rdf:type owl:Class ;
                                                                              owl:unionOf ( <https://example.org/story/place#Building>
                                                                                            <https://example.org/story/place#Fortress>
                                                                                          )
                                                                            ]
                                                       ] ;
                                       rdfs:comment "A space inside a building or fortified complex."@en ;
                                       rdfs:label "Room"@en .


###  https://example.org/story/place#Sea
<https://example.org/story/place#Sea> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://example.org/story/place#WaterArea> ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <https://example.org/story/place#adjacentTo> ;
                                                        owl:someValuesFrom <https://example.org/story/place#LandArea>
                                                      ] ;
                                      rdfs:comment "A large body of salt water."@en ;
                                      rdfs:label "Sea"@en .


###  https://example.org/story/place#Settlement
<https://example.org/story/place#Settlement> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://example.org/story/place#LandArea> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <https://example.org/story/place#partOf> ;
                                                               owl:someValuesFrom <https://example.org/story/place#Realm>
                                                             ] ;
                                             rdfs:comment "An inhabited place. Has a population."@en ;
                                             rdfs:label "Settlement"@en .


###  https://example.org/story/place#Town
<https://example.org/story/place#Town> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://example.org/story/place#Settlement> ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://example.org/story/place#isCapitalOf> ;
                                                         owl:allValuesFrom owl:Nothing
                                                       ] ;
                                       rdfs:comment "Bigger than a hamlet, smaller than a city."@en ;
                                       rdfs:label "Town"@en .


###  https://example.org/story/place#WaterArea
<https://example.org/story/place#WaterArea> rdf:type owl:Class ;
                                            rdfs:subClassOf <https://example.org/story/place#Place> ;
                                            owl:disjointUnionOf ( <https://example.org/story/place#Lake>
                                                                  <https://example.org/story/place#River>
                                                                  <https://example.org/story/place#Sea>
                                                                ) ;
                                            rdfs:comment "A body of water: river, lake, or sea."@en ;
                                            rdfs:label "Water area"@en .


###  https://example.org/story/place#WildArea
<https://example.org/story/place#WildArea> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://example.org/story/place#LandArea> ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://example.org/story/place#hasPopulation> ;
                                                             owl:maxCardinality "0"^^xsd:nonNegativeInteger
                                                           ] ;
                                           rdfs:comment "Uninhabited natural area."@en ;
                                           rdfs:label "Wild area"@en .


###  https://example.org/story/place#WoodedArea
<https://example.org/story/place#WoodedArea> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://example.org/story/place#WildArea> ;
                                             rdfs:comment "Area covered mostly by trees."@en ;
                                             rdfs:label "Wooded area"@en .


###  https://example.org/story/plot#ActionPlotEvent
<https://example.org/story/plot#ActionPlotEvent> rdf:type owl:Class ;
                                                 owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/plot#PlotEvent>
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <https://example.org/story/plot#describesEvent> ;
                                                                                              owl:someValuesFrom <https://example.org/story/action#Action>
                                                                                            ]
                                                                                          ) ;
                                                                       rdf:type owl:Class
                                                                     ] ;
                                                 rdfs:comment "A plot event that narrates an intentional action."@en ;
                                                 rdfs:label "Action plot event"@en .


###  https://example.org/story/plot#Author
<https://example.org/story/plot#Author> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://example.org/story/plot#Contributor> ;
                                        owl:disjointWith <https://example.org/story/plot#Editor> ;
                                        rdfs:comment "A real-world person who originally wrote the work."@en ;
                                        rdfs:label "Author"@en ;
                                        rdfs:seeAlso <http://xmlns.com/foaf/0.1/Person> .


###  https://example.org/story/plot#BattlePlotEvent
<https://example.org/story/plot#BattlePlotEvent> rdf:type owl:Class ;
                                                 owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/plot#PlotEvent>
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <https://example.org/story/plot#describesEvent> ;
                                                                                              owl:someValuesFrom <https://example.org/story/event#Battle>
                                                                                            ]
                                                                                          ) ;
                                                                       rdf:type owl:Class
                                                                     ] ;
                                                 rdfs:comment "A plot event describing a battle."@en ;
                                                 rdfs:label "Battle plot event"@en .


###  https://example.org/story/plot#BirthPlotEvent
<https://example.org/story/plot#BirthPlotEvent> rdf:type owl:Class ;
                                                owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/plot#PlotEvent>
                                                                                           [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <https://example.org/story/plot#describesEvent> ;
                                                                                             owl:someValuesFrom <https://example.org/story/event#Birth>
                                                                                           ]
                                                                                         ) ;
                                                                      rdf:type owl:Class
                                                                    ] ;
                                                rdfs:comment "A plot event describing a birth."@en ;
                                                rdfs:label "Birth plot event"@en .


###  https://example.org/story/plot#Chapter
<https://example.org/story/plot#Chapter> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://example.org/story/plot#StorySection> ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <https://example.org/story/plot#hasChapterNumber> ;
                                                           owl:cardinality "1"^^xsd:nonNegativeInteger
                                                         ] ;
                                         rdfs:comment "A main division of the narrative."@en ;
                                         rdfs:label "Chapter"@en .


###  https://example.org/story/plot#ClosingPlotEvent
<https://example.org/story/plot#ClosingPlotEvent> rdf:type owl:Class ;
                                                  owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/plot#PlotEvent>
                                                                                             [ rdf:type owl:Restriction ;
                                                                                               owl:onProperty [ owl:inverseOf <https://example.org/story/plot#endsWith>
                                                                                                              ] ;
                                                                                               owl:someValuesFrom <https://example.org/story/plot#Story>
                                                                                             ]
                                                                                           ) ;
                                                                        rdf:type owl:Class
                                                                      ] ;
                                                  rdfs:comment "The plot event that ends the whole story."@en ;
                                                  rdfs:label "Closing plot event"@en .


###  https://example.org/story/plot#Contributor
<https://example.org/story/plot#Contributor> rdf:type owl:Class ;
                                             owl:disjointWith <https://example.org/story/plot#Publisher> ;
                                             rdfs:comment "A real-world person who contributes to the production of a narrative work."@en ;
                                             rdfs:label "Contributor"@en .


###  https://example.org/story/plot#DeathPlotEvent
<https://example.org/story/plot#DeathPlotEvent> rdf:type owl:Class ;
                                                owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/plot#PlotEvent>
                                                                                           [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <https://example.org/story/plot#describesEvent> ;
                                                                                             owl:someValuesFrom <https://example.org/story/event#Death>
                                                                                           ]
                                                                                         ) ;
                                                                      rdf:type owl:Class
                                                                    ] ;
                                                rdfs:comment "A plot event describing a death."@en ;
                                                rdfs:label "Death plot event"@en .


###  https://example.org/story/plot#Editor
<https://example.org/story/plot#Editor> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://example.org/story/plot#Contributor> ;
                                        rdfs:comment "A real-world person who edited or compiled the published work."@en ;
                                        rdfs:label "Editor"@en .


###  https://example.org/story/plot#Epilogue
<https://example.org/story/plot#Epilogue> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://example.org/story/plot#StorySection> ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <https://example.org/story/plot#nextSection> ;
                                                            owl:allValuesFrom owl:Nothing
                                                          ] ;
                                          rdfs:comment "A concluding section that follows the main narrative. No section can follow an epilogue (allValuesFrom Nothing on nextSection)."@en ;
                                          rdfs:label "Epilogue"@en .


###  https://example.org/story/plot#JourneyPlotEvent
<https://example.org/story/plot#JourneyPlotEvent> rdf:type owl:Class ;
                                                  owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/plot#PlotEvent>
                                                                                             [ rdf:type owl:Restriction ;
                                                                                               owl:onProperty <https://example.org/story/plot#describesEvent> ;
                                                                                               owl:someValuesFrom <https://example.org/story/event#Journey>
                                                                                             ]
                                                                                           ) ;
                                                                        rdf:type owl:Class
                                                                      ] ;
                                                  rdfs:comment "A plot event describing a journey."@en ;
                                                  rdfs:label "Journey plot event"@en .


###  https://example.org/story/plot#MarriagePlotEvent
<https://example.org/story/plot#MarriagePlotEvent> rdf:type owl:Class ;
                                                   owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/plot#PlotEvent>
                                                                                              [ rdf:type owl:Restriction ;
                                                                                                owl:onProperty <https://example.org/story/plot#describesEvent> ;
                                                                                                owl:someValuesFrom <https://example.org/story/event#Marriage>
                                                                                              ]
                                                                                            ) ;
                                                                         rdf:type owl:Class
                                                                       ] ;
                                                   rdfs:comment "A plot event describing a marriage."@en ;
                                                   rdfs:label "Marriage plot event"@en .


###  https://example.org/story/plot#NarrativeContainer
<https://example.org/story/plot#NarrativeContainer> rdf:type owl:Class ;
                                                    rdfs:comment "A structural element that can contain other narrative parts."@en ;
                                                    rdfs:label "Narrative container"@en .


###  https://example.org/story/plot#NarrativeElement
<https://example.org/story/plot#NarrativeElement> rdf:type owl:Class ;
                                                  rdfs:comment "An atomic narrative element, like a single plot event."@en ;
                                                  rdfs:label "Narrative element"@en .


###  https://example.org/story/plot#NarrativeWork
<https://example.org/story/plot#NarrativeWork> rdf:type owl:Class ;
                                               rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <https://example.org/story/plot#hasAuthor> ;
                                                                 owl:someValuesFrom <https://example.org/story/plot#Author>
                                                               ] ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <https://example.org/story/plot#narrates> ;
                                                                 owl:allValuesFrom <https://example.org/story/plot#Story>
                                                               ] ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <https://example.org/story/plot#hasPublisher> ;
                                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                 owl:onClass <https://example.org/story/plot#Publisher>
                                                               ] ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <https://example.org/story/plot#narrates> ;
                                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                 owl:onClass <https://example.org/story/plot#Story>
                                                               ] ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <https://example.org/story/plot#hasPublicationDate> ;
                                                                 owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                               ] ;
                                               rdfs:comment "A real-world book, manuscript, or film script with authorship, editorial, and publication metadata."@en ;
                                               rdfs:label "Narrative work"@en ;
                                               rdfs:seeAlso <http://purl.org/ontology/bibo/Document> ,
                                                            <http://schema.org/Book> .


###  https://example.org/story/plot#OpeningPlotEvent
<https://example.org/story/plot#OpeningPlotEvent> rdf:type owl:Class ;
                                                  owl:equivalentClass [ owl:intersectionOf ( <https://example.org/story/plot#PlotEvent>
                                                                                             [ rdf:type owl:Restriction ;
                                                                                               owl:onProperty [ owl:inverseOf <https://example.org/story/plot#startsWith>
                                                                                                              ] ;
                                                                                               owl:someValuesFrom <https://example.org/story/plot#Story>
                                                                                             ]
                                                                                           ) ;
                                                                        rdf:type owl:Class
                                                                      ] ;
                                                  rdfs:comment "The plot event that starts the whole story."@en ;
                                                  rdfs:label "Opening plot event"@en .


###  https://example.org/story/plot#PlotEvent
<https://example.org/story/plot#PlotEvent> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://example.org/story/plot#NarrativeElement> ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <https://example.org/story/plot#describesEvent> ;
                                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                             owl:onClass <https://example.org/story/event#Event>
                                                           ] ;
                                           rdfs:comment "A narrative element describing an in-world event. Bridges the plot layer and the event layer via describesEvent."@en ;
                                           rdfs:label "Plot event"@en .


###  https://example.org/story/plot#Prologue
<https://example.org/story/plot#Prologue> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://example.org/story/plot#StorySection> ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty [ owl:inverseOf <https://example.org/story/plot#nextSection>
                                                                           ] ;
                                                            owl:allValuesFrom owl:Nothing
                                                          ] ;
                                          rdfs:comment "An introductory section that precedes the main narrative. No section can precede a prologue (allValuesFrom Nothing on inv(nextSection))."@en ;
                                          rdfs:label "Prologue"@en .


###  https://example.org/story/plot#Publisher
<https://example.org/story/plot#Publisher> rdf:type owl:Class ;
                                           rdfs:comment "A real-world organization that publishes a narrative work."@en ;
                                           rdfs:label "Publisher"@en .


###  https://example.org/story/plot#Story
<https://example.org/story/plot#Story> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://example.org/story/plot#NarrativeContainer> ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://example.org/story/plot#endsWith> ;
                                                         owl:someValuesFrom <https://example.org/story/plot#PlotEvent>
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://example.org/story/plot#hasSection> ;
                                                         owl:someValuesFrom <https://example.org/story/plot#StorySection>
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://example.org/story/plot#startsWith> ;
                                                         owl:someValuesFrom <https://example.org/story/plot#PlotEvent>
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://example.org/story/plot#hasSection> ;
                                                         owl:allValuesFrom <https://example.org/story/plot#StorySection>
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://example.org/story/plot#hasSection> ;
                                                         owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                         owl:onClass <https://example.org/story/plot#Epilogue>
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <https://example.org/story/plot#hasSection> ;
                                                         owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                         owl:onClass <https://example.org/story/plot#Prologue>
                                                       ] ;
                                       owl:disjointWith <https://example.org/story/plot#StorySection> ;
                                       rdfs:comment "The fictional story as a whole."@en ;
                                       rdfs:label "Story"@en .


###  https://example.org/story/plot#StorySection
<https://example.org/story/plot#StorySection> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://example.org/story/plot#NarrativeContainer> ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <https://example.org/story/plot#containsPlotEvent> ;
                                                                owl:someValuesFrom <https://example.org/story/plot#PlotEvent>
                                                              ] ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <https://example.org/story/plot#containsPlotEvent> ;
                                                                owl:allValuesFrom <https://example.org/story/plot#PlotEvent>
                                                              ] ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <https://example.org/story/plot#sectionOf> ;
                                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                owl:onClass <https://example.org/story/plot#Story>
                                                              ] ;
                                              owl:disjointUnionOf ( <https://example.org/story/plot#Chapter>
                                                                    <https://example.org/story/plot#Epilogue>
                                                                    <https://example.org/story/plot#Prologue>
                                                                  ) ;
                                              rdfs:comment "A structural part of a story: prologue, chapter, or epilogue."@en ;
                                              rdfs:label "Story section"@en .


###  https://example.org/story/social#Appellation
<https://example.org/story/social#Appellation> rdf:type owl:Class ;
                                               rdfs:comment "A name, epithet, or title by which a character can be known in the story world."@en ;
                                               rdfs:label "Appellation"@en .


###  https://example.org/story/social#AppellationUse
<https://example.org/story/social#AppellationUse> rdf:type owl:Class ;
                                                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                    owl:onProperty <https://example.org/story/social#validDuring> ;
                                                                    owl:someValuesFrom <https://example.org/story/time#Interval>
                                                                  ] ,
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty <https://example.org/story/social#usedInPlace> ;
                                                                    owl:allValuesFrom <https://example.org/story/place#Place>
                                                                  ] ,
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty <https://example.org/story/social#usesAppellation> ;
                                                                    owl:allValuesFrom <https://example.org/story/social#Appellation>
                                                                  ] ,
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty <https://example.org/story/social#validDuring> ;
                                                                    owl:allValuesFrom <https://example.org/story/time#FiniteInterval>
                                                                  ] ,
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty <https://example.org/story/social#namesCharacter> ;
                                                                    owl:cardinality "1"^^xsd:nonNegativeInteger
                                                                  ] ,
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty <https://example.org/story/social#usesAppellation> ;
                                                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                    owl:onClass <https://example.org/story/social#Appellation>
                                                                  ] ,
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty <https://example.org/story/social#usedInPlace> ;
                                                                    owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                                  ] ;
                                                  rdfs:comment "A temporally scoped use of an appellation for a character."@en ;
                                                  rdfs:label "Appellation use"@en .


