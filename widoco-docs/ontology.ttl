                                                                              <https://example.org/story/plot#describesEvent>
                                                                              <https://example.org/story/event#involvesFactionMember>
                                                                            ) ;
                                                     rdfs:comment "A section mentions a participant in one of its plot events. Inferred from containsPlotEvent, describesEvent, and evt:hasParticipant."@en ;
                                                     rdfs:label "mentions participant"@en .


###  https://example.org/story/plot#mentionsPlace
<https://example.org/story/plot#mentionsPlace> rdf:type owl:ObjectProperty ;
                                               rdfs:domain <https://example.org/story/plot#StorySection> ;
                                               rdfs:range <https://example.org/story/place#Place> ;
                                               owl:propertyChainAxiom ( <https://example.org/story/plot#containsPlotEvent>
                                                                        <https://example.org/story/plot#describesEvent>
                                                                        <https://example.org/story/event#hasDestination>
                                                                      ) ,
                                                                      ( <https://example.org/story/plot#containsPlotEvent>
                                                                        <https://example.org/story/plot#describesEvent>
                                                                        <https://example.org/story/event#hasLocation>
                                                                      ) ,
                                                                      ( <https://example.org/story/plot#containsPlotEvent>
                                                                        <https://example.org/story/plot#describesEvent>
                                                                        <https://example.org/story/event#hasOrigin>
                                                                      ) ;
                                               rdfs:comment "A section mentions a place through event location, origin, or destination."@en ;
                                               rdfs:label "mentions place"@en .


###  https://example.org/story/plot#narrates
<https://example.org/story/plot#narrates> rdf:type owl:ObjectProperty ,
                                                   owl:AsymmetricProperty ,
                                                   owl:IrreflexiveProperty ;
                                          rdfs:domain <https://example.org/story/plot#NarrativeWork> ;
                                          rdfs:range <https://example.org/story/plot#Story> ;
                                          rdfs:comment "Links the real-world work to the fictional story it tells. Asymmetric: a story does not narrate the book."@en ;
                                          rdfs:label "narrates"@en .


###  https://example.org/story/plot#narratesAppellation
<https://example.org/story/plot#narratesAppellation> rdf:type owl:ObjectProperty ;
                                                     rdfs:domain <https://example.org/story/plot#NarrativeWork> ;
                                                     rdfs:range <https://example.org/story/social#Appellation> ;
                                                     owl:propertyChainAxiom ( <https://example.org/story/plot#narrates>
                                                                              <https://example.org/story/plot#storyMentionsAppellation>
                                                                            ) ;
                                                     rdfs:comment "A narrative work narrates an appellation through the story and sections it contains."@en ;
                                                     rdfs:label "narrates appellation"@en .


###  https://example.org/story/plot#narratesEvent
<https://example.org/story/plot#narratesEvent> rdf:type owl:ObjectProperty ;
                                               rdfs:domain <https://example.org/story/plot#NarrativeWork> ;
                                               rdfs:range <https://example.org/story/event#Event> ;
                                               owl:propertyChainAxiom ( <https://example.org/story/plot#narrates>
                                                                        <https://example.org/story/plot#storyContainsEvent>
                                                                      ) ;
                                               rdfs:comment "A narrative work narrates an in-world event via the story it tells."@en ;
                                               rdfs:label "narrates event"@en .


###  https://example.org/story/plot#narratesItem
