#
# Region Connection Calculus (RCC8) Ontology
#
# RCC8 with OWL axioms: symmetry, transitivity, inverses, partial disjointness.
#
# DC, EC, PO: symmetric, irreflexive
# EQ: symmetric + transitive (reflexivity omitted, see comment on rcc:eq)
# TPP, NTPP: transitive (inverses: TPPi, NTPPi)
#

@prefix az:   <https://w3id.org/people/az/> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rcc:  <https://purl.org/region/rcc8/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

rcc: a owl:Ontology ;
    rdfs:label "The RCC8 ontology"@en ;
    dct:title "Region Connection Calculus (RCC8) Ontology"@en ;
    rdfs:comment "RCC8 spatial relations between regions, encoded with DL-safe OWL axioms."@en ;
    owl:versionInfo "1.0" ;
    dct:creator az:me .

#
# Class
#
rcc:Region a owl:Class ;
    rdfs:label "region"@en ;
    rdfs:comment "A continuous extent of space. In story modelling, places occupy regions."@en .

#
# The 8 relations
#

rcc:dc a owl:ObjectProperty, owl:SymmetricProperty, owl:IrreflexiveProperty ;
    rdfs:label "disconnected"@en ;
    rdfs:comment "The two regions share no points at all."@en ;
    rdfs:domain rcc:Region ;
    rdfs:range rcc:Region .

rcc:ec a owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:label "externally connected"@en ;
    rdfs:comment "Boundaries touch but interiors don't overlap."@en ;
    rdfs:domain rcc:Region ;
    rdfs:range rcc:Region .

rcc:po a owl:ObjectProperty, owl:SymmetricProperty, owl:IrreflexiveProperty ;
    rdfs:label "partially overlapping"@en ;
    rdfs:comment "The regions partially overlap. Each has parts not in the other."@en ;
    rdfs:domain rcc:Region ;
    rdfs:range rcc:Region .

rcc:eq a owl:ObjectProperty, owl:SymmetricProperty, owl:TransitiveProperty ;
    rdfs:domain rcc:Region ;
    rdfs:range rcc:Region ;
    rdfs:label "equal"@en ;
    rdfs:comment "Same spatial extent. Symmetric and transitive. Reflexivity is part of the intended RCC8 semantics but is not declared in OWL because ReflexiveProperty without domain/range would apply to all individuals, and with domain/range would force everything to be a Region."@en .

rcc:tpp a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:label "tangential proper part"@en ;
    rdfs:comment "First region is inside the second and their boundaries touch."@en ;
    rdfs:domain rcc:Region ;
    rdfs:range rcc:Region .

rcc:tppi a owl:ObjectProperty, owl:TransitiveProperty ;
    owl:inverseOf rcc:tpp ;
    rdfs:label "tangential proper part inverse"@en ;
    rdfs:comment "Inverse of TPP. First region contains the second, boundaries touching."@en ;
    rdfs:domain rcc:Region ;
    rdfs:range rcc:Region .

rcc:ntpp a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:label "non-tangential proper part"@en ;
    rdfs:comment "First region is completely inside the second, boundaries don't touch."@en ;
    rdfs:domain rcc:Region ;
    rdfs:range rcc:Region .

rcc:ntppi a owl:ObjectProperty, owl:TransitiveProperty ;
    owl:inverseOf rcc:ntpp ;
    rdfs:label "non-tangential proper part inverse"@en ;
    rdfs:comment "Inverse of NTPP. First region completely contains the second."@en ;
    rdfs:domain rcc:Region ;
    rdfs:range rcc:Region .

# Pairwise disjointness.
# OWL 2 DL requires properties in DisjointObjectProperties to be simple
# (OWL 2 Structural Spec, Section 11.1). A property is non-simple if it
# is transitive or appears as the super-property of a property chain.
#
# In the full project (with place.ttl loaded):
#   dc  - simple (no transitivity, no chain)
#   ec  - NON-simple (super-property of chain in place.ttl: adjacentTo -> ec)
#   po  - simple (no transitivity, no chain)
#   eq  - NON-simple (transitive)
#   tpp, ntpp, tppi, ntppi - NON-simple (transitive + chain super-properties)
#
# Therefore dc and po are the ONLY pair that can be declared disjoint.
# IrreflexiveProperty has the same simplicity requirement, which is why
# only dc and po carry it. ec is irreflexive in RCC8 theory but cannot
# be declared so in OWL 2 DL when place.ttl is loaded.
rcc:dc owl:propertyDisjointWith rcc:po .

###############################################################
# Reflexivity of EQ via hasSelf
#
# In RCC8, eq is reflexive: every region is spatially equal to
# itself. Declaring rcc:eq as owl:ReflexiveProperty would force
# EVERY individual in the ontology to be a Region (because
# ReflexiveProperty applies universally, and the domain of eq
# is Region). Instead, we use a class-level hasSelf restriction:
# only Region instances get the self-eq triple.
###############################################################

# hasSelf(eq) was removed because eq is transitive (non-simple),
# and OWL 2 DL requires hasSelf properties to be simple.
# Reflexivity of eq is part of the intended RCC8 semantics but
# cannot be formally expressed in this ontology.

###############################################################
# RCC8 composition chains
#
# From the RCC8 composition table, several 2-relation compositions
# yield a single deterministic result. The most useful:
###############################################################

# ntpp(R1,R2) ^ tpp(R2,R3) => ntpp(R1,R3)
# R1 strictly inside R2, R2 inside R3 touching boundary.
# R1 strictly inside R3 (doesn't touch R3's boundary because R1
# doesn't touch R2's boundary and R2 is inside R3).
rcc:ntpp owl:propertyChainAxiom ( rcc:ntpp rcc:tpp ) .

# tpp(R1,R2) ^ ntpp(R2,R3) => ntpp(R1,R3)
# R1 inside R2 touching boundary. R2 strictly inside R3.
# R1 is inside R3. R2's boundary is strictly inside R3, so R1's
# contact with R2's boundary doesn't reach R3's boundary.
rcc:ntpp owl:propertyChainAxiom ( rcc:tpp rcc:ntpp ) .

# ntpp(R1,R2) ^ eq(R2,R3) => ntpp(R1,R3)
# R1 strictly inside R2, R2 same as R3 => R1 strictly inside R3.
rcc:ntpp owl:propertyChainAxiom ( rcc:ntpp rcc:eq ) .

# eq(R1,R2) ^ ntpp(R2,R3) => ntpp(R1,R3)
rcc:ntpp owl:propertyChainAxiom ( rcc:eq rcc:ntpp ) .

# tpp(R1,R2) ^ eq(R2,R3) => tpp(R1,R3)
rcc:tpp owl:propertyChainAxiom ( rcc:tpp rcc:eq ) .

# eq(R1,R2) ^ tpp(R2,R3) => tpp(R1,R3)
rcc:tpp owl:propertyChainAxiom ( rcc:eq rcc:tpp ) .

# Inverse compositions follow by symmetry of the axioms:
# ntppi(R1,R2) ^ tppi(R2,R3) => ntppi(R1,R3)
rcc:ntppi owl:propertyChainAxiom ( rcc:ntppi rcc:tppi ) .
# tppi(R1,R2) ^ ntppi(R2,R3) => ntppi(R1,R3)
rcc:ntppi owl:propertyChainAxiom ( rcc:tppi rcc:ntppi ) .
# ntppi with eq
rcc:ntppi owl:propertyChainAxiom ( rcc:ntppi rcc:eq ) .
rcc:ntppi owl:propertyChainAxiom ( rcc:eq rcc:ntppi ) .
# tppi with eq
rcc:tppi owl:propertyChainAxiom ( rcc:tppi rcc:eq ) .
rcc:tppi owl:propertyChainAxiom ( rcc:eq rcc:tppi ) .
