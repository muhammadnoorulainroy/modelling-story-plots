@prefix fo: <https://purl.org/family/> .    # A family ontology
@prefix loc: <https://purl.org/location/> . # A location ontology
@prefix meo: <https://purl.org/meo/> .      # An ontology of Middle-earth
@prefix narn: <https://purl.org/narn/> .    # Namespace of the Narn KG
@prefix plot: <https://purl.org/plot/> .    # A story plot ontology
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

#
# The story structure
# (text of the summary generated by Mistral AI)
narn:NarnIChînHúrin a plot:Story, plot:EpicTale, plot:FantasyStory;
  rdfs:label "Narn i chîn Húrin"@sjn, "Tale of the children of Húrin"@en;
  rdfs:comment  "The story of the Húrin's family, held in Middle-earth in the First Age of Arda, that tells how Húrin's children were cursed and what misfortune befell on them."@en;
  plot:hasStoryPart narn:Prologue, narn:TúrinEarlyYears, narn:TúrinInDoriath, narn:TúrinAndTheOutlaws, narn:TúrinInNargothrond, narn:NienorTale, narn:FinalDoom, narn:Epilogue;
  plot:happensIn narn:Endor .

narn:Prologue a plot:StorySection, plot:IntroductorySection;
  rdfs:label "Prologue: The Curse of Morgoth"@en;
  rdfs:comment "The story begins with the heroic but doomed figure of Húrin, a lord of the Edain (Men) and a mighty warrior in the wars against Morgoth, the first Dark Lord. Húrin’s defiance and bravery lead him to be captured after the disastrous Battle of Unnumbered Tears. Morgoth, unable to break Húrin’s spirit, curses his entire family, ensuring their suffering and downfall. Húrin is bound to a chair on a mountain peak, forced to watch the tragedy unfold through Morgoth’s magic."@en;
  plot:hasPlotEvent narn:NirnaethArnoediad, narn:HúrinCapture, narn:CurseOfHúrinFamily, narn:HúrinBoundToAChair;
  plot:startsWith narn:NirnaethArnoediad .

# ... other sections of the story


#
# Places
# We can distinguish plot locations, where the narration actually happens,
# and other places in the fictitious world that the plot locations may relate to
#
narn:Arda a loc:Region;
  rdfs:label "Arda"@qya, "The World"@en;
  rdfs:comment "The World within Ëa (all that exists), where events happen"@en .

narn:Endor a plot:PlotLocation, loc:Region;
  rdfs:label "Endor"@qya, "Middle-earth"@en;
  rdfs:comment "The part of the world in between Belegaer, the Western Sea, and the Easter Sea"@en;
  loc:isPartOf narn:Arda .

narn:Anfauglith a plot:PlotLocation, loc:Desert;
  rdfs:label "Anflauglith"@sjn, "Gasping Dust"@en;
  rdfs:comment "The desert plain to the north of Beleriand, charred by the fires of Thangorodrim since the battle of Dagor Bragollath."@en .

narn:Thangorodrim a plot:PlotLocation, loc:VolcanicMassif;
  rdfs:label "Thangorodrim"@sjn, "Mountains of Tyranny"@en;
  rdfs:comment "A group of three volcanic mountains and the highest peaks of Middle-earth"@en;
  loc:isPartOf narn:Endor;
  loc:tangentiallyConnectedTo narn:Anfauglith .

# ...other places of the story


#
# Characters
# Characters in the story are also real people from the point of view of the fictitious world
#
narn:Húrin a plot:Character, meo:Adan, fo:Male;
  rdfs:label "Húrin"@sjn;
  rdfs:comment "Húrin Thalion was the lord of Dor-lómin who went to battle against the forces of Morgoth during the Nirnaeth Arnoediad. He was cursed – as well as his family – by Morgoth, who forced him to watch the tragedies of his children through Morgoth's sorcery."@en .

narn:Morgoth a plot:Character, meo:Vala, meo:EvilBeing;
  rdfs:label "Morgoth"@sjn, "Black ennemy"@en;
  rdfs:comment "The greatest of the Ainur who became corrupted as he rebelled against the Creator Ilúvatar and combatted all beings that were not enslaved to him."@en .

# ...other characters in the story


#
# Events
# 
#
narn:NirnaethArnoediad a plot:PlotEvent, plot:Battle;
  rdfs:label "Nirnaeth Arnoediad"@sjn, "Battle of Unnumbered Tears"@en;
  rdfs:comment "The battle where a union of Elves, Men, and Dwarves fought the forces of Morgoth but were betrayed by Ulfang and his people, leading to a tragic defeat of the alliance."@en;
  plot:hasFighter narn:Húrin;
  plot:occursIn narn:Anfauglith;
  plot:before narn:CurseOfHúrinFamily .

narn:HúrinCapture a plot:PlotEvent, plot:Capture;
  rdfs:label "Húrin's capture"@en;
  rdfs:comment "The event between the moment Húrin is seized on the battle field and his arrival at Morgoth's fortress"@en;
  plot:during narn:NirnaethArnoediad;
  plot:occursIn narn:Anfauglith, narn:Thangorodrim;
  plot:hasCaptive narn:Húrin;
  plot:hasCaptor narn:Morgoth;
  plot:leadsTo narn:CurseOfHúrinFamily .

# Curses, like diseases or other temporary conditions, may be defined as events, but may also be seen as something different.
narn:CurseOfHúrinFamily a plot:Curse; 
  rdfs:label "Curse of Húrin's family"@en;
  plot:isCastBy narn:Morgoth;
  plot:targets narn:Húrin, narn:Morwen, narn:Túrin, narn:Nienor;
  plot:leadsTo narn:HúrinBoundToAChair .

narn:HúrinBoundToAChair a plot:PlotEvent, plot:Imprisonment;
  rdfs:label "Húrin bound to a chair"@en;
  plot:hasPrisoner narn:Húrin;
  plot:occursIn narn:Thangorodrim .

# ...other events


#
# More on the story structure and summary
#
narn:TúrinEarlyYears a plot:StorySection;
  rdfs:label "The Early Years: Húrin’s Family"@en;
  rdfs:comment "Húrin’s wife, Morwen, and their children, Túrin and Nienor, are left in Dor-lómin, a land now overrun by Easterlings loyal to Morgoth. Morwen, fearing for Túrin’s safety, sends him to the hidden Elven kingdom of Doriath, ruled by King Thingol and Queen Melian. Túrin is only eight years old, but he is strong-willed and proud, traits that will shape his fate."@en;
  plot:follows narn:Prologue .

narn:TúrinInDoriath a plot:StorySection;
  rdfs:label "Túrin in Doriath"@en;
  rdfs:comment "Túrin is fostered by Thingol and becomes close to Beleg, a march-warden of Doriath. He grows into a skilled warrior but is haunted by his past and the shadow of his father’s curse. Túrin accidentally causes the death of Saeros, a proud Elf who insults him. Fleeing Doriath, he joins a band of outlaws in the wilderness."@en;
  plot:follows narn:TúrinAndTheOutlaws .

narn:TúrinAndTheOutlaws a plot:StorySection;
  rdfs:label "The Outlaw and the Dragon-Helm"@en;
  rdfs:comment "Túrin becomes the leader of the outlaws, but his fierce temper and the curse lead to disaster. He is eventually captured by Orcs. Beleg rescues Túrin, but Túrin, mistaking Beleg for an enemy in the dark, kills him with his own sword, Gurthang. Overcome with grief, Túrin is found by the Elves of Nargothrond, who take him in. He adopts the name Gorthol (Dread Helm) and later Agarwaen (Bloodstained), hiding his true identity."@en;
  plot:follows narn:TúrinInDoriath .

narn:TúrinInNargothrond a plot:StorySection;
  rdfs:label "Nargothrond and the Rise of Glaurung"@en;
  rdfs:comment "Túrin rises to prominence in Nargothrond, becoming a great warrior and the right-hand man of King Orodreth. He convinces Orodreth to abandon the Elves’ secretive ways and openly challenge Morgoth, leading to the construction of a mighty bridge and the forging of a great army. Morgoth sends the dragon Glaurung to destroy Nargothrond. Túrin, seeking to slay the dragon, is ensnared by Glaurung’s lies. The dragon reveals Túrin’s true identity and the fate of his family, breaking his spirit. Túrin is tricked into believing his mother and sister are in danger, and he rushes to Dor-lómin, only to find his mother gone and his home in ruins."@en;
  plot:follows narn:TúrinAndTheOutlaws .

narn:NienorTale a plot:StorySection;
  rdfs:label "The Tragedy of Nienor"@en;
  rdfs:comment "Túrin’s sister, Nienor, sets out to find him, accompanied by Mablung, an Elf of Doriath. Glaurung ambushes them, and Nienor, in her terror, loses her memory. She is found by Túrin, who does not recognize her. Túrin, now calling himself Turambar (Master of Fate), marries Nienor, unaware of her true identity. They live in the forest of Brethil, where Nienor becomes pregnant. The dragon Glaurung attacks Brethil. Túrin slays the dragon but is poisoned by its blood. As he lies dying, Nienor’s memory returns, and she realizes the horror of their union. Overcome with despair, Nienor throws herself into the river Teiglin and drowns."@en;
  plot:follows narn:TúrinInNargothrond .

narn:FinalDoom a plot:StorySection;
  rdfs:label "The Final Doom"@en;
  rdfs:comment "Túrin, upon learning the truth, is consumed by grief and rage. He seeks out his sword, Gurthang, which speaks to him, revealing that it has been the instrument of all his misfortunes. Túrin throws himself upon Gurthang, ending his life. The sword shatters, and Túrin is buried beside Nienor. Morwen, having searched for her children in vain, arrives at Túrin’s grave and dies of grief."@en;
  plot:follows narn:NienorTale .

narn:Epilogue a plot:StorySection;
  rdfs:label "Epilogue: The End of the Curse"@en;
  rdfs:comment "Húrin is finally released by Morgoth, who believes the curse has run its course. Húrin travels to the graves of his children and mourns them. The tale ends with the burial of Túrin and Nienor, and the fulfillment of Morgoth’s curse. The stone marking their grave is known as the Stone of the Haunted, a silent testament to their tragedy."@en;
  plot:follows narn:FinalDoom .