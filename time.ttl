#
# Time Ontology
#
# Temporal concepts: instants, intervals, and Allen's 13 interval relations.
#
# FiniteInterval = StartingInterval AND EndingInterval (has both start and end).
#
# All 13 Allen relations with OWL characteristics. Pairwise disjointness
# only for simple relations (starts, startedBy, finishes, finishedBy).
#
# Property chains infer interval relations from instant-level data.
#

@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix tm:   <https://example.org/story/time#> .

tm: a owl:Ontology ;
    rdfs:label "Time Ontology"@en ;
    dct:title "Time Ontology"@en ;
    rdfs:comment "Instants, intervals, and Allen's 13 temporal relations."@en ;
    owl:versionInfo "1.0" ;
    dct:created "2026-03-28T00:00:00Z"^^xsd:dateTime .

###############################################################
# Classes
###############################################################

tm:TemporalEntity a owl:Class ;
    rdfs:label "Temporal entity"@en ;
    rdfs:comment "Superclass of instants and intervals."@en .

tm:Instant a owl:Class ;
    rdfs:subClassOf tm:TemporalEntity ;
    rdfs:label "Instant"@en ;
    rdfs:comment "A single point in time."@en ;
    rdfs:seeAlso <http://www.w3.org/2006/time#Instant> .

tm:Interval a owl:Class ;
    rdfs:subClassOf tm:TemporalEntity ;
    rdfs:label "Interval"@en ;
    rdfs:comment "A stretch of time between two instants."@en ;
    rdfs:seeAlso <http://www.w3.org/2006/time#Interval> .

tm:StartingInterval a owl:Class ;
    rdfs:subClassOf tm:Interval,
        [ a owl:Restriction ;
          owl:onProperty tm:startsAt ;
          owl:someValuesFrom tm:Instant ] ;
    rdfs:label "Starting interval"@en ;
    rdfs:comment "An interval with a known start."@en .

tm:EndingInterval a owl:Class ;
    rdfs:subClassOf tm:Interval,
        [ a owl:Restriction ;
          owl:onProperty tm:endsAt ;
          owl:someValuesFrom tm:Instant ] ;
    rdfs:label "Ending interval"@en ;
    rdfs:comment "An interval with a known end."@en .

tm:FiniteInterval a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf ( tm:StartingInterval tm:EndingInterval )
    ] ;
    rdfs:label "Finite interval"@en ;
    rdfs:comment "An interval with both a known start and a known end."@en .

tm:InfiniteInterval a owl:Class ;
    rdfs:subClassOf tm:Interval ;
    rdfs:label "Infinite interval"@en ;
    rdfs:comment "An interval unbounded on at least one side."@en .

# Disjointness
tm:Instant owl:disjointWith tm:Interval .
tm:FiniteInterval owl:disjointWith tm:InfiniteInterval .

###############################################################
# Instant-level properties
###############################################################

# A point interval is one where start = end (startsAt and endsAt
# point to the same instant). OWL 2 DL can't directly express
# start=end as an equivalentClass, so this is just a named subclass.
tm:PointInterval a owl:Class ;
    rdfs:subClassOf tm:FiniteInterval ;
    rdfs:label "Point interval"@en ;
    rdfs:comment "An interval with zero duration where start and end are the same instant. OWL 2 DL cannot express start=end as a class restriction, so this is a named subclass rather than a defined class."@en .

# An interval has at most one start and one end (Functional, declared below).
# A FiniteInterval has exactly 1 start and exactly 1 end.
tm:FiniteInterval rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty tm:startsAt ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onClass tm:Instant ],
    [ a owl:Restriction ; owl:onProperty tm:endsAt ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onClass tm:Instant ] .

# An InfiniteInterval has at most one start OR at most one end, but
# not both (that would make it finite). We can't express XOR in OWL,
# but we can say: an InfiniteInterval that has both start and end
# would be classified as FiniteInterval, causing inconsistency with
# the declared disjointness FiniteInterval/InfiniteInterval.

tm:startsAt a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Instant ;
    rdfs:label "starts at"@en ;
    rdfs:comment "When an interval begins."@en .

tm:endsAt a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Instant ;
    rdfs:label "ends at"@en ;
    rdfs:comment "When an interval ends."@en .

tm:occursBefore a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain tm:Instant ;
    rdfs:range tm:Instant ;
    rdfs:label "occurs before"@en ;
    rdfs:comment "Strict ordering between instants. Transitive. Asymmetry cannot be declared because the property is non-simple (transitive), but it holds by convention."@en .

tm:occursAfter a owl:ObjectProperty, owl:TransitiveProperty ;
    owl:inverseOf tm:occursBefore ;
    rdfs:domain tm:Instant ;
    rdfs:range tm:Instant ;
    rdfs:label "occurs after"@en ;
    rdfs:comment "Inverse of occursBefore."@en .

tm:occursSimultaneouslyWith a owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:domain tm:Instant ;
    rdfs:range tm:Instant ;
    rdfs:label "occurs simultaneously with"@en ;
    rdfs:comment "Two distinct instants at the same point in time. Used when different IRIs represent the same moment."@en .

tm:occursDuring a owl:ObjectProperty ;
    rdfs:domain tm:Instant ;
    rdfs:range tm:Interval ;
    rdfs:label "occurs during"@en ;
    rdfs:comment "An instant that falls within an interval."@en .

###############################################################
# Allen's 13 Interval Relations
###############################################################

# 1/2. BEFORE / AFTER
tm:beforeInterval a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Interval ;
    rdfs:label "before"@en ;
    rdfs:comment "Allen's 'before': first interval ends before second starts."@en .

tm:afterInterval a owl:ObjectProperty, owl:TransitiveProperty ;
    owl:inverseOf tm:beforeInterval ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Interval ;
    rdfs:label "after"@en ;
    rdfs:comment "Allen's 'after': inverse of before."@en .

# 3/4. MEETS / MET BY
tm:meetsInterval a owl:ObjectProperty, owl:AsymmetricProperty, owl:IrreflexiveProperty ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Interval ;
    rdfs:label "meets"@en ;
    rdfs:comment "Allen's 'meets': first interval ends exactly when second starts. Asymmetric (if I meets J, then J does not meet I) and irreflexive (an interval cannot meet itself)."@en .

tm:metByInterval a owl:ObjectProperty, owl:AsymmetricProperty, owl:IrreflexiveProperty ;
    owl:inverseOf tm:meetsInterval ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Interval ;
    rdfs:label "met by"@en ;
    rdfs:comment "Allen's 'met by': inverse of meets."@en .

# 5/6. OVERLAPS / OVERLAPPED BY
tm:overlapsInterval a owl:ObjectProperty, owl:AsymmetricProperty, owl:IrreflexiveProperty ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Interval ;
    rdfs:label "overlaps"@en ;
    rdfs:comment "Allen's 'overlaps': first starts before second and ends during it."@en .

tm:overlappedByInterval a owl:ObjectProperty, owl:AsymmetricProperty, owl:IrreflexiveProperty ;
    owl:inverseOf tm:overlapsInterval ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Interval ;
    rdfs:label "overlapped by"@en ;
    rdfs:comment "Allen's 'overlapped by': inverse of overlaps."@en .

# 7/8. STARTS / STARTED BY
tm:startsInterval a owl:ObjectProperty, owl:AsymmetricProperty, owl:IrreflexiveProperty ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Interval ;
    rdfs:label "starts"@en ;
    rdfs:comment "Allen's 'starts': same start time, first ends before second."@en .

tm:startedByInterval a owl:ObjectProperty, owl:AsymmetricProperty, owl:IrreflexiveProperty ;
    owl:inverseOf tm:startsInterval ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Interval ;
    rdfs:label "started by"@en ;
    rdfs:comment "Allen's 'started by': inverse of starts."@en .

# 9/10. DURING / CONTAINS
tm:duringInterval a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Interval ;
    rdfs:label "during"@en ;
    rdfs:comment "Allen's 'during': first interval is entirely within the second."@en .

tm:containsInterval a owl:ObjectProperty, owl:TransitiveProperty ;
    owl:inverseOf tm:duringInterval ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Interval ;
    rdfs:label "contains"@en ;
    rdfs:comment "Allen's 'contains': inverse of during."@en .

# 11/12. FINISHES / FINISHED BY
tm:finishesInterval a owl:ObjectProperty, owl:AsymmetricProperty, owl:IrreflexiveProperty ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Interval ;
    rdfs:label "finishes"@en ;
    rdfs:comment "Allen's 'finishes': same end time, first starts after second."@en .

tm:finishedByInterval a owl:ObjectProperty, owl:AsymmetricProperty, owl:IrreflexiveProperty ;
    owl:inverseOf tm:finishesInterval ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Interval ;
    rdfs:label "finished by"@en ;
    rdfs:comment "Allen's 'finished by': inverse of finishes."@en .

# 13. EQUALS
tm:intervalEquals a owl:ObjectProperty, owl:SymmetricProperty, owl:TransitiveProperty ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Interval ;
    rdfs:label "equals"@en ;
    rdfs:comment "Allen's 'equals': same start and end."@en .

###############################################################
# Pairwise disjointness of all SIMPLE Allen relations.
#
# In OWL 2 DL, propertyDisjointWith requires both properties to
# be simple (Section 11.1). The simple Allen relations are:
# meetsInterval, metByInterval, startsInterval, startedByInterval,
# finishesInterval, finishedByInterval (6 total).
#
# The non-simple ones (beforeInterval, afterInterval, duringInterval,
# containsInterval, overlapsInterval, overlappedByInterval,
# intervalEquals) cannot participate in disjointness axioms.
#
# All 15 pairs of the 6 simple relations are declared below.
###############################################################

# meets vs others
tm:meetsInterval owl:propertyDisjointWith
    tm:metByInterval,
    tm:startsInterval, tm:startedByInterval,
    tm:finishesInterval, tm:finishedByInterval .

# metBy vs remaining
tm:metByInterval owl:propertyDisjointWith
    tm:startsInterval, tm:startedByInterval,
    tm:finishesInterval, tm:finishedByInterval .

# starts vs remaining
tm:startsInterval owl:propertyDisjointWith
    tm:startedByInterval, tm:finishesInterval, tm:finishedByInterval .

# startedBy vs remaining
tm:startedByInterval owl:propertyDisjointWith
    tm:finishesInterval, tm:finishedByInterval .

# finishes vs finishedBy
tm:finishesInterval owl:propertyDisjointWith tm:finishedByInterval .

###############################################################
# Property chains: infer interval relations from instant data
###############################################################

# If end of I1 is before start of I2, then I1 before I2
tm:beforeInterval owl:propertyChainAxiom (
    tm:endsAt
    tm:occursBefore
    [ owl:inverseOf tm:startsAt ]
) .

# The meetsInterval chain (endsAt . startsAt^-1) is intentionally not
# declared. It over-generates: for point events where start = end, the
# chain infers that every point event meets itself, and that two
# simultaneous point events meet each other (conflicting with equals).
# Allen's meets requires strict inequality conditions that cannot be
# expressed in a 2-property OWL chain. All meets relations are asserted
# directly in the instance data instead.

###############################################################
# Allen composition chains
#
# From the Allen composition table, several 2-relation compositions
# yield a single deterministic result. These are the compositions
# where BOTH chain elements are either the super-property itself
# or a simple property, satisfying OWL 2 regularity (Section 11.1).
#
# meetsInterval is simple (not transitive, not chain-super). Adding
# chains with it in the body but NOT as the super-property preserves
# its simplicity. All compositions below are verified against the
# standard Allen composition table.
###############################################################

# --- Compositions into beforeInterval ---
# (super: beforeInterval is transitive; chain elements must be S or simple)

# meets(I1,I2) ^ meets(I2,I3) => before(I1,I3)
# I1.end=I2.start, I2.end=I3.start, I1.end < I2.end < I3.start
tm:beforeInterval owl:propertyChainAxiom ( tm:meetsInterval tm:meetsInterval ) .

# meets(I1,I2) ^ before(I2,I3) => before(I1,I3)
# I1 ends at I2's start, I2 entirely before I3
tm:beforeInterval owl:propertyChainAxiom ( tm:meetsInterval tm:beforeInterval ) .

# before(I1,I2) ^ meets(I2,I3) => before(I1,I3)
# I1 entirely before I2, I2 ends at I3's start
tm:beforeInterval owl:propertyChainAxiom ( tm:beforeInterval tm:meetsInterval ) .

# starts(I1,I2) ^ before(I2,I3) => before(I1,I3)
# I1 inside I2 sharing start, I2 entirely before I3
tm:beforeInterval owl:propertyChainAxiom ( tm:startsInterval tm:beforeInterval ) .

# starts(I1,I2) ^ meets(I2,I3) => before(I1,I3)
# I1 ends before I2, I2 ends at I3's start, so I1 ends before I3 starts
tm:beforeInterval owl:propertyChainAxiom ( tm:startsInterval tm:meetsInterval ) .

# finishes(I1,I2) ^ before(I2,I3) => before(I1,I3)
# I1 ends when I2 ends, I2 ends before I3 starts
tm:beforeInterval owl:propertyChainAxiom ( tm:finishesInterval tm:beforeInterval ) .

# --- Compositions into duringInterval ---
# (super: duringInterval is transitive; chain elements must be S or simple)

# starts(I1,I2) ^ during(I2,I3) => during(I1,I3)
# I1 inside I2, I2 inside I3 => I1 inside I3
tm:duringInterval owl:propertyChainAxiom ( tm:startsInterval tm:duringInterval ) .

# finishes(I1,I2) ^ during(I2,I3) => during(I1,I3)
tm:duringInterval owl:propertyChainAxiom ( tm:finishesInterval tm:duringInterval ) .

# during(I1,I2) ^ starts(I2,I3) => during(I1,I3)
# I1 inside I2, I2.start=I3.start and I2.end<I3.end, so I1 inside I3
tm:duringInterval owl:propertyChainAxiom ( tm:duringInterval tm:startsInterval ) .

# during(I1,I2) ^ finishes(I2,I3) => during(I1,I3)
# I1 inside I2, I2.end=I3.end and I2.start>I3.start, so I1 inside I3
tm:duringInterval owl:propertyChainAxiom ( tm:duringInterval tm:finishesInterval ) .

# --- Additional beforeInterval compositions ---

# during(I1,I2) ^ before(I2,I3) => before(I1,I3)
# I1 inside I2, I2 before I3 => I1 ends before I3 starts
tm:beforeInterval owl:propertyChainAxiom ( tm:duringInterval tm:beforeInterval ) .

# meets(I1,I2) ^ finishedBy(I2,I3) => before(I1,I3)
# I1.end=I2.start, I3 inside I2 sharing end, I3.start > I2.start
# so I1.end = I2.start < I3.start => I1 before I3
tm:beforeInterval owl:propertyChainAxiom ( tm:meetsInterval tm:finishedByInterval ) .

# meets(I1,I2) ^ startedBy(I2,I3) => meets(I1,I3)
# I1.end=I2.start, I3.start=I2.start => I1.end=I3.start, so I1 meets I3
# NOTE: this would make meetsInterval a chain-super, making it non-simple.
# That would break all 15 pairwise disjointness declarations.
# So this chain is INTENTIONALLY OMITTED. Documented here for the record.

# --- containsInterval compositions ---
# (super: containsInterval is transitive; chain elements can be anything)

# contains(I1,I2) ^ startedBy(I2,I3) => contains(I1,I3)
# I2 inside I1, I3 inside I2 sharing start => I3 inside I1
tm:containsInterval owl:propertyChainAxiom ( tm:containsInterval tm:startedByInterval ) .

# contains(I1,I2) ^ finishedBy(I2,I3) => contains(I1,I3)
# I2 inside I1, I3 inside I2 sharing end => I3 inside I1
tm:containsInterval owl:propertyChainAxiom ( tm:containsInterval tm:finishedByInterval ) .

# startedBy(I1,I2) ^ contains(I2,I3) => contains(I1,I3)
# I2 inside I1 sharing start, I3 inside I2 => I3 inside I1
tm:containsInterval owl:propertyChainAxiom ( tm:startedByInterval tm:containsInterval ) .

# finishedBy(I1,I2) ^ contains(I2,I3) => contains(I1,I3)
# I2 inside I1 sharing end, I3 inside I2 => I3 inside I1
tm:containsInterval owl:propertyChainAxiom ( tm:finishedByInterval tm:containsInterval ) .

# --- intervalEquals compositions ---

# eq(I1,I2) ^ eq(I2,I3) => eq(I1,I3) — this is transitivity, already declared.
# But eq composed with other relations preserves the other relation:
# eq(I1,I2) ^ before(I2,I3) => before(I1,I3) — trivially true via
#   the fact that eq is transitive and before is compatible with
#   substitution. However, declaring these as chains enables a
#   reasoner to propagate through eq links that are not sameAs.

tm:beforeInterval owl:propertyChainAxiom ( tm:intervalEquals tm:beforeInterval ) .
tm:beforeInterval owl:propertyChainAxiom ( tm:beforeInterval tm:intervalEquals ) .
tm:duringInterval owl:propertyChainAxiom ( tm:intervalEquals tm:duringInterval ) .
tm:duringInterval owl:propertyChainAxiom ( tm:duringInterval tm:intervalEquals ) .
tm:containsInterval owl:propertyChainAxiom ( tm:intervalEquals tm:containsInterval ) .
tm:containsInterval owl:propertyChainAxiom ( tm:containsInterval tm:intervalEquals ) .

# --- Additional before compositions ---

# during(I1,I2) ^ meets(I2,I3) => before(I1,I3)
# I1 inside I2 (I1.end < I2.end), I2 meets I3 (I2.end = I3.start).
# So I1.end < I2.end = I3.start => I1 ends before I3 starts.
tm:beforeInterval owl:propertyChainAxiom ( tm:duringInterval tm:meetsInterval ) .

# starts(I1,I2) ^ finishedBy(I2,I3) => before(I1,I3)
# I1 starts with I2 but ends earlier, I3 ends with I2 but starts later.
# So I1.end < I2.end and I3.start > I2.start >= I1.start.
# Since I1 ends before I2 and I3 starts inside I2: I1.end < I3.start.
tm:beforeInterval owl:propertyChainAxiom ( tm:startsInterval tm:finishedByInterval ) .

# during(I1,I2) ^ startedBy(I2,I3) => during(I1,I3) or before(I1,I3)?
# I1 strictly inside I2, I3 shares start with I2 but ends earlier.
# I1 could be inside I3 or could start after I3 ends. AMBIGUOUS, skip.

# --- Additional containsInterval compositions ---

# startedBy(I1,I2) ^ startedBy(I2,I3) => contains(I1,I3)
# I2 inside I1 sharing start, I3 inside I2 sharing start.
# I3.end <= I2.end < I1.end and I3.start = I2.start = I1.start.
# So I3 inside I1 sharing start => actually startedBy(I1,I3).
# But startedBy subPropertyOf contains? No. Contains is strictly inside.
# Actually startedBy is NOT subproperty of contains (different semantics).
# So this specific result is startedBy, not contains. Skip.

# --- Additional duringInterval compositions ---

# during(I1,I2) ^ startedBy(I2,I3) => during(I1,I3)
# I1 strictly inside I2, I3 shares start with I2 but ends inside I2.
# Since I3.start = I2.start and I3.end < I2.end, and I1 is strictly
# inside I2 (I1.start > I2.start), I1.start > I3.start is possible
# but I1.end < I2.end. We need I1 inside I3, but I1 could extend
# past I3.end. AMBIGUOUS, skip.

# meets ^ eq => meets. But would make meetsInterval chain-super. SKIP.

# --- Compositions producing during via overlaps ---
# overlaps(I1,I2) ^ overlaps(I2,I3) => ??? AMBIGUOUS. Skip.

# before(I1,I2) ^ contains(I2,I3) => before(I1,I3)
# I1 before I2, I3 inside I2 => I1.end < I2.start < I3.start
tm:beforeInterval owl:propertyChainAxiom ( tm:beforeInterval tm:containsInterval ) .

# meets(I1,I2) ^ contains(I2,I3) => before(I1,I3)
# I1.end = I2.start, I3 inside I2 so I3.start > I2.start = I1.end
tm:beforeInterval owl:propertyChainAxiom ( tm:meetsInterval tm:containsInterval ) .

# starts(I1,I2) ^ finishes(I2,I3) => during(I1,I3)
# I1 shares start with I2 but ends earlier, I2 shares end with I3 but starts later
# => I1 strictly inside I3
tm:duringInterval owl:propertyChainAxiom ( tm:startsInterval tm:finishesInterval ) .

# finishes(I1,I2) ^ starts(I2,I3) => during(I1,I3)
# I1 shares end with I2, I2 shares start with I3
# I1.start > I2.start = I3.start and I1.end = I2.end < I3.end
tm:duringInterval owl:propertyChainAxiom ( tm:finishesInterval tm:startsInterval ) .

# finishes(I1,I2) ^ meets(I2,I3) => before(I1,I3)
# I1 ends when I2 ends, I2 ends when I3 starts => I1 ends when I3 starts.
# Actually that's "meets", not "before". So this would make meetsInterval
# chain-super (non-simple). Can't add it. Leaving as documentation.

# before(I1,I2) ^ startedBy(I2,I3) => before(I1,I3)
# I1 before I2, I3 shares start with I2 (but ends earlier).
# I1.end < I2.start = I3.start => I1 before I3
tm:beforeInterval owl:propertyChainAxiom ( tm:beforeInterval tm:startedByInterval ) .

# finishedBy(I1,I2) ^ before(I2,I3) => before or contains? 
# I2 inside I1 sharing end. I2 before I3. I2.end = I1.end < I3.start.
# So I1.end < I3.start => I1 before I3.  
# Wait, but does I1 overlap I3? I1.end < I3.start (yes, from I2.end = I1.end and I2 before I3).
# So I1 before I3. YES.
tm:beforeInterval owl:propertyChainAxiom ( tm:finishedByInterval tm:beforeInterval ) .

# startedBy(I1,I2) ^ before(I2,I3) => ??? 
# I2 inside I1 sharing start. I2 before I3. 
# I2.end < I1.end and I2.end < I3.start. But I1.end > I2.end >= I3.start? Ambiguous. Skip.
