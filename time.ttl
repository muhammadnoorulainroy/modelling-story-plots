#
# Time Ontology
#
# Temporal concepts: instants, intervals, and Allen's 13 interval relations.
#

@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix tm:   <https://example.org/story/time#> .

tm: a owl:Ontology ;
    rdfs:label "Time Ontology"@en ;
    dct:title "Time Ontology"@en ;
    rdfs:comment "Instants, intervals, and Allen's 13 temporal relations."@en ;
    owl:versionInfo "1.0" ;
    dct:created "2026-03-28T00:00:00Z"^^xsd:dateTime .

###############################################################
# Classes
###############################################################

tm:TemporalEntity a owl:Class ;
    rdfs:label "Temporal entity"@en ;
    rdfs:comment "Superclass of instants and intervals."@en .

tm:Instant a owl:Class ;
    rdfs:subClassOf tm:TemporalEntity ;
    rdfs:label "Instant"@en ;
    rdfs:comment "A single point in time."@en .

tm:Interval a owl:Class ;
    rdfs:subClassOf tm:TemporalEntity ;
    rdfs:label "Interval"@en ;
    rdfs:comment "A stretch of time between two instants."@en .

tm:StartingInterval a owl:Class ;
    rdfs:subClassOf tm:Interval,
        [ a owl:Restriction ;
          owl:onProperty tm:startsAt ;
          owl:someValuesFrom tm:Instant ] ;
    rdfs:label "Starting interval"@en ;
    rdfs:comment "An interval with a known start."@en .

tm:EndingInterval a owl:Class ;
    rdfs:subClassOf tm:Interval,
        [ a owl:Restriction ;
          owl:onProperty tm:endsAt ;
          owl:someValuesFrom tm:Instant ] ;
    rdfs:label "Ending interval"@en ;
    rdfs:comment "An interval with a known end."@en .

tm:FiniteInterval a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf ( tm:StartingInterval tm:EndingInterval )
    ] ;
    rdfs:label "Finite interval"@en ;
    rdfs:comment "An interval with both start and end. Defined as StartingInterval and EndingInterval."@en .

tm:InfiniteInterval a owl:Class ;
    rdfs:subClassOf tm:Interval ;
    rdfs:label "Infinite interval"@en ;
    rdfs:comment "An interval unbounded on at least one side."@en .

# Disjointness
tm:Instant owl:disjointWith tm:Interval .
tm:FiniteInterval owl:disjointWith tm:InfiniteInterval .

###############################################################
# Instant-level properties
###############################################################

tm:startsAt a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Instant ;
    rdfs:label "starts at"@en ;
    rdfs:comment "When an interval begins."@en .

tm:endsAt a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Instant ;
    rdfs:label "ends at"@en ;
    rdfs:comment "When an interval ends."@en .

tm:occursBefore a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain tm:Instant ;
    rdfs:range tm:Instant ;
    rdfs:label "occurs before"@en ;
    rdfs:comment "Strict ordering between instants."@en .

tm:occursAfter a owl:ObjectProperty, owl:TransitiveProperty ;
    owl:inverseOf tm:occursBefore ;
    rdfs:domain tm:Instant ;
    rdfs:range tm:Instant ;
    rdfs:label "occurs after"@en ;
    rdfs:comment "Inverse of occursBefore."@en .

tm:occursSimultaneouslyWith a owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:domain tm:Instant ;
    rdfs:range tm:Instant ;
    rdfs:label "occurs simultaneously with"@en ;
    rdfs:comment "Two instants at the same point in time."@en .

tm:occursDuring a owl:ObjectProperty ;
    rdfs:domain tm:Instant ;
    rdfs:range tm:Interval ;
    rdfs:label "occurs during"@en ;
    rdfs:comment "An instant that falls within an interval."@en .

###############################################################
# Allen's 13 Interval Relations
###############################################################

# 1/2. BEFORE / AFTER
tm:beforeInterval a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Interval ;
    rdfs:label "before"@en ;
    rdfs:comment "Allen's 'before': first interval ends before second starts."@en .

tm:afterInterval a owl:ObjectProperty, owl:TransitiveProperty ;
    owl:inverseOf tm:beforeInterval ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Interval ;
    rdfs:label "after"@en ;
    rdfs:comment "Allen's 'after': inverse of before."@en .

# 3/4. MEETS / MET BY
tm:meetsInterval a owl:ObjectProperty ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Interval ;
    rdfs:label "meets"@en ;
    rdfs:comment "Allen's 'meets': first interval ends exactly when second starts."@en .

tm:metByInterval a owl:ObjectProperty ;
    owl:inverseOf tm:meetsInterval ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Interval ;
    rdfs:label "met by"@en ;
    rdfs:comment "Allen's 'met by': inverse of meets."@en .

# 5/6. OVERLAPS / OVERLAPPED BY
tm:overlapsInterval a owl:ObjectProperty, owl:AsymmetricProperty, owl:IrreflexiveProperty ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Interval ;
    rdfs:label "overlaps"@en ;
    rdfs:comment "Allen's 'overlaps': first starts before second and ends during it."@en .

tm:overlappedByInterval a owl:ObjectProperty, owl:AsymmetricProperty, owl:IrreflexiveProperty ;
    owl:inverseOf tm:overlapsInterval ;
    rdfs:domain tm:Interval ;
    rdfs:range tm:Interval ;
    rdfs:label "overlapped by"@en ;
    rdfs:comment "Allen's 'overlapped by': inverse of overlaps."@en .
